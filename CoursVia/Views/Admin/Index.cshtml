@model CoursVia.ViewModels.Admin.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Paneli";

    string KritikSayiClass(int sayi)
    {
        return sayi > 0
            ? "text-amber-700"
            : "text-slate-900";
    }

    string LogAciklama(string? aciklama)
    {
        return string.IsNullOrWhiteSpace(aciklama)
            ? "Açıklama bulunmuyor."
            : aciklama;
    }
}

<div class="min-h-[calc(100vh-130px)] bg-slate-50">

    <div class="grid min-h-[calc(100vh-130px)] grid-cols-1 lg:grid-cols-[300px_minmax(0,1fr)]">

        <partial name="_AdminSidebar" />

        <main class="min-w-0 px-5 py-7 sm:px-7 lg:px-10">

            <div class="mx-auto max-w-7xl space-y-6">

                @if (TempData["AdminHata"] != null)
                {
                    <div class="flash-message alert alert-error rounded-2xl shadow-sm transition-all duration-500">
                        <span>@TempData["AdminHata"]</span>
                    </div>
                }

                @if (TempData["AdminBasari"] != null)
                {
                    <div class="flash-message alert rounded-2xl border border-emerald-100 bg-emerald-50 text-emerald-700 shadow-sm transition-all duration-500">
                        <span>@TempData["AdminBasari"]</span>
                    </div>
                }

                <!-- Üst Başlık -->
                <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
                    <div class="flex flex-col gap-5 md:flex-row md:items-center md:justify-between">

                        <div>
                            <p class="text-sm font-semibold text-blue-600">
                                Admin Paneli
                            </p>

                            <h1 class="mt-2 text-3xl font-black tracking-tight text-slate-900">
                                Hoş geldiniz, @Model.AdminAdSoyad
                            </h1>

                            <div class="mt-2 flex items-center gap-2 text-sm font-medium text-slate-500">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     fill="none"
                                     viewBox="0 0 24 24"
                                     stroke-width="1.5"
                                     stroke="currentColor"
                                     class="h-5 w-5 text-blue-500">
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                </svg>

                                <span id="dynamic-clock"></span>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Özet Kartları -->
                <section class="grid grid-cols-1 gap-4 md:grid-cols-3">

                    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                        <div class="flex items-center justify-between gap-4">

                            <div>
                                <p class="text-xs font-black uppercase tracking-wide text-slate-400">
                                    Toplam Kullanıcı
                                </p>

                                <p class="mt-2 text-3xl font-black text-slate-900">
                                    @Model.ToplamKullaniciSayisi
                                </p>
                            </div>

                            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-slate-100 text-slate-700">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     fill="none"
                                     viewBox="0 0 24 24"
                                     stroke-width="2"
                                     stroke="currentColor"
                                     class="h-5 w-5">
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          d="M18 18.75a6 6 0 0 0-12 0M12 12a3.75 3.75 0 1 0 0-7.5 3.75 3.75 0 0 0 0 7.5Z" />
                                </svg>
                            </div>

                        </div>
                    </div>

                    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                        <div class="flex items-center justify-between gap-4">

                            <div>
                                <p class="text-xs font-black uppercase tracking-wide text-slate-400">
                                    Online Kullanıcı
                                </p>

                                <p class="mt-2 text-3xl font-black text-emerald-700">
                                    @Model.OnlineKullaniciSayisi
                                </p>
                            </div>

                            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-700">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     fill="none"
                                     viewBox="0 0 24 24"
                                     stroke-width="2"
                                     stroke="currentColor"
                                     class="h-5 w-5">
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.5 20.25a7.5 7.5 0 0 1 15 0M19.5 8.25h.008v.008H19.5V8.25Z" />
                                </svg>
                            </div>

                        </div>
                    </div>

                    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                        <div class="flex items-center justify-between gap-4">

                            <div>
                                <p class="text-xs font-black uppercase tracking-wide text-slate-400">
                                    Yayındaki Kurs
                                </p>

                                <p class="mt-2 text-3xl font-black text-emerald-700">
                                    @Model.YayindakiKursSayisi
                                </p>
                            </div>

                            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-700">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     fill="none"
                                     viewBox="0 0 24 24"
                                     stroke-width="2"
                                     stroke="currentColor"
                                     class="h-5 w-5">
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25A8.967 8.967 0 0 1 18 3.75c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                                </svg>
                            </div>

                        </div>
                    </div>

                </section>

                <!-- Onay Süreçleri -->
                <section class="grid grid-cols-1 gap-4 lg:grid-cols-2">

                    <a asp-controller="AdminEgitmenBasvuru"
                       asp-action="Basvurular"
                       class="group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">

                        <div class="flex items-center justify-between gap-4">

                            <div>
                                <p class="text-xs font-black uppercase tracking-wide text-slate-400">
                                    Onay Bekleyen Eğitmen
                                </p>

                                <p class="mt-2 text-3xl font-black @KritikSayiClass(Model.OnayBekleyenEgitmenSayisi)">
                                    @Model.OnayBekleyenEgitmenSayisi
                                </p>
                            </div>

                            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-amber-50 text-amber-700 transition group-hover:bg-amber-100">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     fill="none"
                                     viewBox="0 0 24 24"
                                     stroke-width="2"
                                     stroke="currentColor"
                                     class="h-5 w-5">
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.5 20.25a7.5 7.5 0 0 1 15 0M18 8.25l1.5 1.5 3-3" />
                                </svg>
                            </div>

                        </div>

                        <p class="mt-3 text-sm font-semibold text-slate-500">
                            Eğitmen başvuruları.
                        </p>

                    </a>

                    <a asp-controller="AdminKursOnay"
                       asp-action="Basvurular"
                       class="group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">

                        <div class="flex items-center justify-between gap-4">

                            <div>
                                <p class="text-xs font-black uppercase tracking-wide text-slate-400">
                                    Onay Bekleyen Kurs
                                </p>

                                <p class="mt-2 text-3xl font-black @KritikSayiClass(Model.OnayBekleyenKursSayisi)">
                                    @Model.OnayBekleyenKursSayisi
                                </p>
                            </div>

                            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-amber-50 text-amber-700 transition group-hover:bg-amber-100">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     fill="none"
                                     viewBox="0 0 24 24"
                                     stroke-width="2"
                                     stroke="currentColor"
                                     class="h-5 w-5">
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25A8.967 8.967 0 0 1 18 3.75c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                                </svg>
                            </div>

                        </div>

                        <p class="mt-3 text-sm font-semibold text-slate-500">
                            Yayın onayı bekleyen kurslar.
                        </p>

                    </a>

                </section>

                <!-- Son İşlemler -->
                <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">

                    <div class="border-b border-slate-100 px-5 py-4">

                        <h2 class="text-base font-black text-slate-900">
                            Son Admin İşlemleri
                        </h2>

                        <p class="mt-1 text-sm text-slate-500">
                            Son kaydedilen yönetici hareketleri.
                        </p>

                    </div>

                    @if (Model.SonIslemler.Any())
                    {
                        <div class="divide-y divide-slate-100">

                            @foreach (var islem in Model.SonIslemler)
                            {
                                <article class="px-5 py-4 transition hover:bg-slate-50">

                                    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">

                                        <div class="min-w-0">

                                            <div class="flex flex-wrap items-center gap-2">

                                                <h3 class="text-sm font-black text-slate-900">
                                                    @islem.IslemTipi
                                                </h3>

                                                <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-bold text-slate-500">
                                                    @islem.AdminAdSoyad
                                                </span>

                                            </div>

                                            <p class="mt-2 line-clamp-2 text-sm leading-6 text-slate-500">
                                                @LogAciklama(islem.Aciklama)
                                            </p>

                                        </div>

                                        <div class="shrink-0 text-left sm:text-right">

                                            <p class="text-xs font-bold text-slate-400">
                                                @islem.IslemTarihi.ToString("dd.MM.yyyy")
                                            </p>

                                            <p class="mt-0.5 text-xs font-semibold text-slate-400">
                                                @islem.IslemTarihi.ToString("HH:mm")
                                            </p>

                                        </div>

                                    </div>

                                </article>
                            }

                        </div>
                    }
                    else
                    {
                        <div class="px-6 py-12 text-center">

                            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-2xl bg-slate-100 text-slate-500">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     fill="none"
                                     viewBox="0 0 24 24"
                                     stroke-width="2"
                                     stroke="currentColor"
                                     class="h-5 w-5">
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          d="M8.25 6.75h7.5M8.25 12h7.5M8.25 17.25h4.5M6 3.75h12A2.25 2.25 0 0 1 20.25 6v12A2.25 2.25 0 0 1 18 20.25H6A2.25 2.25 0 0 1 3.75 18V6A2.25 2.25 0 0 1 6 3.75Z" />
                                </svg>
                            </div>

                            <h3 class="mt-4 text-base font-black text-slate-900">
                                İşlem kaydı bulunmuyor
                            </h3>

                            <p class="mt-1 text-sm text-slate-500">
                                Admin işlemleri burada listelenir.
                            </p>

                        </div>
                    }

                </section>

            </div>

        </main>

    </div>

</div>

@section Scripts {
    <script>
        function updateClock() {
            const now = new Date();

            const timeString = now.toLocaleTimeString('tr-TR', {
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit'
            });

            const dateString = now.toLocaleDateString('tr-TR', {
                weekday: 'long',
                year: 'numeric',
                month: 'long',
                day: 'numeric'
            });

            const clockElement = document.getElementById('dynamic-clock');

            if (clockElement) {
                clockElement.textContent = `${dateString} | ${timeString}`;
            }
        }

        updateClock();
        setInterval(updateClock, 1000);
    </script>
}
