@using Microsoft.EntityFrameworkCore
@inject CoursVia.Data.AppDbContext DbContext

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    int bekleyenEgitmenBasvuruSayisi = await DbContext.EgitmenProfilleri
        .AsNoTracking()
        .CountAsync(x => x.DurumId == 4);

    int bekleyenKursOnaySayisi = await DbContext.Kurslar
        .AsNoTracking()
        .CountAsync(x => x.DurumId == 4);

    bool dashboardAktif = currentController == "Admin" &&
        currentAction == "Index";

    bool egitmenBasvurulariAktif = currentController == "AdminEgitmenBasvuru" &&
        (currentAction == "Basvurular" ||
         currentAction == "Detay");

    bool kursOnaylariAktif = currentController == "AdminKursOnay" &&
        (currentAction == "Basvurular" ||
         currentAction == "Detay");

    bool kullanicilarAktif = currentController == "AdminKullanici" &&
        (currentAction == "Kullanicilar" ||
         currentAction == "Detay" ||
         currentAction == "Duzenle");

    bool kurslarAktif = currentController == "AdminKurs" &&
        (currentAction == "Kurslar" ||
         currentAction == "Detay");

    bool yorumlarAktif = currentController == "AdminYorum" &&
        currentAction == "Yorumlar";

    bool kategorilerAktif = currentController == "AdminKategori" &&
        currentAction == "Kategoriler";

    bool bildirimlerAktif = currentController == "Bildirim" &&
        currentAction == "Bildirimler";

    bool loglarAktif = currentController == "AdminLog" &&
        currentAction == "Loglar";
}

<aside class="my-5 h-fit rounded-3xl border border-slate-200 bg-white p-3 shadow-sm lg:sticky lg:top-24 lg:ml-4">

    <div class="mb-3 px-2 pt-1">
        <p class="text-xs font-bold uppercase tracking-wider text-blue-600">
            Admin Paneli
        </p>

        <h2 class="mt-1 text-base font-black text-slate-900">
            Yönetim
        </h2>
    </div>

    <nav class="space-y-3">

        <!-- Panel -->
        <div>
            <p class="mb-1.5 px-2 text-[11px] font-black uppercase tracking-wider text-slate-400">
                Panel
            </p>

            <div class="space-y-1.5">

                <a asp-controller="Admin"
                   asp-action="Index"
                   class="group flex items-center gap-3 rounded-xl border px-3 py-2 text-sm font-semibold transition-colors
                          @(dashboardAktif
                                               ? "border-blue-100 bg-blue-50 text-blue-700"
                                               : "border-transparent text-slate-600 hover:border-slate-200 hover:bg-slate-50 hover:text-blue-600")">

                    <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg
                                 @(dashboardAktif
                                                              ? "bg-blue-100 text-blue-700"
                                                              : "bg-slate-100 text-slate-500 group-hover:bg-blue-50 group-hover:text-blue-600")">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke-width="2"
                             stroke="currentColor"
                             class="h-5 w-5">
                            <path stroke-linecap="round"
                                  stroke-linejoin="round"
                                  d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25A2.25 2.25 0 0 1 13.5 18v-2.25Z" />
                        </svg>
                    </span>

                    <span>Dashboard</span>
                </a>

            </div>
        </div>

        <!-- Onay Süreçleri -->
        <div>
            <p class="mb-1.5 px-2 text-[11px] font-black uppercase tracking-wider text-slate-400">
                Onay Süreçleri
            </p>

            <div class="space-y-1.5">

                <a asp-controller="AdminEgitmenBasvuru"
                   asp-action="Basvurular"
                   class="group flex items-center gap-3 rounded-xl border px-3 py-2 text-sm font-semibold transition-colors
                          @(egitmenBasvurulariAktif
                                               ? "border-blue-100 bg-blue-50 text-blue-700"
                                               : "border-transparent text-slate-600 hover:border-slate-200 hover:bg-slate-50 hover:text-blue-600")">

                    <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg
                                 @(egitmenBasvurulariAktif
                                                              ? "bg-blue-100 text-blue-700"
                                                              : "bg-slate-100 text-slate-500 group-hover:bg-blue-50 group-hover:text-blue-600")">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke-width="2"
                             stroke="currentColor"
                             class="h-5 w-5">
                            <path stroke-linecap="round"
                                  stroke-linejoin="round"
                                  d="M15 9.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0ZM4.5 20.25a8.25 8.25 0 0 1 15 0M17.25 8.25l1.5 1.5 3-3" />
                        </svg>
                    </span>

                    <span class="min-w-0 flex-1 truncate">
                        Eğitmen Başvuruları
                    </span>

                    @if (bekleyenEgitmenBasvuruSayisi > 0)
                    {
                        <span class="ml-auto inline-flex min-w-6 items-center justify-center rounded-full bg-red-500 px-2 py-0.5 text-[11px] font-black leading-5 text-white shadow-sm">
                            @bekleyenEgitmenBasvuruSayisi
                        </span>
                    }
                </a>

                <a asp-controller="AdminKursOnay"
                   asp-action="Basvurular"
                   class="group flex items-center gap-3 rounded-xl border px-3 py-2 text-sm font-semibold transition-colors
                          @(kursOnaylariAktif
                                               ? "border-blue-100 bg-blue-50 text-blue-700"
                                               : "border-transparent text-slate-600 hover:border-slate-200 hover:bg-slate-50 hover:text-blue-600")">

                    <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg
                                 @(kursOnaylariAktif
                                                              ? "bg-blue-100 text-blue-700"
                                                              : "bg-slate-100 text-slate-500 group-hover:bg-blue-50 group-hover:text-blue-600")">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke-width="2"
                             stroke="currentColor"
                             class="h-5 w-5">
                            <path stroke-linecap="round"
                                  stroke-linejoin="round"
                                  d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25A8.967 8.967 0 0 1 18 3.75c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                        </svg>
                    </span>

                    <span class="min-w-0 flex-1 truncate">
                        Kurs Onayları
                    </span>

                    @if (bekleyenKursOnaySayisi > 0)
                    {
                        <span class="ml-auto inline-flex min-w-6 items-center justify-center rounded-full bg-red-500 px-2 py-0.5 text-[11px] font-black leading-5 text-white shadow-sm">
                            @bekleyenKursOnaySayisi
                        </span>
                    }
                </a>

            </div>
        </div>

        <!-- Yönetim -->
        <div>
            <p class="mb-1.5 px-2 text-[11px] font-black uppercase tracking-wider text-slate-400">
                Yönetim
            </p>

            <div class="space-y-1.5">

                <a asp-controller="AdminKullanici"
                   asp-action="Kullanicilar"
                   class="group flex items-center gap-3 rounded-xl border px-3 py-2 text-sm font-semibold transition-colors
                          @(kullanicilarAktif
                                               ? "border-blue-100 bg-blue-50 text-blue-700"
                                               : "border-transparent text-slate-600 hover:border-slate-200 hover:bg-slate-50 hover:text-blue-600")">

                    <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg
                                 @(kullanicilarAktif
                                                              ? "bg-blue-100 text-blue-700"
                                                              : "bg-slate-100 text-slate-500 group-hover:bg-blue-50 group-hover:text-blue-600")">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke-width="2"
                             stroke="currentColor"
                             class="h-5 w-5">
                            <path stroke-linecap="round"
                                  stroke-linejoin="round"
                                  d="M18 18.75a6 6 0 0 0-12 0M12 12a3.75 3.75 0 1 0 0-7.5 3.75 3.75 0 0 0 0 7.5Zm7.5 6.75a4.5 4.5 0 0 0-3-4.243M4.5 18.75a4.5 4.5 0 0 1 3-4.243" />
                        </svg>
                    </span>

                    <span>Kullanıcılar</span>
                </a>

                <a asp-controller="AdminKurs"
                   asp-action="Kurslar"
                   class="group flex items-center gap-3 rounded-xl border px-3 py-2 text-sm font-semibold transition-colors
                          @(kurslarAktif
                                               ? "border-blue-100 bg-blue-50 text-blue-700"
                                               : "border-transparent text-slate-600 hover:border-slate-200 hover:bg-slate-50 hover:text-blue-600")">

                    <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg
                                 @(kurslarAktif
                                                              ? "bg-blue-100 text-blue-700"
                                                              : "bg-slate-100 text-slate-500 group-hover:bg-blue-50 group-hover:text-blue-600")">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke-width="2"
                             stroke="currentColor"
                             class="h-5 w-5">
                            <path stroke-linecap="round"
                                  stroke-linejoin="round"
                                  d="M4.5 6.75h15M4.5 12h15M4.5 17.25h15" />
                        </svg>
                    </span>

                    <span>Kurslar</span>
                </a>

                <a asp-controller="AdminYorum"
                   asp-action="Yorumlar"
                   class="group flex items-center gap-3 rounded-xl border px-3 py-2 text-sm font-semibold transition-colors
                          @(yorumlarAktif
                                               ? "border-blue-100 bg-blue-50 text-blue-700"
                                               : "border-transparent text-slate-600 hover:border-slate-200 hover:bg-slate-50 hover:text-blue-600")">

                    <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg
                                 @(yorumlarAktif
                                                              ? "bg-blue-100 text-blue-700"
                                                              : "bg-slate-100 text-slate-500 group-hover:bg-blue-50 group-hover:text-blue-600")">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke-width="2"
                             stroke="currentColor"
                             class="h-5 w-5">
                            <path stroke-linecap="round"
                                  stroke-linejoin="round"
                                  d="M7.5 8.25h9M7.5 12h6m-8.25 7.5 3.75-3.75H18A2.25 2.25 0 0 0 20.25 13.5V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v7.5A2.25 2.25 0 0 0 6 15.75h.75v3.75Z" />
                        </svg>
                    </span>

                    <span>Yorumlar</span>
                </a>

                <a asp-controller="AdminKategori"
                   asp-action="Kategoriler"
                   class="group flex items-center gap-3 rounded-xl border px-3 py-2 text-sm font-semibold transition-colors
                          @(kategorilerAktif
                                               ? "border-blue-100 bg-blue-50 text-blue-700"
                                               : "border-transparent text-slate-600 hover:border-slate-200 hover:bg-slate-50 hover:text-blue-600")">

                    <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg
                                 @(kategorilerAktif
                                                              ? "bg-blue-100 text-blue-700"
                                                              : "bg-slate-100 text-slate-500 group-hover:bg-blue-50 group-hover:text-blue-600")">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke-width="2"
                             stroke="currentColor"
                             class="h-5 w-5">
                            <path stroke-linecap="round"
                                  stroke-linejoin="round"
                                  d="M4.5 6.75h6.75v6.75H4.5V6.75Zm8.25 0h6.75v6.75h-6.75V6.75ZM4.5 15h6.75v2.25H4.5V15Zm8.25 0h6.75v2.25h-6.75V15Z" />
                        </svg>
                    </span>

                    <span>Kategoriler</span>
                </a>

            </div>
        </div>

        <!-- Sistem -->
        <div>
            <p class="mb-1.5 px-2 text-[11px] font-black uppercase tracking-wider text-slate-400">
                Sistem
            </p>

            <div class="space-y-1.5">

                <a asp-controller="Bildirim"
                   asp-action="Bildirimler"
                   class="group flex items-center gap-3 rounded-xl border px-3 py-2 text-sm font-semibold transition-colors
                          @(bildirimlerAktif
                                               ? "border-blue-100 bg-blue-50 text-blue-700"
                                               : "border-transparent text-slate-600 hover:border-slate-200 hover:bg-slate-50 hover:text-blue-600")">

                    <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg
                                 @(bildirimlerAktif
                                                              ? "bg-blue-100 text-blue-700"
                                                              : "bg-slate-100 text-slate-500 group-hover:bg-blue-50 group-hover:text-blue-600")">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke-width="2"
                             stroke="currentColor"
                             class="h-5 w-5">
                            <path stroke-linecap="round"
                                  stroke-linejoin="round"
                                  d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a3 3 0 0 1-5.714 0" />
                        </svg>
                    </span>

                    <span>Bildirimler</span>
                </a>

                <a asp-controller="AdminLog"
                   asp-action="Loglar"
                   class="group flex items-center gap-3 rounded-xl border px-3 py-2 text-sm font-semibold transition-colors
                          @(loglarAktif
                                               ? "border-blue-100 bg-blue-50 text-blue-700"
                                               : "border-transparent text-slate-600 hover:border-slate-200 hover:bg-slate-50 hover:text-blue-600")">

                    <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg
                                 @(loglarAktif
                                                              ? "bg-blue-100 text-blue-700"
                                                              : "bg-slate-100 text-slate-500 group-hover:bg-blue-50 group-hover:text-blue-600")">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             fill="none"
                             viewBox="0 0 24 24"
                             stroke-width="2"
                             stroke="currentColor"
                             class="h-5 w-5">
                            <path stroke-linecap="round"
                                  stroke-linejoin="round"
                                  d="M8.25 6.75h7.5M8.25 12h7.5M8.25 17.25h4.5M6 3.75h12A2.25 2.25 0 0 1 20.25 6v12A2.25 2.25 0 0 1 18 20.25H6A2.25 2.25 0 0 1 3.75 18V6A2.25 2.25 0 0 1 6 3.75Z" />
                        </svg>
                    </span>

                    <span>Admin Logları</span>
                </a>

            </div>
        </div>

    </nav>

</aside>
