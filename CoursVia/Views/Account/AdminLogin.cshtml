@{
    Layout = null;
    ViewData["Title"] = "Admin Girişi";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Admin Girişi - CoursVia</title>

    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/sweetalert2/sweetalert2.min.css" />
</head>

<body class="min-h-screen bg-slate-50 text-slate-900 font-sans">

    <div class="min-h-screen flex items-center justify-center px-4 py-10 sm:px-6 lg:px-8">

        <div class="w-full max-w-md">

            <!-- Logo / Başlık -->
            <div class="text-center mb-8">
                <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-blue-600 text-white shadow-lg">
                    <svg xmlns="http://www.w3.org/2000/svg"
                         fill="none"
                         viewBox="0 0 24 24"
                         stroke-width="2"
                         stroke="currentColor"
                         class="w-8 h-8">
                        <path stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M12 3.75 4.5 6.75v5.25c0 4.62 3.15 8.93 7.5 10.25 4.35-1.32 7.5-5.63 7.5-10.25V6.75L12 3.75Z" />
                        <path stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M9.75 12.75 11.25 14.25 14.25 10.5" />
                    </svg>
                </div>

                <h1 class="mt-6 text-4xl font-black text-blue-600 tracking-tight">
                    CoursVia
                </h1>

             
            </div>

            <!-- Kart -->
            <div class="rounded-3xl border border-slate-200 bg-white shadow-sm overflow-hidden">

                <div class="border-b border-slate-200 px-6 py-5 sm:px-8">
                    <h2 class="text-xl font-black text-slate-900">
                        Admin Girişi
                    </h2>

                  
                </div>

                <div class="p-6 sm:p-8">

                    @if (ViewBag.Hata != null)
                    {
                        <div class="flash-message mb-5 rounded-2xl border border-red-200 bg-red-50 p-4 transition-all duration-500">
                            <p class="text-sm font-medium text-red-700">
                                @ViewBag.Hata
                            </p>
                        </div>
                    }

                    @if (TempData["Basari"] != null)
                    {
                        <div class="flash-message mb-5 rounded-2xl border border-emerald-200 bg-emerald-50 p-4 transition-all duration-500">
                            <p class="text-sm font-medium text-emerald-700">
                                @TempData["Basari"]
                            </p>
                        </div>
                    }

                    <form asp-controller="Account"
                          asp-action="AdminLogin"
                          method="post"
                          class="space-y-5">

                        <div>
                            <label class="block text-sm font-semibold text-slate-700 mb-1">
                                E-posta
                            </label>

                            <input type="email"
                                   name="eposta"
                                   class="input input-bordered w-full rounded-xl border-slate-300 bg-white shadow-sm focus:border-blue-500"
                                   placeholder="ornek@mail.com"
                                   autocomplete="email"
                                   required />
                        </div>

                        <div>
                            <div class="flex items-center justify-between mb-1">
                                <label class="block text-sm font-semibold text-slate-700">
                                    Şifre
                                </label>

                                <a asp-controller="Account"
                                   asp-action="ForgotPassword"
                                   class="text-sm font-semibold text-blue-600 hover:text-blue-700">
                                    Şifremi unuttum
                                </a>
                            </div>

                            <input type="password"
                                   name="sifre"
                                   class="input input-bordered w-full rounded-xl border-slate-300 bg-white shadow-sm focus:border-blue-500"
                                   placeholder="••••••••"
                                   autocomplete="current-password"
                                   required />
                        </div>

                        <button type="submit"
                                class="btn btn-primary w-full rounded-xl">
                            Admin Girişi Yap
                        </button>
                    </form>



                    <div class="mt-6 flex justify-center">
                        <a asp-controller="Home"
                           asp-action="Index"
                           class="btn btn-outline rounded-xl px-8">
                            Ana Sayfa
                        </a>
                    </div>

                </div>
            </div>

            <p class="mt-6 text-center text-xs text-slate-400">
                CoursVia Yönetim Paneli
            </p>

        </div>
    </div>

    <script src="~/lib/sweetalert2/sweetalert2.all.min.js"></script>

    <script>
        const flashMessages = document.querySelectorAll(".flash-message");

        if (flashMessages.length > 0) {
            setTimeout(function () {
                flashMessages.forEach(function (message) {
                    message.classList.add("opacity-0", "translate-y-[-6px]");

                    setTimeout(function () {
                        message.remove();
                    }, 500);
                });
            }, 3000);
        }

        // --- Şifre Göster/Gizle (Eye) İşlevi ---
        document.querySelectorAll('input[type="password"]').forEach(function(input) {
            if (input.parentElement.classList.contains('relative') && input.parentElement.querySelector('.toggle-password')) return;

            const wrapper = document.createElement('div');
            wrapper.className = 'relative flex items-center w-full';

            input.parentElement.insertBefore(wrapper, input);
            wrapper.appendChild(input);

            input.classList.add('pr-10');

            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'absolute right-3 text-slate-400 hover:text-blue-600 focus:outline-none transition-colors toggle-password z-10';
            btn.innerHTML = `
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 transition-transform duration-200 eye-icon">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                </svg>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 hidden transition-transform duration-200 eye-slash-icon">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 0 0 1.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.451 10.451 0 0 1 12 4.5c4.756 0 8.773 3.162 10.065 7.498a10.522 10.522 0 0 1-4.293 5.774M6.228 6.228 3 3m3.228 3.228 3.65 3.65m7.894 7.894L21 21m-3.228-3.228-3.65-3.65m0 0a3 3 0 1 0-4.243-4.243m4.242 4.242L9.88 9.88" />
                </svg>
            `;

            wrapper.appendChild(btn);

            btn.addEventListener('click', function () {
                const isPassword = input.type === 'password';
                input.type = isPassword ? 'text' : 'password';

                const eye = btn.querySelector('.eye-icon');
                const eyeSlash = btn.querySelector('.eye-slash-icon');

                if (isPassword) {
                    eye.classList.add('hidden');
                    eyeSlash.classList.remove('hidden');
                    eyeSlash.classList.add('scale-110');
                    setTimeout(() => eyeSlash.classList.remove('scale-110'), 200);
                } else {
                    eyeSlash.classList.add('hidden');
                    eye.classList.remove('hidden');
                    eye.classList.add('scale-110');
                    setTimeout(() => eye.classList.remove('scale-110'), 200);
                }
            });
        });
    </script>

</body>
</html>