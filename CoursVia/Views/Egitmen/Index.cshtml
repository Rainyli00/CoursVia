@model CoursVia.Models.EgitmenProfili

@{
    ViewData["Title"] = "Eğitmen Paneli";

    var adSoyad = $"{Model.Kullanici.Ad} {Model.Kullanici.Soyad}";

    int yayindakiKurs = ViewBag.YayindakiKurs ?? 0;
    int onayBekleyenKurs = ViewBag.OnayBekleyenKurs ?? 0;
    int taslakKurs = ViewBag.TaslakKurs ?? 0;

    var sonKurslar = ViewBag.SonKurslar as List<CoursVia.Models.Kurs> ?? new List<CoursVia.Models.Kurs>();
    var sonKayitlar = ViewBag.SonKayitlar as List<CoursVia.Models.KursKaydi> ?? new List<CoursVia.Models.KursKaydi>();
}

<div class="min-h-[calc(100vh-130px)] bg-slate-50">

    <div class="grid min-h-[calc(100vh-130px)] grid-cols-1 lg:grid-cols-[280px_minmax(0,1fr)]">

        <partial name="_EgitmenSidebar" />

        <main class="min-w-0 px-5 py-7 sm:px-7 lg:px-10">

            <div class="mx-auto max-w-7xl space-y-6">

                <!-- Üst Başlık -->
                <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
                    <div class="flex flex-col gap-5 md:flex-row md:items-center md:justify-between">

                        <div>
                            <p class="text-sm font-semibold text-blue-600">
                                Eğitmen Paneli
                            </p>

                            <h1 class="mt-2 text-3xl font-black tracking-tight text-slate-900">
                                Hoş geldiniz, @adSoyad
                            </h1>

                            <div class="mt-2 flex items-center gap-2 text-sm font-medium text-slate-500">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     fill="none"
                                     viewBox="0 0 24 24"
                                     stroke-width="1.5"
                                     stroke="currentColor"
                                     class="h-5 w-5 text-blue-500">
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                </svg>

                                <span id="dynamic-clock"></span>
                            </div>
                        </div>

                    

                    </div>
                </div>

                <!-- Kurs İstatistik Kartları -->
                <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
                    <div class="flex items-center gap-5 rounded-3xl border border-emerald-100 bg-white p-6 shadow-sm transition hover:shadow-md">
                        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-600">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-7 w-7">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-sm font-semibold text-slate-500">Yayındaki Kurslar</p>
                            <p class="text-2xl font-black text-slate-900">@yayindakiKurs</p>
                        </div>
                    </div>

                    <div class="flex items-center gap-5 rounded-3xl border border-amber-100 bg-white p-6 shadow-sm transition hover:shadow-md">
                        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-amber-50 text-amber-600">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-7 w-7">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-sm font-semibold text-slate-500">Onay Bekleyen</p>
                            <p class="text-2xl font-black text-slate-900">@onayBekleyenKurs</p>
                        </div>
                    </div>

                    <div class="flex items-center gap-5 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:shadow-md">
                        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-50 text-slate-600">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-7 w-7">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-sm font-semibold text-slate-500">Taslak Kurslar</p>
                            <p class="text-2xl font-black text-slate-900">@taslakKurs</p>
                        </div>
                    </div>
                </div>

                <!-- Listeler Alanı -->
                <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">

                    <!-- Son Kurslar -->
                    <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">

                        <div class="flex items-center justify-between border-b border-slate-100 px-6 py-5">
                            <div>
                                <h2 class="text-lg font-black text-slate-900">
                                    Son Kurslar
                                </h2>

                                <p class="mt-1 text-sm text-slate-500">
                                    En son oluşturduğunuz kurslar.
                                </p>
                            </div>

                            <a asp-controller="EgitmenKurs"
                               asp-action="Kurslarim"
                               class="text-sm font-bold text-blue-600 hover:text-blue-700">
                                Tümünü Gör
                            </a>
                        </div>

                        @if (sonKurslar.Any())
                        {
                            <div class="divide-y divide-slate-100">
                                @foreach (var kurs in sonKurslar)
                                {
                                    string durumClass = kurs.DurumId switch
                                    {
                                        3 => "bg-slate-100 text-slate-700",
                                        4 => "bg-amber-50 text-amber-700",
                                        5 => "bg-emerald-50 text-emerald-700",
                                        6 => "bg-red-50 text-red-700",
                                        7 => "bg-orange-50 text-orange-700",
                                        _ => "bg-slate-100 text-slate-700"
                                    };

                                    var kategoriler = kurs.KursKategorileri
                                        .Select(x => x.Kategori.KategoriAdi)
                                        .ToList();

                                    <div class="flex flex-col gap-3 px-6 py-4 transition hover:bg-slate-50 sm:flex-row sm:items-center sm:justify-between">

                                        <div class="min-w-0">
                                            <div class="flex flex-wrap items-center gap-2">
                                                <h3 class="truncate text-sm font-bold text-slate-900">
                                                    @kurs.KursAdi
                                                </h3>

                                                <span class="rounded-full px-2.5 py-0.5 text-xs font-bold @durumClass">
                                                    @kurs.Durum.DurumAdi
                                                </span>
                                            </div>

                                            <p class="mt-1 text-xs text-slate-500">
                                                @kurs.OlusturmaTarihi.ToString("dd.MM.yyyy")

                                                @if (kategoriler.Any())
                                                {
                                                    <span> • @string.Join(", ", kategoriler)</span>
                                                }
                                            </p>
                                        </div>



                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="px-6 py-10 text-center">
                                <p class="text-sm font-semibold text-slate-700">
                                    Henüz kurs oluşturmadınız.
                                </p>

                                <p class="mt-1 text-sm text-slate-500">
                                    İlk kursunuzu oluşturarak eğitime başlayabilirsiniz.
                                </p>

                                <a asp-controller="EgitmenKurs"
                                   asp-action="KursOlustur"
                                   class="btn btn-primary btn-sm mt-5 rounded-xl">
                                    İlk Kursumu Oluştur
                                </a>
                            </div>
                        }

                    </div>

                    <!-- Son Öğrenci Kayıtları -->
                <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">

                    <div class="border-b border-slate-100 px-6 py-5">
                        <h2 class="text-lg font-black text-slate-900">
                            Son Öğrenci Kayıtları
                        </h2>

                        <p class="mt-1 text-sm text-slate-500">
                            Kurslarınıza yapılan son kayıtlar.
                        </p>
                    </div>

                    @if (sonKayitlar.Any())
                    {
                        <div class="divide-y divide-slate-100">
                            @foreach (var kayit in sonKayitlar)
                            {
                                <div class="flex flex-col gap-2 px-6 py-4 sm:flex-row sm:items-center sm:justify-between">
                                    <div>
                                        <p class="text-sm font-bold text-slate-900">
                                            @kayit.Kullanici.Ad @kayit.Kullanici.Soyad
                                        </p>

                                        <p class="mt-1 text-xs text-slate-500">
                                            @kayit.Kurs.KursAdi
                                        </p>
                                    </div>

                                    <span class="text-xs font-semibold text-slate-400">
                                        @kayit.KayitTarihi.ToString("dd.MM.yyyy")
                                    </span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="px-6 py-10 text-center">
                            <p class="text-sm font-semibold text-slate-700">
                                Henüz öğrenci kaydı bulunmuyor.
                            </p>

                            <p class="mt-1 text-sm text-slate-500">
                                Kurslarınız yayına alındıktan sonra kayıtlar burada görünür.
                            </p>
                        </div>
                    }

                </div>
                </div>
                <!-- Listeler Alanı Sonu -->

            </div>

        </main>

    </div>

</div>

@section Scripts {
    <script>
        function updateClock() {
            const now = new Date();

            const timeString = now.toLocaleTimeString('tr-TR', {
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit'
            });

            const dateString = now.toLocaleDateString('tr-TR', {
                weekday: 'long',
                year: 'numeric',
                month: 'long',
                day: 'numeric'
            });

            const clockElement = document.getElementById('dynamic-clock');

            if (clockElement) {
                clockElement.textContent = `${dateString} | ${timeString}`;
            }
        }

        updateClock();
        setInterval(updateClock, 1000);
    </script>
}