@model CoursVia.ViewModels.Egitmen.Ogrencilerim.OgrencilerimViewModel

@{
    ViewData["Title"] = "Öğrencilerim";

    string SinavDurumClass(string? durum, bool? gectiMi)
    {
        if (gectiMi == true)
            return "border-emerald-100 bg-emerald-50 text-emerald-700";

        if (gectiMi == false)
            return "border-red-100 bg-red-50 text-red-700";

        if (durum == "Devam ediyor")
            return "border-blue-100 bg-blue-50 text-blue-700";

        return "border-slate-200 bg-slate-50 text-slate-600";
    }

    string IlerlemeBarClass(int yuzde)
    {
        if (yuzde >= 80)
            return "bg-emerald-500";

        if (yuzde >= 40)
            return "bg-blue-500";

        return "bg-amber-500";
    }

    string IlerlemeTextClass(int yuzde)
    {
        if (yuzde >= 80)
            return "text-emerald-700";

        if (yuzde >= 40)
            return "text-blue-700";

        return "text-amber-700";
    }

    int ortalamaIlerleme = Math.Clamp(Model.OrtalamaIlerlemeYuzdesi, 0, 100);

    int baslangicSayfa = Math.Max(1, Model.Sayfa - 2);
    int bitisSayfa = Math.Min(Model.ToplamSayfa, Model.Sayfa + 2);
}

<div class="min-h-[calc(100vh-130px)] bg-slate-50">
    <div class="grid min-h-[calc(100vh-130px)] grid-cols-1 lg:grid-cols-[280px_minmax(0,1fr)]">

        <partial name="_EgitmenSidebar" />

        <main class="min-w-0 px-5 py-6 lg:px-8">

            <div class="mx-auto max-w-6xl space-y-5">

                <!-- Başlık -->
                <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                    <div>
                        <p class="text-xs font-bold uppercase tracking-wider text-blue-600">
                            Eğitmen Paneli
                        </p>

                        <h1 class="mt-1 text-2xl font-black text-slate-900">
                            Öğrencilerim
                        </h1>

                        <p class="mt-1 text-sm leading-6 text-slate-500">
                            Kurslarınıza kayıtlı öğrencilerin ders ilerlemelerini ve sınav durumlarını takip edin.
                        </p>
                    </div>
                </section>

                <!-- Özet Kartları -->
                <section class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">

                    <div class="flex flex-col justify-center rounded-3xl border border-blue-100 bg-white p-5 shadow-sm transition hover:shadow-md">
                        <div class="flex items-center gap-4">
                            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-blue-50 text-blue-600">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
                                </svg>
                            </div>
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Toplam Öğrenci</p>
                                <p class="mt-0.5 text-2xl font-black text-slate-900">@Model.ToplamOgrenciSayisi</p>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col justify-center gap-3 rounded-3xl border border-indigo-100 bg-white p-5 shadow-sm transition hover:shadow-md">
                        <div class="flex items-center gap-4">
                            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-indigo-50 text-indigo-600">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
                                </svg>
                            </div>
                            <div class="flex-1">
                                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Ortalama İlerleme</p>
                                <p class="mt-0.5 text-2xl font-black text-slate-900">%@ortalamaIlerleme</p>
                            </div>
                        </div>
                        <div class="h-2 w-full overflow-hidden rounded-full bg-slate-100">
                            <div class="h-full rounded-full bg-indigo-500 transition-all duration-500" style="width:@ortalamaIlerleme%"></div>
                        </div>
                    </div>

                    <div class="flex flex-col justify-center rounded-3xl border border-amber-100 bg-white p-5 shadow-sm transition hover:shadow-md">
                        <div class="flex items-center gap-4">
                            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-amber-50 text-amber-600">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                                </svg>
                            </div>
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Sınava Giren</p>
                                <p class="mt-0.5 text-2xl font-black text-slate-900">@Model.SinavaGirenOgrenciSayisi</p>
                            </div>
                        </div>
                    </div>

                    <div class="flex flex-col justify-center rounded-3xl border border-emerald-100 bg-white p-5 shadow-sm transition hover:shadow-md">
                        <div class="flex items-center gap-4">
                            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-700">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-6 w-6">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
                                </svg>
                            </div>
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Sınavdan Geçen</p>
                                <p class="mt-0.5 text-2xl font-black text-emerald-700">@Model.SinavdanGecenOgrenciSayisi</p>
                            </div>
                        </div>
                    </div>

                </section>

                <!-- Filtre -->
                <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">

                    <form asp-controller="Egitmen"
                          asp-action="Ogrencilerim"
                          method="get"
                          class="grid grid-cols-1 gap-3 lg:grid-cols-[1fr_280px_auto]">

                        <input type="hidden" name="sayfa" value="1" />

                        <input type="text"
                               name="arama"
                               value="@Model.Arama"
                               placeholder="Öğrenci adı veya soyadı ara"
                               class="input input-bordered w-full rounded-xl border-slate-300 bg-white" />

                        <select name="kursId"
                                class="select select-bordered w-full rounded-xl border-slate-300 bg-white">

                            <option value="">Tüm kurslar</option>

                            @foreach (var kurs in Model.Kurslar)
                            {
                                if (Model.KursId == kurs.KursId)
                                {
                                    <option value="@kurs.KursId" selected>
                                        @kurs.KursAdi
                                    </option>
                                }
                                else
                                {
                                    <option value="@kurs.KursId">
                                        @kurs.KursAdi
                                    </option>
                                }
                            }

                        </select>

                        <div class="flex flex-wrap gap-2 lg:justify-end">
                            <button type="submit"
                                    class="btn btn-primary rounded-xl px-6">
                                Filtrele
                            </button>

                            @if (!string.IsNullOrWhiteSpace(Model.Arama) || Model.KursId.HasValue)
                            {
                                <a asp-controller="Egitmen"
                                   asp-action="Ogrencilerim"
                                   class="btn btn-outline rounded-xl">
                                    Temizle
                                </a>
                            }
                        </div>

                    </form>

                </section>

                <!-- Liste -->
                <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">

                    <div class="flex flex-col gap-1 border-b border-slate-100 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">

                        <div>
                            <h2 class="text-base font-black text-slate-900">
                                Öğrenci Listesi
                            </h2>

                            <p class="mt-1 text-sm text-slate-500">
                                Toplam @Model.ToplamKayit kayıt içinden @Model.Ogrenciler.Count kayıt listeleniyor
                            </p>
                        </div>

                        @if (Model.ToplamSayfa > 1)
                        {
                            <p class="text-sm font-semibold text-slate-500">
                                Sayfa @Model.Sayfa / @Model.ToplamSayfa
                            </p>
                        }

                    </div>

                    @if (Model.Ogrenciler.Any())
                    {
                        <div class="overflow-x-auto">
                            <table class="table w-full">

                                <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
                                    <tr>
                                        <th class="px-5 py-4">Öğrenci</th>
                                        <th class="px-5 py-4">Kurs</th>
                                        <th class="px-5 py-4">Kayıt Tarihi</th>
                                        <th class="px-5 py-4">Ders İlerlemesi</th>
                                        <th class="px-5 py-4">Sınav Durumu</th>
                                    </tr>
                                </thead>

                                <tbody class="divide-y divide-slate-100">
                                    @foreach (var ogrenci in Model.Ogrenciler)
                                    {
                                        string sinavDurumu = string.IsNullOrWhiteSpace(ogrenci.SinavDurumu)
                                        ? "Henüz girmedi"
                                        : ogrenci.SinavDurumu;

                                        int ilerleme = Math.Clamp(ogrenci.IlerlemeYuzdesi, 0, 100);

                                        <tr class="transition hover:bg-slate-50">

                                            <td class="px-5 py-4">
                                                <div>
                                                    <p class="font-bold text-slate-900">
                                                        @ogrenci.OgrenciAdSoyad
                                                    </p>
                                                </div>
                                            </td>

                                            <td class="px-5 py-4">
                                                <p class="max-w-xs truncate text-sm font-semibold text-slate-700">
                                                    @ogrenci.KursAdi
                                                </p>
                                            </td>

                                            <td class="px-5 py-4">
                                                <p class="text-sm font-medium text-slate-600">
                                                    @ogrenci.KayitTarihi.ToString("dd.MM.yyyy")
                                                </p>
                                            </td>

                                            <td class="px-5 py-4">
                                                <div class="w-52">

                                                    <div class="mb-1.5 flex items-center justify-between gap-3">
                                                        <span class="text-xs font-semibold text-slate-500">
                                                            @ogrenci.TamamlananDersSayisi / @ogrenci.ToplamDersSayisi ders
                                                        </span>

                                                        <span class="text-xs font-black @IlerlemeTextClass(ilerleme)">
                                                            %@ilerleme
                                                        </span>
                                                    </div>

                                                    <div class="h-2.5 overflow-hidden rounded-full bg-slate-100">
                                                        <div class="h-full rounded-full @IlerlemeBarClass(ilerleme) transition-all duration-500"
                                                             style="width:@ilerleme%">
                                                        </div>
                                                    </div>

                                                </div>
                                            </td>

                                            <td class="px-5 py-4">
                                                <div class="space-y-1">

                                                    <span class="inline-flex rounded-full border px-2.5 py-1 text-xs font-bold @SinavDurumClass(sinavDurumu, ogrenci.SinavdanGectiMi)">
                                                        @sinavDurumu
                                                    </span>

                                                    @if (ogrenci.SinavGirisSayisi > 0)
                                                    {
                                                        <p class="text-xs font-semibold text-slate-500">
                                                            @ogrenci.SinavGirisSayisi giriş

                                                            @if (ogrenci.SonSinavPuani.HasValue)
                                                            {
                                                                <span> · @ogrenci.SonSinavPuani puan</span>
                                                            }
                                                        </p>
                                                    }
                                                    else
                                                    {
                                                        <p class="text-xs font-semibold text-slate-400">
                                                            Sınav kaydı yok
                                                        </p>
                                                    }

                                                </div>
                                            </td>

                                        </tr>
                                    }
                                </tbody>

                            </table>
                        </div>

                        @if (Model.ToplamSayfa > 1)
                        {
                            <div class="flex flex-col gap-3 border-t border-slate-100 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">

                                <p class="text-sm text-slate-500">
                                    Toplam
                                    <span class="font-bold text-slate-900">@Model.ToplamKayit</span>
                                    kayıt —
                                    Sayfa
                                    <span class="font-bold text-slate-900">@Model.Sayfa</span>
                                    /
                                    <span class="font-bold text-slate-900">@Model.ToplamSayfa</span>
                                </p>

                                <div class="flex flex-wrap items-center gap-2">

                                    @if (Model.OncekiSayfaVar)
                                    {
                                        <a asp-controller="Egitmen"
                                           asp-action="Ogrencilerim"
                                           asp-route-arama="@Model.Arama"
                                           asp-route-kursId="@Model.KursId"
                                           asp-route-sayfa="@(Model.Sayfa - 1)"
                                           class="btn btn-sm btn-outline rounded-xl">
                                            Önceki
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-outline rounded-xl opacity-50"
                                                disabled>
                                            Önceki
                                        </button>
                                    }

                                    @if (baslangicSayfa > 1)
                                    {
                                        <a asp-controller="Egitmen"
                                           asp-action="Ogrencilerim"
                                           asp-route-arama="@Model.Arama"
                                           asp-route-kursId="@Model.KursId"
                                           asp-route-sayfa="1"
                                           class="btn btn-sm btn-outline rounded-xl">
                                            1
                                        </a>

                                        @if (baslangicSayfa > 2)
                                        {
                                            <span class="px-1 text-sm font-bold text-slate-400">
                                                ...
                                            </span>
                                        }
                                    }

                                    @for (int i = baslangicSayfa; i <= bitisSayfa; i++)
                                    {
                                        if (i == Model.Sayfa)
                                        {
                                            <span class="btn btn-sm btn-primary rounded-xl">
                                                @i
                                            </span>
                                        }
                                        else
                                        {
                                            <a asp-controller="Egitmen"
                                               asp-action="Ogrencilerim"
                                               asp-route-arama="@Model.Arama"
                                               asp-route-kursId="@Model.KursId"
                                               asp-route-sayfa="@i"
                                               class="btn btn-sm btn-outline rounded-xl">
                                                @i
                                            </a>
                                        }
                                    }

                                    @if (bitisSayfa < Model.ToplamSayfa)
                                    {
                                        @if (bitisSayfa < Model.ToplamSayfa - 1)
                                        {
                                            <span class="px-1 text-sm font-bold text-slate-400">
                                                ...
                                            </span>
                                        }

                                        <a asp-controller="Egitmen"
                                           asp-action="Ogrencilerim"
                                           asp-route-arama="@Model.Arama"
                                           asp-route-kursId="@Model.KursId"
                                           asp-route-sayfa="@Model.ToplamSayfa"
                                           class="btn btn-sm btn-outline rounded-xl">
                                            @Model.ToplamSayfa
                                        </a>
                                    }

                                    @if (Model.SonrakiSayfaVar)
                                    {
                                        <a asp-controller="Egitmen"
                                           asp-action="Ogrencilerim"
                                           asp-route-arama="@Model.Arama"
                                           asp-route-kursId="@Model.KursId"
                                           asp-route-sayfa="@(Model.Sayfa + 1)"
                                           class="btn btn-sm btn-outline rounded-xl">
                                            Sonraki
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-outline rounded-xl opacity-50"
                                                disabled>
                                            Sonraki
                                        </button>
                                    }

                                </div>

                            </div>
                        }
                    }
                    else
                    {
                        <div class="px-6 py-14 text-center">

                            <h3 class="text-base font-black text-slate-900">
                                Öğrenci bulunamadı
                            </h3>

                            <p class="mt-1 text-sm text-slate-500">
                                Seçili filtrelere uygun öğrenci kaydı bulunmuyor.
                            </p>

                            @if (!string.IsNullOrWhiteSpace(Model.Arama) || Model.KursId.HasValue)
                            {
                                <a asp-controller="Egitmen"
                                   asp-action="Ogrencilerim"
                                   class="btn btn-sm btn-primary mt-4 rounded-xl px-6">
                                    Filtreleri Temizle
                                </a>
                            }

                        </div>
                    }

                </section>

            </div>

        </main>

    </div>
</div>
