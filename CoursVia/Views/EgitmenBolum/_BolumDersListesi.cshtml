@model CoursVia.Models.Kurs
@using System.Text.Json

@{
    bool isEditable = Model.DurumId == 3 ||
                      Model.DurumId == 5 ||
                      Model.DurumId == 6 ||
                      Model.DurumId == 7;
}

<div class="space-y-6">

    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">

        <div class="mb-5 flex items-center justify-between">

            <div>
                <h2 class="text-xl font-black text-slate-900">
                    Bölümler ve Dersler
                </h2>
            </div>

        </div>

        @if (!Model.Bolumler.Any())
        {
            <div class="flex flex-col items-center justify-center rounded-2xl border border-dashed border-slate-300 bg-slate-50 py-12 text-center">

                <p class="font-medium text-slate-500">
                    Henüz bölüm eklenmemiş.
                </p>

                <p class="mt-1 text-sm text-slate-400">
                    Sağ panelden yeni bir bölüm oluşturarak başlayabilirsiniz.
                </p>

            </div>
        }
        else
        {
            <div class="space-y-4" id="sortable-bolumler">

                @foreach (var bolum in Model.Bolumler)
                {
                    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-50"
                         data-id="@bolum.BolumId">

                        <div class="flex items-center justify-between gap-4 bg-white px-5 py-4">

                            <div class="flex min-w-0 items-center gap-3">

                                @if (isEditable)
                                {
                                    <div class="drag-handle cursor-move text-slate-300 hover:text-slate-500"
                                         title="Bölümü sürükle">
                                        <svg xmlns="http://www.w3.org/2000/svg"
                                             class="h-5 w-5"
                                             fill="none"
                                             viewBox="0 0 24 24"
                                             stroke="currentColor">
                                            <path stroke-linecap="round"
                                                  stroke-linejoin="round"
                                                  stroke-width="2"
                                                  d="M4 6h16M4 12h16M4 18h16" />
                                        </svg>
                                    </div>
                                }

                                <button type="button"
                                        class="btn-bolum-toggle flex min-w-0 items-center gap-2 text-left"
                                        data-target="bolum-icerik-@bolum.BolumId"
                                        aria-controls="bolum-icerik-@bolum.BolumId"
                                        aria-expanded="false">
                                    <svg xmlns="http://www.w3.org/2000/svg"
                                         class="bolum-chevron h-4 w-4 shrink-0 text-slate-400 transition-transform"
                                         fill="none"
                                         viewBox="0 0 24 24"
                                         stroke="currentColor">
                                        <path stroke-linecap="round"
                                              stroke-linejoin="round"
                                              stroke-width="2"
                                              d="M19 9l-7 7-7-7" />
                                    </svg>

                                    <span class="min-w-0 truncate font-bold text-slate-900">
                                        <span class="bolum-sira mr-2 text-slate-400">
                                            Bölüm @bolum.SiraNo:
                                        </span>

                                        @bolum.BolumAdi
                                    </span>

                                    <span class="bolum-ders-sayisi shrink-0 rounded-full bg-slate-100 px-2.5 py-1 text-xs font-bold text-slate-500">
                                        @bolum.Dersler.Count ders
                                    </span>
                                </button>

                            </div>

                            <div class="flex items-center gap-1">

                                @if (isEditable)
                                {
                                    <button type="button"
                                            class="btn btn-sm btn-ghost rounded-lg text-slate-600 hover:bg-slate-100 btn-bolum-duzenle"
                                            data-bolum-id="@bolum.BolumId"
                                            data-bolum-adi="@bolum.BolumAdi">
                                        Düzenle
                                    </button>

                                    <form asp-controller="EgitmenBolum"
                                          asp-action="BolumSil"
                                          method="post"
                                          class="form-bolum-sil mr-2">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden"
                                               name="bolumId"
                                               value="@bolum.BolumId" />

                                        <button type="submit"
                                                class="btn btn-sm btn-ghost btn-square rounded-lg text-red-400 hover:bg-red-50 hover:text-red-600"
                                                title="Bölümü Sil">
                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                 class="h-4 w-4"
                                                 fill="none"
                                                 viewBox="0 0 24 24"
                                                 stroke="currentColor">
                                                <path stroke-linecap="round"
                                                      stroke-linejoin="round"
                                                      stroke-width="2"
                                                      d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                            </svg>
                                        </button>

                                    </form>

                                    <button type="button"
                                            class="btn btn-sm btn-ghost rounded-lg text-blue-600 hover:bg-blue-50 btn-ders-ekle"
                                            data-bolum-id="@bolum.BolumId"
                                            data-kurs-id="@Model.KursId"
                                            data-bolum-adi="@bolum.BolumAdi">
                                        Ders Ekle
                                    </button>
                                }

                            </div>

                        </div>

                        <div id="bolum-icerik-@bolum.BolumId"
                             class="hidden border-t border-slate-200 p-4">

                            <ul class="sortable-dersler min-h-[52px] space-y-2 rounded-xl"
                                data-bolum-id="@bolum.BolumId">

                                @if (!bolum.Dersler.Any())
                                {
                                    <li class="ders-empty-placeholder pointer-events-none rounded-xl border border-dashed border-slate-200 bg-white px-4 py-3 text-sm italic text-slate-400">
                                        Bu bölüme henüz ders eklenmemiş.
                                    </li>
                                }
                                else
                                {
                                    @foreach (var ders in bolum.Dersler)
                                    {
                                        var materyallerJson = JsonSerializer.Serialize(ders.DersMateryalleri
                                            .OrderBy(x => x.MateryalId)
                                            .Select(x => new
                                            {
                                                materyalId = x.MateryalId,
                                                baslik = x.Baslik,
                                                materyalUrl = x.MateryalUrl
                                            }));

                                        <li class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm transition hover:border-blue-200"
                                            data-ders-id="@ders.DersId">

                                            <div class="flex items-center justify-between p-3">

                                                <div class="flex min-w-0 items-center gap-3">

                                                    @if (isEditable)
                                                    {
                                                        <div class="ders-drag-handle cursor-move text-slate-300 hover:text-slate-500"
                                                             title="Dersi sürükle">
                                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                                 class="h-4 w-4"
                                                                 fill="none"
                                                                 viewBox="0 0 24 24"
                                                                 stroke="currentColor">
                                                                <path stroke-linecap="round"
                                                                      stroke-linejoin="round"
                                                                      stroke-width="2"
                                                                      d="M4 6h16M4 12h16M4 18h16" />
                                                            </svg>
                                                        </div>
                                                    }

                                                    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-blue-50 text-blue-600">
                                                        <svg xmlns="http://www.w3.org/2000/svg"
                                                             class="h-4 w-4"
                                                             viewBox="0 0 20 20"
                                                             fill="currentColor">
                                                            <path fill-rule="evenodd"
                                                                  d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z"
                                                                  clip-rule="evenodd" />
                                                        </svg>
                                                    </div>

                                                    <div class="min-w-0">
                                                        <span class="font-medium text-slate-700">
                                                            <span class="ders-sira">@ders.SiraNo.</span>
                                                            @ders.DersAdi
                                                        </span>

                                                        @if (ders.DersMateryalleri.Any())
                                                        {
                                                            <span class="ml-2 rounded-full border border-emerald-200 bg-emerald-50 px-2 py-0.5 text-xs font-bold text-emerald-700">
                                                                @ders.DersMateryalleri.Count materyal
                                                            </span>
                                                        }
                                                    </div>

                                                </div>

                                                <div class="flex shrink-0 flex-wrap items-center justify-end gap-2">

                                                    <button type="button"
                                                            class="btn btn-xs btn-outline btn-info rounded-lg btn-video-izle"
                                                            data-video-url="@ders.VideoUrl"
                                                            data-ders-adi="@ders.DersAdi"
                                                            data-aciklama="@ders.Aciklama"
                                                            data-materyaller="@materyallerJson">
                                                        Önizle
                                                    </button>

                                                    @if (ders.DersMateryalleri.Any())
                                                    {
                                                        <button type="button"
                                                                class="btn btn-xs btn-outline btn-success rounded-lg btn-toggle-materyal"
                                                                data-target="materyaller-@ders.DersId">
                                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                                 class="h-3 w-3"
                                                                 fill="none"
                                                                 viewBox="0 0 24 24"
                                                                 stroke="currentColor">
                                                                <path stroke-linecap="round"
                                                                      stroke-linejoin="round"
                                                                      stroke-width="2"
                                                                      d="M19 9l-7 7-7-7" />
                                                            </svg>

                                                            Dosyalar
                                                        </button>
                                                    }

                                                     @if (isEditable)
{
    <button type="button"
       class="btn btn-xs btn-outline rounded-lg btn-ders-duzenle"
       data-ders-id="@ders.DersId"
       data-kurs-id="@Model.KursId"
       data-bolum-id="@ders.BolumId"
       data-ders-adi="@ders.DersAdi"
       data-aciklama="@ders.Aciklama"
       data-video-url="@ders.VideoUrl"
       data-materyaller="@materyallerJson">
        Düzenle
    </button>

    <form asp-controller="EgitmenDers"
          asp-action="DersSil"
          method="post"
          class="form-ders-sil">

        @Html.AntiForgeryToken()

        <input type="hidden"
               name="dersId"
               value="@ders.DersId" />

        <button type="submit"
                class="btn btn-xs btn-outline btn-error rounded-lg">
            Sil
        </button>
    </form>
}                      
 
                                                </div>

                                            </div>

                                            @if (ders.DersMateryalleri.Any())
                                            {
                                                <div id="materyaller-@ders.DersId"
                                                     class="hidden border-t border-slate-100 bg-slate-50 px-4 py-3">

                                                    <p class="mb-2 text-xs font-bold uppercase tracking-wide text-slate-500">
                                                        Materyaller
                                                    </p>

                                                    <div class="space-y-1.5">

                                                        @foreach (var mat in ders.DersMateryalleri)
                                                        {
                                                            <a href="@mat.MateryalUrl"
                                                               target="_blank"
                                                               class="flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700 transition hover:border-blue-300 hover:text-blue-600">

                                                                <svg xmlns="http://www.w3.org/2000/svg"
                                                                     class="h-4 w-4 text-slate-400"
                                                                     fill="none"
                                                                     viewBox="0 0 24 24"
                                                                     stroke="currentColor">
                                                                    <path stroke-linecap="round"
                                                                          stroke-linejoin="round"
                                                                          stroke-width="2"
                                                                          d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                                                </svg>

                                                                @mat.Baslik
                                                            </a>
                                                        }

                                                    </div>

                                                </div>
                                            }

                                        </li>
                                    }
                                }

                            </ul>

                        </div>

                    </div>
                }

            </div>
        }

    </div>

</div>
