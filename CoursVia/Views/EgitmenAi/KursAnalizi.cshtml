@model CoursVia.ViewModels.Ai.AiKarsilastirmaViewModel
@using CoursVia.Services.Ai

@{
    ViewData["Title"] = "AI Kurs Analizi";

    var kursId = Model.KursId ?? 0;

    string ModelAdi(AiModelTipi modelTipi)
    {
        return modelTipi switch
        {
            AiModelTipi.Gemini => "Gemini",
            AiModelTipi.LocalGemma => "Local Gemma",
            AiModelTipi.MiniCoursVia => "MiniCoursVia",
            AiModelTipi.Hepsi => "Karşılaştırma",
            _ => "AI Modeli"
        };
    }

    string ModelBadgeClass(AiModelTipi modelTipi)
    {
        return modelTipi switch
        {
            AiModelTipi.Gemini => "bg-indigo-50 text-indigo-700 ring-indigo-200",
            AiModelTipi.LocalGemma => "bg-purple-50 text-purple-700 ring-purple-200",
            AiModelTipi.MiniCoursVia => "bg-emerald-50 text-emerald-700 ring-emerald-200",
            AiModelTipi.Hepsi => "bg-slate-100 text-slate-700 ring-slate-200",
            _ => "bg-slate-50 text-slate-600 ring-slate-200"
        };
    }
}

<div class="min-h-[calc(100vh-130px)] bg-slate-50">

    <div class="grid min-h-[calc(100vh-130px)] grid-cols-1 lg:grid-cols-[300px_minmax(0,1fr)]">

        <partial name="_EgitmenSidebar" />

        <main class="min-w-0 px-5 py-7 sm:px-7 lg:px-10">

            <div class="mx-auto max-w-7xl space-y-5">

                <!-- Üst Başlık -->
                <section class="flex flex-col gap-4 rounded-2xl border border-slate-200 bg-white px-5 py-4 shadow-sm md:flex-row md:items-center md:justify-between">

                    <div>
                        <div class="mb-2 flex flex-wrap items-center gap-2">
                            <span class="inline-flex rounded-full bg-blue-50 px-2.5 py-1 text-xs font-bold text-blue-700 ring-1 ring-inset ring-blue-200/50">
                                Eğitmen AI
                            </span>
                            <span class="inline-flex rounded-full @ModelBadgeClass(Model.SecilenModelTipi) px-2.5 py-1 text-xs font-bold ring-1 ring-inset">
                                @ModelAdi(Model.SecilenModelTipi)
                            </span>
                        </div>

                        <h1 class="text-2xl font-black tracking-tight text-slate-900">
                            @Model.Baslik
                        </h1>

                        @if (!string.IsNullOrWhiteSpace(Model.Aciklama))
                        {
                            <p class="mt-1 text-sm font-medium text-slate-500">
                                @Model.Aciklama
                            </p>
                        }
                    </div>

                    <div class="flex shrink-0">
                        <a asp-controller="EgitmenKurs"
                           asp-action="Kurslarim"
                           class="btn btn-outline rounded-xl px-6">
                            Geri Dön
                        </a>
                    </div>
                </section>

                <!-- Model Seçimi -->
                <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                    <div class="mb-4">
                        <h2 class="text-base font-black text-slate-900">Model Seçimi</h2>
                        <p class="text-sm font-medium leading-6 text-slate-500">
                            Aynı kurs verisiyle farklı AI modellerini çalıştırarak sonuçları inceleyebilirsin.
                        </p>
                    </div>

                    <div class="grid grid-cols-2 gap-3 lg:grid-cols-4">
                        <a asp-controller="EgitmenAi"
                           asp-action="KursAnalizi"
                           asp-route-kursId="@kursId"
                           asp-route-modelTipi="@AiModelTipi.Gemini"
                           class="flex min-h-[2.5rem] items-center justify-center rounded-xl border text-sm font-bold transition-all @(Model.SecilenModelTipi == AiModelTipi.Gemini ? "border-indigo-600 bg-indigo-600 text-white shadow-md shadow-indigo-600/20" : "border-slate-200 bg-white text-slate-700 hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700")">
                            Gemini
                        </a>

                        <a asp-controller="EgitmenAi"
                           asp-action="KursAnalizi"
                           asp-route-kursId="@kursId"
                           asp-route-modelTipi="@AiModelTipi.LocalGemma"
                           class="flex min-h-[2.5rem] items-center justify-center rounded-xl border text-sm font-bold transition-all @(Model.SecilenModelTipi == AiModelTipi.LocalGemma ? "border-purple-600 bg-purple-600 text-white shadow-md shadow-purple-600/20" : "border-slate-200 bg-white text-slate-700 hover:border-purple-200 hover:bg-purple-50 hover:text-purple-700")">
                            Local Gemma
                        </a>

                        <a asp-controller="EgitmenAi"
                           asp-action="KursAnalizi"
                           asp-route-kursId="@kursId"
                           asp-route-modelTipi="@AiModelTipi.MiniCoursVia"
                           class="flex min-h-[2.5rem] items-center justify-center rounded-xl border text-sm font-bold transition-all @(Model.SecilenModelTipi == AiModelTipi.MiniCoursVia ? "border-emerald-600 bg-emerald-600 text-white shadow-md shadow-emerald-600/20" : "border-slate-200 bg-white text-slate-700 hover:border-emerald-200 hover:bg-emerald-50 hover:text-emerald-700")">
                            MiniCoursVia
                        </a>

                        <a asp-controller="EgitmenAi"
                           asp-action="KursAnalizi"
                           asp-route-kursId="@kursId"
                           asp-route-modelTipi="@AiModelTipi.Hepsi"
                           class="flex min-h-[2.5rem] items-center justify-center rounded-xl border text-sm font-bold transition-all @(Model.SecilenModelTipi == AiModelTipi.Hepsi ? "border-slate-800 bg-slate-800 text-white shadow-md shadow-slate-800/20" : "border-slate-200 bg-white text-slate-700 hover:border-slate-300 hover:bg-slate-100 hover:text-slate-900")">
                            Üçünü Karşılaştır
                        </a>
                    </div>
                </section>

                <!-- Sonuclar -->
                @if (Model.Sonuclar == null || !Model.Sonuclar.Any())
                {
                    <div class="rounded-2xl border border-yellow-100 bg-yellow-50 px-5 py-4 shadow-sm">
                        <p class="text-sm font-bold text-yellow-800">AI analizi bulunamadı.</p>
                    </div>
                }
                else
                {
                    <div class="grid grid-cols-1 gap-5 @(Model.Sonuclar.Count > 1 ? "xl:grid-cols-3" : "")">
                        @foreach (var sonuc in Model.Sonuclar)
                        {
                            <article class="flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
                                <div class="border-b border-slate-100 bg-slate-50/50 px-5 py-4">
                                    <div class="flex items-start justify-between gap-3">
                                        <div>
                                            <div class="mb-2 flex flex-wrap gap-2">
                                                <span class="inline-flex rounded-full px-2.5 py-1 text-[11px] font-bold ring-1 ring-inset @ModelBadgeClass(sonuc.ModelTipi)">
                                                    @ModelAdi(sonuc.ModelTipi)
                                                </span>

                                                @if (sonuc.BasariliMi)
                                                {
                                                    <span class="inline-flex rounded-full bg-emerald-50 px-2.5 py-1 text-[11px] font-bold text-emerald-700 ring-1 ring-inset ring-emerald-200/50">
                                                        Başarılı
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="inline-flex rounded-full bg-red-50 px-2.5 py-1 text-[11px] font-bold text-red-700 ring-1 ring-inset ring-red-200/50">
                                                        Hata
                                                    </span>
                                                }

                                                @if (sonuc.GuvenlikFiltresiUygulandiMi)
                                                {
                                                    <span class="inline-flex rounded-full bg-yellow-50 px-2.5 py-1 text-[11px] font-bold text-yellow-700 ring-1 ring-inset ring-yellow-200/50">
                                                        Temizlendi
                                                    </span>
                                                }
                                            </div>

                                            <h2 class="text-base font-black text-slate-900">
                                                @sonuc.ModelAdi
                                            </h2>
                                        </div>

                                        <div class="text-right">
                                            <div class="text-[11px] font-bold uppercase tracking-wider text-slate-400">Süre</div>
                                            <div class="mt-0.5 text-sm font-black text-slate-700">@sonuc.SureText</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="flex-1 p-5">
                                    @if (sonuc.BasariliMi)
                                    {
                                        <div class="prose prose-sm prose-slate max-w-none whitespace-pre-line leading-relaxed text-slate-700">
                                            @sonuc.Cikti
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="rounded-xl border border-red-100 bg-red-50 px-4 py-3">
                                            <p class="text-sm font-semibold text-red-800">
                                                @(sonuc.HataMesaji ?? "AI modeli hata döndürdü.")
                                            </p>
                                        </div>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                }

                <div class="px-2 text-xs font-semibold text-slate-400">
                    AI çıktıları güvenlik filtresinden geçerek temizlendikten sonra öneri kayıtlarına eklenir.
                </div>

            </div>

        </main>

    </div>

</div>