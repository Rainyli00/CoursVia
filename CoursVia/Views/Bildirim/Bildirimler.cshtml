@model CoursVia.ViewModels.Bildirim.BildirimlerViewModel

@{
    ViewData["Title"] = "Bildirimler";

    string aktifRol = User.FindFirst("AktifRol")?.Value ?? "";

    bool adminPaneli = aktifRol == "Admin";
    bool egitmenPaneli = aktifRol == "Eğitmen";
    bool ogrenciPaneli = aktifRol == "Öğrenci";

    string TipBadgeClass(string tip)
    {
        return tip switch
        {
            "Bilgilendirme" => "bg-blue-50 text-blue-700",
            "Uyarı" => "bg-amber-50 text-amber-700",
            _ => "bg-slate-100 text-slate-600"
        };
    }

    string OkunmaClass(bool okunduMu)
    {
        return okunduMu
            ? "border-slate-200 bg-white"
            : "border-blue-100 bg-blue-50/40";
    }

    string DurumTabClass(string aktifDurum, string tabDurum)
    {
        return aktifDurum == tabDurum
            ? "bg-slate-900 text-white"
            : "bg-white text-slate-600 border border-slate-200 hover:border-blue-200 hover:text-blue-700";
    }

    int baslangicSayfa = Math.Max(1, Model.Sayfa - 2);
    int bitisSayfa = Math.Min(Model.ToplamSayfa, Model.Sayfa + 2);
}

<div class="min-h-[calc(100vh-130px)] bg-slate-50">

    <div class="grid min-h-[calc(100vh-130px)] grid-cols-1 lg:grid-cols-[300px_minmax(0,1fr)]">

        @if (adminPaneli)
        {
            <partial name="_AdminSidebar" />
        }
        else if (egitmenPaneli)
        {
            <partial name="_EgitmenSidebar" />
        }
        else if (ogrenciPaneli)
        {
            <partial name="_OgrenciSidebar" />
        }

        <main class="min-w-0 px-5 py-7 sm:px-7 lg:px-10">

            <div class="mx-auto max-w-7xl space-y-4">

                <!-- Üst Alan -->
                <section class="rounded-2xl border border-slate-200 bg-white px-5 py-4 shadow-sm">

                    <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">

                        <div>
                            <h1 class="text-2xl font-black tracking-tight text-slate-900">
                                Bildirimler
                            </h1>

                            <p class="mt-1 text-sm text-slate-500">
                                Hesabınıza ait bildirimleri takip edin.
                            </p>
                        </div>

                        <div class="flex flex-col gap-3 sm:flex-row sm:items-center">

                            <div class="flex flex-wrap gap-2 text-xs font-bold">

                                <span class="rounded-full bg-slate-100 px-3 py-1 text-slate-600">
                                    Toplam: @Model.ToplamBildirimSayisi
                                </span>

                                <span class="rounded-full bg-blue-50 px-3 py-1 text-blue-700">
                                    Okunmamış: @Model.OkunmamisBildirimSayisi
                                </span>

                                <span class="rounded-full bg-slate-100 px-3 py-1 text-slate-600">
                                    Okunmuş: @Model.OkunmusBildirimSayisi
                                </span>

                            </div>

                            @if (Model.OkunmamisBildirimSayisi > 0)
                            {
                                <form asp-controller="Bildirim"
                                      asp-action="TumunuOkunduYap"
                                      method="post">
                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="durum" value="@Model.Durum" />

                                    <button type="submit"
                                            class="btn btn-primary btn-sm rounded-xl px-4">
                                        Tümünü Okundu Yap
                                    </button>
                                </form>
                            }

                        </div>

                    </div>

                </section>

                <!-- Filtre -->
                <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">

                    <div class="flex flex-wrap gap-2">

                        <a asp-controller="Bildirim"
                           asp-action="Bildirimler"
                           asp-route-durum="tum"
                           class="rounded-xl px-3.5 py-2 text-sm font-bold transition @DurumTabClass(Model.Durum, "tum")">
                            Tümü
                        </a>

                        <a asp-controller="Bildirim"
                           asp-action="Bildirimler"
                           asp-route-durum="okunmamis"
                           class="rounded-xl px-3.5 py-2 text-sm font-bold transition @DurumTabClass(Model.Durum, "okunmamis")">
                            Okunmamış
                        </a>

                        <a asp-controller="Bildirim"
                           asp-action="Bildirimler"
                           asp-route-durum="okunmus"
                           class="rounded-xl px-3.5 py-2 text-sm font-bold transition @DurumTabClass(Model.Durum, "okunmus")">
                            Okunmuş
                        </a>

                    </div>

                </section>

                <!-- Liste -->
                <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">

                    @if (Model.Bildirimler.Any())
                    {
                        <div class="divide-y divide-slate-100">

                            @foreach (var bildirim in Model.Bildirimler)
                            {
                                <article class="border-l-4 px-5 py-4 transition hover:bg-slate-50 @OkunmaClass(bildirim.OkunduMu)">

                                    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">

                                        <div class="min-w-0 flex-1">

                                            <div class="flex flex-wrap items-center gap-2">

                                                <span class="rounded-full px-2.5 py-1 text-xs font-bold @TipBadgeClass(bildirim.BildirimTipiAdi)">
                                                    @bildirim.BildirimTipiAdi
                                                </span>

                                                @if (!bildirim.OkunduMu)
                                                {
                                                    <span class="rounded-full bg-blue-600 px-2.5 py-1 text-xs font-bold text-white">
                                                        Yeni
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-bold text-slate-500">
                                                        Okundu
                                                    </span>
                                                }

                                                <span class="text-xs font-semibold text-slate-400">
                                                    @bildirim.OlusturmaTarihi.ToString("dd.MM.yyyy HH:mm")
                                                </span>

                                            </div>

                                            <h2 class="mt-3 text-base font-black text-slate-900">
                                                @bildirim.Baslik
                                            </h2>

                                            <p class="mt-1 text-sm leading-6 text-slate-600">
                                                @bildirim.Mesaj
                                            </p>

                                        </div>

                                        <div class="flex shrink-0 gap-2 sm:justify-end">

                                            @if (!bildirim.OkunduMu)
                                            {
                                                <form asp-controller="Bildirim"
                                                      asp-action="OkunduYap"
                                                      method="post">
                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden" name="id" value="@bildirim.BildirimId" />
                                                    <input type="hidden" name="durum" value="@Model.Durum" />
                                                    <input type="hidden" name="sayfa" value="@Model.Sayfa" />

                                                    <button type="submit"
                                                            class="btn btn-outline btn-xs rounded-lg">
                                                        Okundu
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-controller="Bildirim"
                                                      asp-action="OkunmadiYap"
                                                      method="post">
                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden" name="id" value="@bildirim.BildirimId" />
                                                    <input type="hidden" name="durum" value="@Model.Durum" />
                                                    <input type="hidden" name="sayfa" value="@Model.Sayfa" />

                                                    <button type="submit"
                                                            class="btn btn-outline btn-xs rounded-lg">
                                                        Okunmamış
                                                    </button>
                                                </form>
                                            }

                                            <form asp-controller="Bildirim"
                                                  asp-action="Sil"
                                                  method="post">
                                                @Html.AntiForgeryToken()

                                                <input type="hidden" name="id" value="@bildirim.BildirimId" />
                                                <input type="hidden" name="durum" value="@Model.Durum" />
                                                <input type="hidden" name="sayfa" value="@Model.Sayfa" />

                                                <button type="submit"
                                                        class="btn btn-error btn-xs rounded-lg text-white">
                                                    Sil
                                                </button>
                                            </form>

                                        </div>

                                    </div>

                                </article>
                            }

                        </div>

                        @if (Model.ToplamSayfa > 1)
                        {
                            <div class="flex flex-col gap-3 border-t border-slate-100 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">

                                <p class="text-sm text-slate-500">
                                    Sayfa
                                    <span class="font-bold text-slate-900">@Model.Sayfa</span>
                                    /
                                    <span class="font-bold text-slate-900">@Model.ToplamSayfa</span>
                                </p>

                                <div class="flex flex-wrap items-center gap-2">

                                    @if (Model.OncekiSayfaVar)
                                    {
                                        <a asp-controller="Bildirim"
                                           asp-action="Bildirimler"
                                           asp-route-durum="@Model.Durum"
                                           asp-route-sayfa="@(Model.Sayfa - 1)"
                                           class="btn btn-outline btn-sm rounded-xl">
                                            Önceki
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-outline btn-sm rounded-xl opacity-50"
                                                disabled>
                                            Önceki
                                        </button>
                                    }

                                    @if (baslangicSayfa > 1)
                                    {
                                        <a asp-controller="Bildirim"
                                           asp-action="Bildirimler"
                                           asp-route-durum="@Model.Durum"
                                           asp-route-sayfa="1"
                                           class="btn btn-outline btn-sm rounded-xl">
                                            1
                                        </a>

                                        @if (baslangicSayfa > 2)
                                        {
                                            <span class="px-1 text-sm font-bold text-slate-400">
                                                ...
                                            </span>
                                        }
                                    }

                                    @for (int i = baslangicSayfa; i <= bitisSayfa; i++)
                                    {
                                        if (i == Model.Sayfa)
                                        {
                                            <span class="btn btn-primary btn-sm rounded-xl">
                                                @i
                                            </span>
                                        }
                                        else
                                        {
                                            <a asp-controller="Bildirim"
                                               asp-action="Bildirimler"
                                               asp-route-durum="@Model.Durum"
                                               asp-route-sayfa="@i"
                                               class="btn btn-outline btn-sm rounded-xl">
                                                @i
                                            </a>
                                        }
                                    }

                                    @if (bitisSayfa < Model.ToplamSayfa)
                                    {
                                        @if (bitisSayfa < Model.ToplamSayfa - 1)
                                        {
                                            <span class="px-1 text-sm font-bold text-slate-400">
                                                ...
                                            </span>
                                        }

                                        <a asp-controller="Bildirim"
                                           asp-action="Bildirimler"
                                           asp-route-durum="@Model.Durum"
                                           asp-route-sayfa="@Model.ToplamSayfa"
                                           class="btn btn-outline btn-sm rounded-xl">
                                            @Model.ToplamSayfa
                                        </a>
                                    }

                                    @if (Model.SonrakiSayfaVar)
                                    {
                                        <a asp-controller="Bildirim"
                                           asp-action="Bildirimler"
                                           asp-route-durum="@Model.Durum"
                                           asp-route-sayfa="@(Model.Sayfa + 1)"
                                           class="btn btn-outline btn-sm rounded-xl">
                                            Sonraki
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-outline btn-sm rounded-xl opacity-50"
                                                disabled>
                                            Sonraki
                                        </button>
                                    }

                                </div>

                            </div>
                        }
                    }
                    else
                    {
                        <div class="px-6 py-16 text-center">

                            <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-100 text-slate-400">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     fill="none"
                                     viewBox="0 0 24 24"
                                     stroke-width="2"
                                     stroke="currentColor"
                                     class="h-7 w-7">
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a3 3 0 0 1-5.714 0" />
                                </svg>
                            </div>

                            <h3 class="mt-4 text-base font-black text-slate-900">
                                Bildirim bulunamadı
                            </h3>

                            <p class="mt-1 text-sm text-slate-500">
                                Seçili filtreye uygun bildiriminiz bulunmuyor.
                            </p>

                            @if (Model.Durum != "tum")
                            {
                                <a asp-controller="Bildirim"
                                   asp-action="Bildirimler"
                                   asp-route-durum="tum"
                                   class="btn btn-primary btn-sm mt-5 rounded-xl px-5">
                                    Tüm Bildirimleri Göster
                                </a>
                            }

                        </div>
                    }

                </section>

            </div>

        </main>

    </div>

</div>
