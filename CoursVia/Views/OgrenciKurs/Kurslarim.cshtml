@model CoursVia.ViewModels.Ogrenci.OgrenciKurslarimViewModel

@{
    ViewData["Title"] = "Kurslarım";

    string returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    int ortalamaIlerleme = Math.Clamp(Model.OrtalamaIlerlemeYuzdesi, 0, 100);

    int bulunanKursSayisi = Model.ToplamKayit > 0
        ? Model.ToplamKayit
        : Model.Kurslar.Count;

    string IlerlemeBarClass(int yuzde)
    {
        if (yuzde >= 80)
            return "bg-emerald-500";

        if (yuzde >= 40)
            return "bg-blue-500";

        return "bg-amber-500";
    }

    string IlerlemeTextClass(int yuzde)
    {
        if (yuzde >= 80)
            return "text-emerald-700";

        if (yuzde >= 40)
            return "text-blue-700";

        return "text-amber-700";
    }

    string KursDurumClass(bool tamamlandiMi)
    {
        return tamamlandiMi
            ? "border-emerald-100 bg-emerald-50 text-emerald-700"
            : "border-blue-100 bg-blue-50 text-blue-700";
    }

    string SinavDurumClass(string? durum, bool? gectiMi)
    {
        if (gectiMi == true)
            return "border-emerald-100 bg-emerald-50 text-emerald-700";

        if (gectiMi == false)
            return "border-red-100 bg-red-50 text-red-700";

        if (durum == "Devam ediyor")
            return "border-blue-100 bg-blue-50 text-blue-700";

        return "border-slate-200 bg-slate-50 text-slate-600";
    }

    string DevamButonMetni(bool tamamlandiMi, int ilerleme)
    {
        if (tamamlandiMi)
            return "Tekrar Aç";

        if (ilerleme == 0)
            return "Başla";

        return "Devam Et";
    }

    string YildizGoster(int? puan)
    {
        if (!puan.HasValue || puan.Value < 1)
            return "☆☆☆☆☆";

        int dolu = Math.Clamp(puan.Value, 1, 5);

        return new string('★', dolu) + new string('☆', 5 - dolu);
    }
}

<div class="min-h-[calc(100vh-130px)] bg-slate-50">

    <div class="grid min-h-[calc(100vh-130px)] grid-cols-1 lg:grid-cols-[300px_minmax(0,1fr)]">

        <partial name="_OgrenciSidebar" />

        <main class="min-w-0 px-5 py-7 sm:px-7 lg:px-10">

            <div class="mx-auto max-w-6xl space-y-5">

                @if (TempData["OgrenciHata"] != null)
                {
                    <div class="flash-message alert alert-error rounded-2xl shadow-sm transition-all duration-500">
                        <span>@TempData["OgrenciHata"]</span>
                    </div>
                }

                @if (TempData["OgrenciBasari"] != null)
                {
                    <div class="flash-message alert rounded-2xl border border-emerald-100 bg-emerald-50 text-emerald-700 shadow-sm transition-all duration-500">
                        <span>@TempData["OgrenciBasari"]</span>
                    </div>
                }

                <!-- Başlık -->
                <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">

                        <div>
                            <p class="text-xs font-bold uppercase tracking-wider text-blue-600">
                                Öğrenci Paneli
                            </p>

                            <h1 class="mt-1 text-2xl font-black text-slate-900">
                                Kurslarım
                            </h1>

                            <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-500">
                                Kayıtlı olduğun kursları, ders ilerlemeni, favorilerini ve değerlendirmelerini buradan takip edebilirsin.
                            </p>
                        </div>

                        <a asp-controller="OgrenciKurs"
                           asp-action="Kesfet"
                           class="btn btn-primary rounded-xl px-6">
                            Kurs Keşfet
                        </a>

                    </div>
                </section>

                <!-- Kompakt Özet Kartları -->
                <section class="grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-4">

                    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                        <div class="flex items-center justify-between gap-4">

                            <div class="flex items-center gap-3">
                                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-slate-100 text-slate-700">
                                    <svg xmlns="http://www.w3.org/2000/svg"
                                         fill="none"
                                         viewBox="0 0 24 24"
                                         stroke-width="2"
                                         stroke="currentColor"
                                         class="h-5 w-5">
                                        <path stroke-linecap="round"
                                              stroke-linejoin="round"
                                              d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                                    </svg>
                                </div>

                                <p class="text-sm font-black text-slate-700">
                                    Toplam Kayıtlı Kurs Sayısı
                                </p>
                            </div>

                            <p class="text-3xl font-black text-slate-900">
                                @Model.ToplamKursSayisi
                            </p>

                        </div>
                    </div>

                    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                        <div class="flex items-center justify-between gap-4">

                            <div class="flex items-center gap-3">
                                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-blue-50 text-blue-700">
                                    <svg xmlns="http://www.w3.org/2000/svg"
                                         fill="none"
                                         viewBox="0 0 24 24"
                                         stroke-width="2"
                                         stroke="currentColor"
                                         class="h-5 w-5">
                                        <path stroke-linecap="round"
                                              stroke-linejoin="round"
                                              d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25A8.967 8.967 0 0 1 18 3.75c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                                    </svg>
                                </div>

                                <p class="text-sm font-black text-slate-700">
                                    Devam Eden Kurs Sayısı
                                </p>
                            </div>

                            <p class="text-3xl font-black text-blue-700">
                                @Model.DevamEdenKursSayisi
                            </p>

                        </div>
                    </div>

                    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                        <div class="flex items-center justify-between gap-4">

                            <div class="flex items-center gap-3">
                                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-emerald-50 text-emerald-700">
                                    <svg xmlns="http://www.w3.org/2000/svg"
                                         fill="none"
                                         viewBox="0 0 24 24"
                                         stroke-width="2"
                                         stroke="currentColor"
                                         class="h-5 w-5">
                                        <path stroke-linecap="round"
                                              stroke-linejoin="round"
                                              d="M9 12.75 11.25 15 15 9.75M6.75 3.75h10.5A2.25 2.25 0 0 1 19.5 6v12A2.25 2.25 0 0 1 17.25 20.25H6.75A2.25 2.25 0 0 1 4.5 18V6A2.25 2.25 0 0 1 6.75 3.75Z" />
                                    </svg>
                                </div>

                                <p class="text-sm font-black text-slate-700">
                                    Tamamlanan Kurs Sayısı
                                </p>
                            </div>

                            <p class="text-3xl font-black text-emerald-700">
                                @Model.TamamlananKursSayisi
                            </p>

                        </div>
                    </div>

                    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                        <div class="min-w-0">
                            <div class="flex items-center justify-between gap-3">
                                <p class="text-sm font-black text-slate-700">
                                    Ortalama Ders İlerlemesi
                                </p>

                                <p class="text-2xl font-black text-blue-700">
                                    %@ortalamaIlerleme
                                </p>
                            </div>

                            <div class="mt-3 h-2 overflow-hidden rounded-full bg-slate-100">
                                <div class="h-full rounded-full bg-blue-500 transition-all duration-500"
                                     style="width:@ortalamaIlerleme%">
                                </div>
                            </div>
                        </div>
                    </div>

                </section>

                <!-- Filtre -->
                <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">

                    <form asp-controller="OgrenciKurs"
                          asp-action="Kurslarim"
                          method="get"
                          class="grid grid-cols-1 gap-3 xl:grid-cols-[minmax(0,1fr)_220px_220px_220px_auto]">

                        <input type="hidden" name="sayfa" value="1" />

                        <input type="text"
                               name="arama"
                               value="@Model.Arama"
                               placeholder="Kurs adı veya eğitmen ara"
                               class="input input-bordered w-full rounded-xl border-slate-300 bg-white" />

                        <select name="durum"
                                class="select select-bordered w-full rounded-xl border-slate-300 bg-white">

                            @if (Model.Durum == "tum")
                            {
                                <option value="tum" selected>Tüm kurslar</option>
                            }
                            else
                            {
                                <option value="tum">Tüm kurslar</option>
                            }

                            @if (Model.Durum == "devam")
                            {
                                <option value="devam" selected>Devam eden kurslar</option>
                            }
                            else
                            {
                                <option value="devam">Devam eden kurslar</option>
                            }

                            @if (Model.Durum == "tamamlanan")
                            {
                                <option value="tamamlanan" selected>Tamamlanan kurslar</option>
                            }
                            else
                            {
                                <option value="tamamlanan">Tamamlanan kurslar</option>
                            }

                            @if (Model.Durum == "favoriler")
                            {
                                <option value="favoriler" selected>Favorilerim</option>
                            }
                            else
                            {
                                <option value="favoriler">Favorilerim</option>
                            }

                        </select>

                        <select name="kategoriId"
                                class="select select-bordered w-full rounded-xl border-slate-300 bg-white">

                            @if (!Model.KategoriId.HasValue)
                            {
                                <option value="" selected>Tüm kategoriler</option>
                            }
                            else
                            {
                                <option value="">Tüm kategoriler</option>
                            }

                            @foreach (var kategori in Model.Kategoriler)
                            {
                                if (Model.KategoriId == kategori.KategoriId)
                                {
                                    <option value="@kategori.KategoriId" selected>
                                        @kategori.KategoriAdi
                                    </option>
                                }
                                else
                                {
                                    <option value="@kategori.KategoriId">
                                        @kategori.KategoriAdi
                                    </option>
                                }
                            }

                        </select>

                        <select name="siralama"
                                class="select select-bordered w-full rounded-xl border-slate-300 bg-white">

                            @if (Model.Siralama == "guncel")
                            {
                                <option value="guncel" selected>Güncel</option>
                            }
                            else
                            {
                                <option value="guncel">Güncel</option>
                            }

                            @if (Model.Siralama == "eski")
                            {
                                <option value="eski" selected>Eski</option>
                            }
                            else
                            {
                                <option value="eski">Eski</option>
                            }

                            @if (Model.Siralama == "az")
                            {
                                <option value="az" selected>A-Z</option>
                            }
                            else
                            {
                                <option value="az">A-Z</option>
                            }

                            @if (Model.Siralama == "za")
                            {
                                <option value="za" selected>Z-A</option>
                            }
                            else
                            {
                                <option value="za">Z-A</option>
                            }

                            @if (Model.Siralama == "puanYuksek")
                            {
                                <option value="puanYuksek" selected>Puan: Yüksekten Düşüğe</option>
                            }
                            else
                            {
                                <option value="puanYuksek">Puan: Yüksekten Düşüğe</option>
                            }

                            @if (Model.Siralama == "puanDusuk")
                            {
                                <option value="puanDusuk" selected>Puan: Düşükten Yükseğe</option>
                            }
                            else
                            {
                                <option value="puanDusuk">Puan: Düşükten Yükseğe</option>
                            }

                        </select>

                        <div class="flex gap-2 lg:justify-end">
                            <button type="submit"
                                    class="btn btn-primary rounded-xl px-6">
                                Filtrele
                            </button>

                            @if (!string.IsNullOrWhiteSpace(Model.Arama) ||
                                                    Model.Durum != "tum" ||
                                                    Model.KategoriId.HasValue ||
                                                    Model.Siralama != "guncel")
                            {
                                <a asp-controller="OgrenciKurs"
                                   asp-action="Kurslarim"
                                   class="btn btn-outline rounded-xl">
                                    Temizle
                                </a>
                            }
                        </div>

                    </form>

                </section>

                <!-- Liste -->
                <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">

                    <div class="flex flex-col gap-1 border-b border-slate-100 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
                        <div>
                            <h2 class="text-base font-black text-slate-900">
                                Kayıtlı Kurslar
                            </h2>

                            <p class="mt-1 text-sm text-slate-500">
                                @bulunanKursSayisi kurs bulundu
                            </p>
                        </div>
                    </div>

                    @if (Model.Kurslar.Any())
                    {
                        <div class="divide-y divide-slate-100">

                            @foreach (var kurs in Model.Kurslar)
                            {
                                int ilerleme = Math.Clamp(kurs.IlerlemeYuzdesi, 0, 100);

                                bool sinavDurumuVar =
                                !string.IsNullOrWhiteSpace(kurs.SinavDurumu) &&
                                kurs.SinavDurumu != "Henüz sınava girmedi" &&
                                kurs.SinavDurumu != "Henüz girmedi";

                                string modalId = $"degerlendirmeModal_{kurs.KursId}";
                                string degerlendirmeFormId = $"degerlendirmeForm_{kurs.KursId}";
                                string degerlendirmeSilFormId = $"degerlendirmeSilForm_{kurs.KursId}";
                                string kartClass = kurs.GuncelleniyorMu
                                    ? "p-5 bg-amber-50/50 ring-1 ring-inset ring-amber-100"
                                    : "p-5 transition hover:bg-slate-50";
                                string kapakClass = kurs.GuncelleniyorMu
                                    ? "h-28 w-full rounded-2xl object-cover opacity-55 grayscale shadow-sm md:w-44"
                                    : "h-28 w-full rounded-2xl object-cover shadow-sm md:w-44";

                                <article class="@kartClass">

                                    <div class="flex flex-col gap-4 md:flex-row md:items-center">

                                        <div class="relative shrink-0">
                                            @if (!string.IsNullOrWhiteSpace(kurs.KapakGorselUrl))
                                            {
                                                <img src="@kurs.KapakGorselUrl"
                                                     alt="@kurs.KursAdi"
                                                     class="@kapakClass" />
                                            }
                                            else
                                            {
                                                <div class="flex h-28 w-full items-center justify-center rounded-2xl @(kurs.GuncelleniyorMu ? "bg-amber-100 text-amber-800" : "bg-blue-50 text-blue-700") text-sm font-black md:w-44">
                                                    CoursVia
                                                </div>
                                            }

                                            @if (kurs.GuncelleniyorMu)
                                            {
                                                <div class="absolute inset-0 flex items-center justify-center rounded-2xl bg-slate-950/35">
                                                    <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/95 text-amber-700 shadow-sm">
                                                        <svg xmlns="http://www.w3.org/2000/svg"
                                                             fill="none"
                                                             viewBox="0 0 24 24"
                                                             stroke-width="2"
                                                             stroke="currentColor"
                                                             class="h-5 w-5">
                                                            <path stroke-linecap="round"
                                                                  stroke-linejoin="round"
                                                                  d="M16.5 10.5V7.5a4.5 4.5 0 0 0-9 0v3m-.75 0h10.5A1.5 1.5 0 0 1 18.75 12v6A1.5 1.5 0 0 1 17.25 19.5H6.75A1.5 1.5 0 0 1 5.25 18v-6a1.5 1.5 0 0 1 1.5-1.5Z" />
                                                        </svg>
                                                    </span>
                                                </div>
                                            }
                                        </div>

                                        <div class="min-w-0 flex-1">

                                            <div class="flex flex-wrap items-center gap-2">

                                                <h3 class="line-clamp-1 text-base font-black text-slate-900">
                                                    @kurs.KursAdi
                                                </h3>

                                                @if (kurs.GuncelleniyorMu)
                                                {
                                                    <span class="rounded-full border border-amber-200 bg-amber-100 px-2.5 py-0.5 text-xs font-black text-amber-800">
                                                        Erişime Geçici Kapalı
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="rounded-full border px-2.5 py-0.5 text-xs font-bold @KursDurumClass(kurs.KursTamamlandiMi)">
                                                        @(kurs.KursTamamlandiMi ? "Kurs Tamamlandı" : "Kurs Devam Ediyor")
                                                    </span>
                                                }

                                                @if (kurs.FavorideMi)
                                                {
                                                    <span title="Favorilerimde"
                                                          class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-amber-100 bg-amber-50 text-amber-500">
                                                        <svg xmlns="http://www.w3.org/2000/svg"
                                                             viewBox="0 0 24 24"
                                                             fill="currentColor"
                                                             class="h-4 w-4">
                                                            <path fill-rule="evenodd"
                                                                  d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354l-4.627 2.825c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006Z"
                                                                  clip-rule="evenodd" />
                                                        </svg>
                                                    </span>
                                                }

                                            </div>

                                            <p class="mt-1 text-sm font-semibold text-slate-500">
                                                Eğitmen: @kurs.EgitmenAdSoyad
                                            </p>

                                            <div class="mt-2 flex flex-wrap items-center gap-2 text-xs font-semibold text-slate-500">

                                                <span>
                                                    Kayıt Tarihi: @kurs.KayitTarihi.ToString("dd.MM.yyyy")
                                                </span>

                                                @if (kurs.Kategoriler.Any())
                                                {
                                                    <span class="text-slate-300">•</span>

                                                    <span class="max-w-[260px] truncate">
                                                        @string.Join(", ", kurs.Kategoriler)
                                                    </span>
                                                }

                                                @if (kurs.GuncelleniyorMu)
                                                {
                                                    <span class="text-slate-300">•</span>

                                                    <span class="font-bold text-amber-700">
                                                        Kurs erişime geçici olarak kapalı
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-slate-300">•</span>

                                                    <span>
                                                        @kurs.TamamlananDersSayisi / @kurs.ToplamDersSayisi ders tamamlandı
                                                    </span>

                                                    @if (sinavDurumuVar)
                                                    {
                                                        <span class="text-slate-300">•</span>

                                                        <span class="rounded-full border px-2.5 py-0.5 font-bold @SinavDurumClass(kurs.SinavDurumu, kurs.SinavdanGectiMi)">
                                                            @kurs.SinavDurumu
                                                        </span>
                                                    }

                                                    @if (kurs.SonSinavPuani.HasValue)
                                                    {
                                                        <span class="text-slate-300">•</span>

                                                        <span>
                                                            Son sınav puanı: @kurs.SonSinavPuani
                                                        </span>
                                                    }
                                                }

                                            </div>

                                            @if (kurs.GuncelleniyorMu)
                                            {
                                                <div class="mt-4 max-w-2xl rounded-xl border border-amber-200 bg-white/80 px-4 py-3">
                                                    <div class="flex gap-3">
                                                        <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-amber-100 text-amber-700">
                                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                                 fill="none"
                                                                 viewBox="0 0 24 24"
                                                                 stroke-width="2"
                                                                 stroke="currentColor"
                                                                 class="h-4 w-4">
                                                                <path stroke-linecap="round"
                                                                      stroke-linejoin="round"
                                                                      d="M12 6v6l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                                            </svg>
                                                        </div>

                                                        <div class="min-w-0">
                                                            <p class="text-sm font-black text-amber-900">
                                                                Kurs güncelleme modunda
                                                            </p>

                                                            <p class="mt-1 text-xs font-semibold leading-5 text-amber-800">
                                                                İçerik düzenlenirken kurs erişimi kapalıdır. Yayına alındığında kaldığınız yerden devam edebilirsiniz.
                                                            </p>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="mt-4 max-w-2xl">

                                                    <div class="mb-1.5 flex items-center justify-between gap-3">
                                                        <span class="text-xs font-semibold text-slate-500">
                                                            Ders İlerlemesi
                                                        </span>

                                                        <span class="text-xs font-black @IlerlemeTextClass(ilerleme)">
                                                            %@ilerleme
                                                        </span>
                                                    </div>

                                                    <div class="h-2.5 overflow-hidden rounded-full bg-slate-100">
                                                        <div class="h-full rounded-full @IlerlemeBarClass(ilerleme) transition-all duration-500"
                                                             style="width:@ilerleme%">
                                                        </div>
                                                    </div>

                                                </div>
                                            }

                                            @if (kurs.DegerlendirmeVarMi)
                                            {
                                                <div class="mt-3 max-w-2xl rounded-xl border border-amber-100 bg-amber-50 px-3 py-2">

                                                    <div class="flex flex-wrap items-center gap-2">
                                                        <span class="text-sm font-black text-amber-600">
                                                            @YildizGoster(kurs.KendiPuan)
                                                        </span>

                                                        <span class="text-xs font-bold text-amber-700">
                                                            @kurs.KendiPuan / 5
                                                        </span>
                                                    </div>

                                                    @if (!string.IsNullOrWhiteSpace(kurs.KendiYorumMetni))
                                                    {
                                                        <p class="mt-1 line-clamp-2 text-xs font-semibold leading-5 text-amber-800">
                                                            “@kurs.KendiYorumMetni”
                                                        </p>
                                                    }

                                                </div>
                                            }

                                        </div>

                                        <div class="flex shrink-0 flex-row gap-2 md:w-44 md:flex-col">

                                            @if (kurs.GuncelleniyorMu)
                                            {
                                                <button type="button"
                                                        class="btn btn-disabled btn-sm flex-1 rounded-xl border-amber-200 bg-amber-100 text-amber-800 md:flex-none"
                                                        disabled>
                                                    Erişime Kapalı
                                                </button>
                                            }
                                            else
                                            {
                                                <a asp-controller="OgrenciDers"
                                                   asp-action="Izle"
                                                   asp-route-kursId="@kurs.KursId"
                                                   class="btn btn-primary btn-sm flex-1 rounded-xl md:flex-none">
                                                    @DevamButonMetni(kurs.KursTamamlandiMi, ilerleme)
                                                </a>
                                            }

                                            <form asp-controller="OgrenciKurs"
                                                  asp-action="FavoriDegistir"
                                                  asp-route-id="@kurs.KursId"
                                                  method="post"
                                                  class="flex-1 md:flex-none">

                                                @Html.AntiForgeryToken()

                                                <input type="hidden"
                                                       name="returnUrl"
                                                       value="@returnUrl" />

                                                <button type="submit"
                                                        class="btn btn-outline btn-sm w-full rounded-xl @(kurs.FavorideMi ? "border-amber-200 text-amber-600 hover:bg-amber-50" : "")">

                                                    @if (kurs.FavorideMi)
                                                    {
                                                        <span class="inline-flex items-center gap-1.5">
                                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                                 viewBox="0 0 24 24"
                                                                 fill="currentColor"
                                                                 class="h-4 w-4">
                                                                <path fill-rule="evenodd"
                                                                      d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.006 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354l-4.627 2.825c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006Z"
                                                                      clip-rule="evenodd" />
                                                            </svg>
                                                            Çıkar
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="inline-flex items-center gap-1.5">
                                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                                 fill="none"
                                                                 viewBox="0 0 24 24"
                                                                 stroke-width="1.8"
                                                                 stroke="currentColor"
                                                                 class="h-4 w-4">
                                                                <path stroke-linecap="round"
                                                                      stroke-linejoin="round"
                                                                      d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.563.563 0 0 0-.182-.557L3.04 10.385a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
                                                            </svg>
                                                            Favori
                                                        </span>
                                                    }
                                                </button>

                                            </form>

                                            @if (kurs.GuncelleniyorMu)
                                            {
                                                <button type="button"
                                                        class="btn btn-outline btn-sm flex-1 rounded-xl opacity-60 md:flex-none"
                                                        disabled>
                                                    Değerlendirme Kapalı
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        onclick="document.getElementById('@modalId').showModal()"
                                                        class="btn btn-outline btn-sm flex-1 rounded-xl md:flex-none">
                                                    @(kurs.DegerlendirmeVarMi ? "Puanı Güncelle" : "Değerlendir")
                                                </button>
                                            }

                                            <form asp-controller="OgrenciKurs"
                                                  asp-action="KayitIptal"
                                                  asp-route-id="@kurs.KursId"
                                                  method="post"
                                                  class="js-kayit-sil-form flex-1 md:flex-none">

                                                @Html.AntiForgeryToken()

                                                <input type="hidden"
                                                       name="returnUrl"
                                                       value="@returnUrl" />

                                                <button type="submit"
                                                        class="btn btn-error btn-sm w-full rounded-xl text-white shadow-sm hover:brightness-95">
                                                    Kaydı Sil
                                                </button>

                                            </form>

                                        </div>

                                    </div>

                                    <dialog id="@modalId" class="modal">

                                        <div class="modal-box rounded-2xl bg-white">

                                            <form method="dialog">
                                                <button class="btn btn-sm btn-circle btn-ghost absolute right-4 top-4">
                                                    ✕
                                                </button>
                                            </form>

                                            <h3 class="text-lg font-black text-slate-900">
                                                Kursu Değerlendir
                                            </h3>

                                            <p class="mt-1 text-sm text-slate-500">
                                                @kurs.KursAdi için puanını ve yorumunu paylaşabilirsin.
                                            </p>

                                            <form id="@degerlendirmeFormId"
                                                  asp-controller="OgrenciKurs"
                                                  asp-action="Degerlendir"
                                                  method="post"
                                                  class="mt-5 space-y-4">

                                                @Html.AntiForgeryToken()

                                                <input type="hidden"
                                                       name="kursId"
                                                       value="@kurs.KursId" />

                                                <input type="hidden"
                                                       name="returnUrl"
                                                       value="@returnUrl" />

                                                <div>
                                                    <label class="mb-2 block text-sm font-bold text-slate-700">
                                                        Puan
                                                    </label>

                                                    <div class="rating rating-lg gap-1">

                                                        @for (int puanSecenek = 1; puanSecenek <= 5; puanSecenek++)
                                                        {
                                                            if (kurs.KendiPuan == puanSecenek)
                                                            {
                                                                <input type="radio"
                                                                       name="puan"
                                                                       value="@puanSecenek"
                                                                       required
                                                                       class="mask mask-star-2 bg-amber-400"
                                                                       checked />
                                                            }
                                                            else
                                                            {
                                                                <input type="radio"
                                                                       name="puan"
                                                                       value="@puanSecenek"
                                                                       required
                                                                       class="mask mask-star-2 bg-amber-400" />
                                                            }
                                                        }

                                                    </div>
                                                </div>

                                                <div>
                                                    <label class="mb-2 block text-sm font-bold text-slate-700">
                                                        Yorum
                                                    </label>

                                                    <textarea name="yorumMetni"
                                                      rows="4"
                                                      maxlength="500"
                                                      placeholder="Kurs hakkındaki düşünceni yazabilirsin."
                                                      class="textarea textarea-bordered w-full resize-none rounded-xl border-slate-300 bg-white">@kurs.KendiYorumMetni</textarea>

                                                    <p class="mt-1 text-xs text-slate-400">
                                                        Yorum alanı isteğe bağlıdır.
                                                    </p>
                                                </div>

                                            </form>

                                            @if (kurs.DegerlendirmeVarMi)
                                            {
                                                <form id="@degerlendirmeSilFormId"
                                                      asp-controller="OgrenciKurs"
                                                      asp-action="DegerlendirmeSil"
                                                      method="post">

                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden"
                                                           name="kursId"
                                                           value="@kurs.KursId" />

                                                    <input type="hidden"
                                                           name="returnUrl"
                                                           value="@returnUrl" />

                                                </form>
                                            }

                                            <div class="mt-5 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">

                                                <div>
                                                    @if (kurs.DegerlendirmeVarMi)
                                                    {
                                                        <button type="submit"
                                                                form="@degerlendirmeSilFormId"
                                                                class="btn btn-error rounded-xl text-white">
                                                            Değerlendirmeyi Sil
                                                        </button>
                                                    }
                                                </div>

                                                <div class="flex justify-end gap-2">

                                                    <button type="button"
                                                            onclick="document.getElementById('@modalId').close()"
                                                            class="btn btn-outline rounded-xl">
                                                        Vazgeç
                                                    </button>

                                                    <button type="submit"
                                                            form="@degerlendirmeFormId"
                                                            class="btn btn-primary rounded-xl px-6">
                                                        @(kurs.DegerlendirmeVarMi ? "Güncelle" : "Kaydet")
                                                    </button>

                                                </div>

                                            </div>

                                        </div>

                                        <form method="dialog" class="modal-backdrop">
                                            <button>Kapat</button>
                                        </form>

                                    </dialog>

                                </article>
                            }

                        </div>

                        @if (Model.ToplamSayfa > 1)
                        {
                            <div class="flex flex-col gap-3 border-t border-slate-100 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">

                                <p class="text-sm text-slate-500">
                                    Sayfa
                                    <span class="font-bold text-slate-900">@Model.Sayfa</span>
                                    /
                                    <span class="font-bold text-slate-900">@Model.ToplamSayfa</span>
                                </p>

                                <div class="flex flex-wrap items-center gap-2">

                                    @if (Model.OncekiSayfaVar)
                                    {
                                        <a asp-controller="OgrenciKurs"
                                           asp-action="Kurslarim"
                                           asp-route-arama="@Model.Arama"
                                           asp-route-durum="@Model.Durum"
                                           asp-route-kategoriId="@Model.KategoriId"
                                           asp-route-siralama="@Model.Siralama"
                                           asp-route-sayfa="@(Model.Sayfa - 1)"
                                           class="btn btn-outline btn-sm rounded-xl">
                                            Önceki
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-outline btn-sm rounded-xl opacity-50"
                                                disabled>
                                            Önceki
                                        </button>
                                    }

                                    @for (int i = 1; i <= Model.ToplamSayfa; i++)
                                    {
                                        if (i == Model.Sayfa)
                                        {
                                            <span class="btn btn-primary btn-sm rounded-xl">
                                                @i
                                            </span>
                                        }
                                        else
                                        {
                                            <a asp-controller="OgrenciKurs"
                                               asp-action="Kurslarim"
                                               asp-route-arama="@Model.Arama"
                                               asp-route-durum="@Model.Durum"
                                               asp-route-kategoriId="@Model.KategoriId"
                                               asp-route-siralama="@Model.Siralama"
                                               asp-route-sayfa="@i"
                                               class="btn btn-outline btn-sm rounded-xl">
                                                @i
                                            </a>
                                        }
                                    }

                                    @if (Model.SonrakiSayfaVar)
                                    {
                                        <a asp-controller="OgrenciKurs"
                                           asp-action="Kurslarim"
                                           asp-route-arama="@Model.Arama"
                                           asp-route-durum="@Model.Durum"
                                           asp-route-kategoriId="@Model.KategoriId"
                                           asp-route-siralama="@Model.Siralama"
                                           asp-route-sayfa="@(Model.Sayfa + 1)"
                                           class="btn btn-outline btn-sm rounded-xl">
                                            Sonraki
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-outline btn-sm rounded-xl opacity-50"
                                                disabled>
                                            Sonraki
                                        </button>
                                    }

                                </div>

                            </div>
                        }
                    }
                    else
                    {
                        <div class="px-6 py-14 text-center">

                            <h3 class="text-base font-black text-slate-900">
                                Kurs bulunamadı
                            </h3>

                            <p class="mt-1 text-sm text-slate-500">
                                @if (Model.Durum == "favoriler")
                                {
                                    <span>Henüz favorilere eklediğin bir kurs bulunmuyor.</span>
                                }
                                else
                                {
                                    <span>Arama veya filtreye uygun kayıtlı kurs bulunmuyor.</span>
                                }
                            </p>

                            <div class="mt-5 flex justify-center gap-2">
                                <a asp-controller="OgrenciKurs"
                                   asp-action="Kurslarim"
                                   class="btn btn-outline rounded-xl px-6">
                                    Filtreleri Temizle
                                </a>

                                <a asp-controller="OgrenciKurs"
                                   asp-action="Kesfet"
                                   class="btn btn-primary rounded-xl px-6">
                                    Kurs Keşfet
                                </a>
                            </div>

                        </div>
                    }

                </section>

            </div>

        </main>

    </div>

</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            document.querySelectorAll(".js-kayit-sil-form").forEach(function (form) {
                form.addEventListener("submit", function (event) {
                    event.preventDefault();

                    Swal.fire({
                        title: "Kurs kaydı silinsin mi?",
                        text: "Bu işlem geri alınamaz. Kursa ait tüm verilerin silinecek.",
                        icon: "warning",
                        showCancelButton: true,
                        confirmButtonText: "Evet, sil",
                        cancelButtonText: "Vazgeç",
                        confirmButtonColor: "#dc2626",
                        cancelButtonColor: "#64748b",
                        reverseButtons: true,
                        focusCancel: true
                    }).then(function (result) {
                        if (result.isConfirmed) {
                            form.submit();
                        }
                    });
                });
            });

        });
    </script>
}
