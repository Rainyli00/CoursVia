@model CoursVia.ViewModels.Ogrenci.KursDetayViewModel

@{
    ViewData["Title"] = Model.KursAdi;

    int ortalamaPuanYuvarlak = Model.OrtalamaPuan <= 0
        ? 0
        : Math.Clamp((int)Math.Round(Model.OrtalamaPuan), 1, 5);
}

<div class="min-h-[calc(100vh-130px)] bg-slate-50">

    <div class="grid min-h-[calc(100vh-130px)] grid-cols-1 lg:grid-cols-[300px_minmax(0,1fr)]">

        <partial name="_OgrenciSidebar" />

        <main class="min-w-0 px-5 py-7 sm:px-7 lg:px-10">

            <div class="mx-auto max-w-6xl space-y-5">

                @if (TempData["OgrenciHata"] != null)
                {
                    <div class="flash-message alert alert-error rounded-2xl shadow-sm transition-all duration-500">
                        <span>@TempData["OgrenciHata"]</span>
                    </div>
                }

                @if (TempData["OgrenciBasari"] != null)
                {
                    <div class="flash-message alert rounded-2xl border border-emerald-100 bg-emerald-50 text-emerald-700 shadow-sm transition-all duration-500">
                        <span>@TempData["OgrenciBasari"]</span>
                    </div>
                }

                <!-- Üst Başlık -->
                <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">

                    <div class="mb-4 flex flex-wrap items-center gap-2 text-sm">
                        <a asp-controller="OgrenciKurs"
                           asp-action="Kesfet"
                           class="font-bold text-blue-600 transition hover:text-blue-700">
                            Kurs Keşfet
                        </a>

                        <span class="text-slate-300">/</span>

                        <span class="font-semibold text-slate-500">
                            Kurs Detayı
                        </span>
                    </div>

                    <div class="grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1fr)_340px] lg:items-start">

                        <!-- Sol Bilgi -->
                        <div class="min-w-0">

                            <div class="flex flex-wrap items-center gap-2">

                                @if (Model.KayitliMi)
                                {
                                    <span class="rounded-full border border-emerald-100 bg-emerald-50 px-3 py-1 text-xs font-bold text-emerald-700">
                                        Kayıtlısın
                                    </span>
                                }

                                @if (Model.KendiKursuMu)
                                {
                                    <span class="rounded-full border border-blue-100 bg-blue-50 px-3 py-1 text-xs font-bold text-blue-700">
                                        Kendi Kursun
                                    </span>
                                }

                            </div>

                            <h1 class="mt-3 text-2xl font-black leading-tight text-slate-900 md:text-3xl">
                                @Model.KursAdi
                            </h1>

                            <p class="mt-3 max-w-3xl text-sm leading-7 text-slate-500">
                                @(string.IsNullOrWhiteSpace(Model.Aciklama)
                                                                ? "Bu kurs için açıklama girilmemiş."
                                                                : Model.Aciklama)
                            </p>

                            <div class="mt-5 flex flex-wrap items-center gap-3 text-sm font-semibold text-slate-600">

                                <span>
                                    Eğitmen:
                                    <span class="text-slate-900">
                                        @Model.EgitmenAdSoyad
                                    </span>
                                </span>

                                <span class="text-slate-300">•</span>

                                <span>
                                    @Model.BolumSayisi bölüm
                                </span>

                                <span class="text-slate-300">•</span>

                                <span>
                                    @Model.DersSayisi ders
                                </span>

                                <span class="text-slate-300">•</span>

                                <span class="inline-flex items-center gap-2">
                                    <span class="font-black text-amber-600">
                                        @(Model.OrtalamaPuan > 0 ? Model.OrtalamaPuan.ToString("0.0") : "0.0")
                                    </span>

                                    <span class="text-slate-500">
                                        @Model.DegerlendirmeSayisi değerlendirme
                                    </span>
                                </span>

                            </div>

                            @if (Model.Kategoriler.Any())
                            {
                                <div class="mt-5 flex flex-wrap gap-2">
                                    @foreach (var kategori in Model.Kategoriler)
                                    {
                                        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-bold text-slate-600">
                                            @kategori
                                        </span>
                                    }
                                </div>
                            }

                        </div>

                        <!-- Sağ Görsel -->
                        <div class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 shadow-sm">

                            @if (!string.IsNullOrWhiteSpace(Model.KapakGorselUrl))
                            {
                                <img src="@Model.KapakGorselUrl"
                                     alt="@Model.KursAdi"
                                     class="h-52 w-full object-cover" />
                            }
                            else
                            {
                                <div class="flex h-52 w-full items-center justify-center bg-blue-50 text-lg font-black text-blue-700">
                                    CoursVia
                                </div>
                            }

                        </div>

                    </div>

                </section>

                <div class="grid grid-cols-1 gap-5 xl:grid-cols-[minmax(0,1fr)_320px]">

                    <!-- Sol İçerik -->
                    <div class="space-y-5">

                        <!-- Kurs İçeriği -->
                        <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">

                            <div class="border-b border-slate-100 px-5 py-4">
                                <h2 class="text-lg font-black text-slate-900">
                                    Kurs İçeriği
                                </h2>

                                <p class="mt-1 text-sm text-slate-500">
                                    Kursa ait bölümler ve dersler aşağıda listelenir.
                                </p>
                            </div>

                            @if (Model.Bolumler.Any())
                            {
                                <div class="divide-y divide-slate-100">

                                    @foreach (var bolum in Model.Bolumler)
                                    {
                                        <details class="group" open>

                                            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 transition hover:bg-slate-50">

                                                <div class="min-w-0">
                                                    <h3 class="truncate text-sm font-black text-slate-900">
                                                        @bolum.SiraNo. @bolum.BolumAdi
                                                    </h3>

                                                    <p class="mt-1 text-xs font-semibold text-slate-400">
                                                        @bolum.Dersler.Count ders
                                                    </p>
                                                </div>

                                                <svg xmlns="http://www.w3.org/2000/svg"
                                                     class="h-5 w-5 shrink-0 text-slate-400 transition group-open:rotate-180"
                                                     fill="none"
                                                     viewBox="0 0 24 24"
                                                     stroke="currentColor">
                                                    <path stroke-linecap="round"
                                                          stroke-linejoin="round"
                                                          stroke-width="2"
                                                          d="M19 9l-7 7-7-7" />
                                                </svg>

                                            </summary>

                                            @if (bolum.Dersler.Any())
                                            {
                                                <div class="border-t border-slate-100 bg-slate-50">

                                                    @foreach (var ders in bolum.Dersler)
                                                    {
                                                        <div class="flex items-start justify-between gap-4 border-b border-slate-100 px-5 py-3 last:border-b-0">

                                                            <div class="min-w-0 flex-1">

                                                                <div class="flex items-start gap-3">

                                                                    <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-white text-xs font-black text-blue-700 ring-1 ring-blue-100">
                                                                        @ders.SiraNo
                                                                    </span>

                                                                    <div class="min-w-0">
                                                                        <p class="truncate text-sm font-bold text-slate-800">
                                                                            @ders.DersAdi
                                                                        </p>

                                                                        @if (!string.IsNullOrWhiteSpace(ders.Aciklama))
                                                                        {
                                                                            <p class="mt-1 line-clamp-1 text-xs leading-5 text-slate-500">
                                                                                @ders.Aciklama
                                                                            </p>
                                                                        }
                                                                    </div>

                                                                </div>

                                                            </div>

                                                            <div class="shrink-0">

                                                                @if (ders.MateryalSayisi > 0)
                                                                {
                                                                    <span class="inline-flex items-center gap-1.5 rounded-full border border-blue-100 bg-blue-50 px-2.5 py-1 text-xs font-bold text-blue-700">

                                                                        <svg xmlns="http://www.w3.org/2000/svg"
                                                                             class="h-3.5 w-3.5"
                                                                             fill="none"
                                                                             viewBox="0 0 24 24"
                                                                             stroke="currentColor">
                                                                            <path stroke-linecap="round"
                                                                                  stroke-linejoin="round"
                                                                                  stroke-width="2"
                                                                                  d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5A3.375 3.375 0 0 0 10.125 2.25H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                                                                        </svg>

                                                                        Ek kaynak var
                                                                    </span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="inline-flex items-center rounded-full border border-slate-200 bg-white px-2.5 py-1 text-xs font-bold text-slate-400">
                                                                        Kaynak yok
                                                                    </span>
                                                                }

                                                            </div>

                                                        </div>
                                                    }

                                                </div>
                                            }
                                            else
                                            {
                                                <div class="border-t border-slate-100 bg-slate-50 px-5 py-4">
                                                    <p class="text-sm font-semibold text-slate-400">
                                                        Bu bölümde ders bulunmuyor.
                                                    </p>
                                                </div>
                                            }

                                        </details>
                                    }

                                </div>
                            }
                            else
                            {
                                <div class="px-6 py-12 text-center">
                                    <h3 class="text-base font-black text-slate-900">
                                        İçerik bulunamadı
                                    </h3>

                                    <p class="mt-1 text-sm text-slate-500">
                                        Bu kurs için henüz bölüm veya ders listesi bulunmuyor.
                                    </p>
                                </div>
                            }

                        </section>

                        <!-- Kurs Değerlendirmeleri -->
                        <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">

                            <div class="flex flex-col gap-3 border-b border-slate-100 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">

                                <div>
                                    <h2 class="text-lg font-black text-slate-900">
                                        Kurs Değerlendirmeleri
                                    </h2>

                                    <p class="mt-1 text-sm text-slate-500">
                                        Öğrencilerin bu kurs için yaptığı değerlendirmeler.
                                    </p>
                                </div>

                                <div class="rounded-2xl border border-amber-100 bg-amber-50 px-4 py-3">

                                    <div class="flex items-center gap-3">

                                        <span class="text-2xl font-black text-amber-600">
                                            @(Model.OrtalamaPuan > 0 ? Model.OrtalamaPuan.ToString("0.0") : "0.0")
                                        </span>

                                        <div>
                                            <div class="rating rating-sm">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    if (ortalamaPuanYuvarlak == i)
                                                    {
                                                        <input type="radio"
                                                               name="yorumOrtalamaPuan"
                                                               class="mask mask-star-2 bg-amber-400"
                                                               checked
                                                               disabled />
                                                    }
                                                    else
                                                    {
                                                        <input type="radio"
                                                               name="yorumOrtalamaPuan"
                                                               class="mask mask-star-2 bg-amber-400"
                                                               disabled />
                                                    }
                                                }
                                            </div>

                                            <p class="text-xs font-semibold text-amber-700">
                                                @Model.DegerlendirmeSayisi değerlendirme
                                            </p>
                                        </div>

                                    </div>

                                </div>

                            </div>

                            @if (Model.Degerlendirmeler.Any())
                            {
                                <div class="divide-y divide-slate-100">

                                    @foreach (var yorum in Model.Degerlendirmeler)
                                    {
                                        int yorumPuani = Math.Clamp(yorum.Puan, 1, 5);
                                        string yorumRatingName = $"yorumPuan_{yorum.DegerlendirmeId}";

                                        <article class="px-5 py-4">

                                            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">

                                                <div class="min-w-0">

                                                    <div class="flex flex-wrap items-center gap-2">

                                                        <h3 class="text-sm font-black text-slate-900">
                                                            @yorum.OgrenciAdSoyad
                                                        </h3>

                                                        <span class="text-xs font-semibold text-slate-400">
                                                            @yorum.DegerlendirmeTarihi.ToString("dd.MM.yyyy")
                                                        </span>

                                                    </div>

                                                    @if (!string.IsNullOrWhiteSpace(yorum.YorumMetni))
                                                    {
                                                        <p class="mt-2 text-sm leading-6 text-slate-600">
                                                            “@yorum.YorumMetni”
                                                        </p>
                                                    }
                                                    else
                                                    {
                                                        <p class="mt-2 text-sm font-semibold text-slate-400">
                                                            Yorum metni bulunmuyor.
                                                        </p>
                                                    }

                                                </div>

                                                <div class="shrink-0">

                                                    <div class="rating rating-sm">
                                                        @for (int i = 1; i <= 5; i++)
                                                        {
                                                            if (yorumPuani == i)
                                                            {
                                                                <input type="radio"
                                                                       name="@yorumRatingName"
                                                                       class="mask mask-star-2 bg-amber-400"
                                                                       checked
                                                                       disabled />
                                                            }
                                                            else
                                                            {
                                                                <input type="radio"
                                                                       name="@yorumRatingName"
                                                                       class="mask mask-star-2 bg-amber-400"
                                                                       disabled />
                                                            }
                                                        }
                                                    </div>

                                                    <p class="mt-1 text-right text-xs font-bold text-amber-700">
                                                        @yorum.Puan / 5
                                                    </p>

                                                </div>

                                            </div>

                                        </article>
                                    }

                                </div>

                                @if (Model.YorumToplamSayfa > 1)
                                {
                                    <div class="flex flex-col gap-3 border-t border-slate-100 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">

                                        <p class="text-sm text-slate-500">
                                            Yorum sayfası
                                            <span class="font-bold text-slate-900">@Model.YorumSayfa</span>
                                            /
                                            <span class="font-bold text-slate-900">@Model.YorumToplamSayfa</span>
                                        </p>

                                        <div class="flex flex-wrap items-center gap-2">

                                            @if (Model.YorumOncekiSayfaVar)
                                            {
                                                <a asp-controller="OgrenciKurs"
                                                   asp-action="Detay"
                                                   asp-route-id="@Model.KursId"
                                                   asp-route-yorumSayfa="@(Model.YorumSayfa - 1)"
                                                   class="btn btn-outline btn-sm rounded-xl">
                                                    Önceki
                                                </a>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        class="btn btn-outline btn-sm rounded-xl opacity-50"
                                                        disabled>
                                                    Önceki
                                                </button>
                                            }

                                            @for (int i = 1; i <= Model.YorumToplamSayfa; i++)
                                            {
                                                if (i == Model.YorumSayfa)
                                                {
                                                    <span class="btn btn-primary btn-sm rounded-xl">
                                                        @i
                                                    </span>
                                                }
                                                else
                                                {
                                                    <a asp-controller="OgrenciKurs"
                                                       asp-action="Detay"
                                                       asp-route-id="@Model.KursId"
                                                       asp-route-yorumSayfa="@i"
                                                       class="btn btn-outline btn-sm rounded-xl">
                                                        @i
                                                    </a>
                                                }
                                            }

                                            @if (Model.YorumSonrakiSayfaVar)
                                            {
                                                <a asp-controller="OgrenciKurs"
                                                   asp-action="Detay"
                                                   asp-route-id="@Model.KursId"
                                                   asp-route-yorumSayfa="@(Model.YorumSayfa + 1)"
                                                   class="btn btn-outline btn-sm rounded-xl">
                                                    Sonraki
                                                </a>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        class="btn btn-outline btn-sm rounded-xl opacity-50"
                                                        disabled>
                                                    Sonraki
                                                </button>
                                            }

                                        </div>

                                    </div>
                                }
                            }
                            else
                            {
                                <div class="px-6 py-12 text-center">

                                    <h3 class="text-base font-black text-slate-900">
                                        Henüz değerlendirme yok
                                    </h3>

                                    <p class="mt-1 text-sm text-slate-500">
                                        Bu kurs için öğrenciler tarafından yapılmış bir değerlendirme bulunmuyor.
                                    </p>

                                </div>
                            }

                        </section>

                    </div>

                    <!-- Sağ İşlem Kartı -->
                    <aside class="h-fit xl:sticky xl:top-24">

                        <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">

                            <div class="space-y-4">

                                <div>
                                    <p class="text-xs font-bold uppercase tracking-wider text-blue-600">
                                        Kurs Özeti
                                    </p>

                                    <h2 class="mt-1 line-clamp-2 text-lg font-black text-slate-900">
                                        @Model.KursAdi
                                    </h2>
                                </div>

                                <div class="rounded-2xl border border-slate-100 bg-slate-50 p-4">

                                    <div class="flex items-center justify-between gap-3">
                                        <span class="text-sm font-bold text-slate-500">
                                            Ortalama Puan
                                        </span>

                                        <span class="text-lg font-black text-slate-900">
                                            @(Model.OrtalamaPuan > 0 ? Model.OrtalamaPuan.ToString("0.0") : "0.0")
                                        </span>
                                    </div>

                                    <div class="mt-2 flex items-center justify-between gap-3">

                                        <div class="rating rating-sm">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (ortalamaPuanYuvarlak == i)
                                                {
                                                    <input type="radio"
                                                           name="sagKartOrtalamaPuan"
                                                           class="mask mask-star-2 bg-amber-400"
                                                           checked
                                                           disabled />
                                                }
                                                else
                                                {
                                                    <input type="radio"
                                                           name="sagKartOrtalamaPuan"
                                                           class="mask mask-star-2 bg-amber-400"
                                                           disabled />
                                                }
                                            }
                                        </div>

                                        <span class="text-xs font-semibold text-slate-500">
                                            @Model.DegerlendirmeSayisi değerlendirme
                                        </span>

                                    </div>

                                </div>

                                <div class="grid grid-cols-2 gap-3">

                                    <div class="rounded-2xl border border-slate-100 bg-white p-3">
                                        <p class="text-xs font-bold text-slate-400">
                                            Bölüm
                                        </p>

                                        <p class="mt-1 text-xl font-black text-slate-900">
                                            @Model.BolumSayisi
                                        </p>
                                    </div>

                                    <div class="rounded-2xl border border-slate-100 bg-white p-3">
                                        <p class="text-xs font-bold text-slate-400">
                                            Ders
                                        </p>

                                        <p class="mt-1 text-xl font-black text-slate-900">
                                            @Model.DersSayisi
                                        </p>
                                    </div>

                                </div>

                                <div class="space-y-2">

                                    @if (Model.KendiKursuMu)
                                    {
                                        <button type="button"
                                                class="btn w-full rounded-xl border-slate-200 bg-slate-100 text-slate-400"
                                                disabled>
                                            Kendi Kursuna Kayıt Olamazsın
                                        </button>

                                        <a asp-controller="EgitmenKurs"
                                           asp-action="OnIzle"
                                           asp-route-id="@Model.KursId"
                                           class="btn btn-outline w-full rounded-xl">
                                            Eğitmen Önizlemeye Git
                                        </a>
                                    }
                                    else if (Model.KayitliMi)
                                    {
                                        <a asp-controller="OgrenciDers"
                                           asp-action="Izle"
                                           asp-route-kursId="@Model.KursId"
                                           class="btn btn-primary w-full rounded-xl">
                                            Derse Devam Et
                                        </a>
                                    }
                                    else
                                    {
                                        <form asp-controller="OgrenciKurs"
                                              asp-action="KayitOl"
                                              asp-route-id="@Model.KursId"
                                              method="post">

                                            @Html.AntiForgeryToken()

                                            <button type="submit"
                                                    class="btn btn-primary w-full rounded-xl">
                                                Kayıt Ol
                                            </button>
                                        </form>
                                    }

                                    <a asp-controller="OgrenciKurs"
                                       asp-action="Kesfet"
                                       class="btn btn-outline w-full rounded-xl">
                                        Keşfetmeye Dön
                                    </a>

                                </div>

                            </div>

                        </section>

                    </aside>

                </div>

            </div>

        </main>

    </div>

</div>