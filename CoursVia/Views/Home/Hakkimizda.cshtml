@{
    ViewData["Title"] = "Hakkımızda";
}

<div class="bg-slate-50">

    <!-- Hero -->
    <section class="border-b border-slate-200 bg-white">
        <div class="mx-auto max-w-7xl px-5 py-14 sm:px-7 lg:px-8">

            <div class="flex flex-col items-center text-center max-w-4xl mx-auto">

                <p class="text-sm font-black uppercase tracking-wider text-blue-600">
                    CoursVia Hakkında
                </p>

                <h1 class="mt-3 text-4xl font-black tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
                    Online eğitimi daha erişilebilir, düzenli ve ölçülebilir hale getiriyoruz.
                </h1>

                <p class="mt-5 max-w-2xl text-base leading-8 text-slate-600">
                    CoursVia; öğrencilerin kurslara kolayca erişmesini, eğitmenlerin içeriklerini yönetmesini
                    ve yöneticilerin tüm süreci güvenli şekilde takip etmesini sağlayan modern bir online eğitim platformudur.
                </p>

                <div class="mt-8 flex flex-wrap justify-center gap-4">
                    <a asp-controller="Home"
                       asp-action="Kurslar"
                       class="btn btn-primary rounded-xl px-8 text-base">
                        Kursları Keşfet
                    </a>
                </div>

            </div>

        </div>
    </section>

    <!-- Özellikler -->
    <section class="mx-auto max-w-7xl px-5 py-12 sm:px-7 lg:px-8">

        <div class="grid grid-cols-1 gap-5 md:grid-cols-3">

            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-blue-50 text-blue-700">
                    <svg xmlns="http://www.w3.org/2000/svg"
                         fill="none"
                         viewBox="0 0 24 24"
                         stroke-width="2"
                         stroke="currentColor"
                         class="h-5 w-5">
                        <path stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.5 20.25a8.25 8.25 0 0 1 15 0" />
                    </svg>
                </div>

                <h3 class="mt-5 text-lg font-black text-slate-900">
                    Öğrenciler için
                </h3>

                <p class="mt-2 text-sm leading-7 text-slate-600">
                    Öğrenciler kursları keşfedebilir, dersleri takip edebilir, sınavlara katılabilir ve başarılı olduklarında sertifika kazanabilir.
                </p>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-50 text-emerald-700">
                    <svg xmlns="http://www.w3.org/2000/svg"
                         fill="none"
                         viewBox="0 0 24 24"
                         stroke-width="2"
                         stroke="currentColor"
                         class="h-5 w-5">
                        <path stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M12 4.5v15m7.5-7.5h-15" />
                    </svg>
                </div>

                <h3 class="mt-5 text-lg font-black text-slate-900">
                    Eğitmenler için
                </h3>

                <p class="mt-2 text-sm leading-7 text-slate-600">
                    Eğitmenler kurs oluşturabilir, bölümler ve dersler ekleyebilir, sınav hazırlayabilir ve öğrencilerinin ilerlemesini takip edebilir.
                </p>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-slate-100 text-slate-700">
                    <svg xmlns="http://www.w3.org/2000/svg"
                         fill="none"
                         viewBox="0 0 24 24"
                         stroke-width="2"
                         stroke="currentColor"
                         class="h-5 w-5">
                        <path stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M9 12.75 11.25 15 15 9.75M12 3.75 4.5 6.75v5.25c0 4.5 3.15 8.7 7.5 9.75 4.35-1.05 7.5-5.25 7.5-9.75V6.75L12 3.75Z" />
                    </svg>
                </div>

                <h3 class="mt-5 text-lg font-black text-slate-900">
                    Yönetim için
                </h3>

                <p class="mt-2 text-sm leading-7 text-slate-600">
                    Adminler kullanıcıları, kurs onaylarını, eğitmen başvurularını, yorumları, kategorileri ve sistem kayıtlarını yönetebilir.
                </p>
            </div>

        </div>

    </section>

    <!-- Misyon -->
    <section class="mx-auto max-w-7xl px-5 pb-14 sm:px-7 lg:px-8">

        <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">

            <div class="grid grid-cols-1 gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">

                <div>
                    <p class="text-sm font-black uppercase tracking-wider text-blue-600">
                        Amacımız
                    </p>

                    <h2 class="mt-3 text-3xl font-black tracking-tight text-slate-900">
                        Eğitim sürecini herkes için daha düzenli hale getirmek.
                    </h2>
                </div>

                <div class="space-y-4 text-sm leading-8 text-slate-600">
                    <p>
                        CoursVia, klasik eğitim yönetimini modern web teknolojileriyle birleştirerek kullanıcı dostu bir öğrenme deneyimi sunmayı hedefler.
                    </p>

                    <p>
                        Platform; kurs yayınlama, içerik düzenleme, sınav değerlendirme, ilerleme takibi ve sertifika doğrulama gibi temel ihtiyaçları sade bir arayüzle karşılar.
                    </p>
                </div>

            </div>

        </div>

    </section>

</div>