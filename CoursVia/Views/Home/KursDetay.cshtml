@model CoursVia.ViewModels.Ogrenci.KursDetayViewModel

@{
    ViewData["Title"] = Model.KursAdi;

    int ortalamaPuanYuvarlak = Model.OrtalamaPuan <= 0
        ? 0
        : Math.Clamp((int)Math.Round(Model.OrtalamaPuan), 1, 5);

    string kurslarReturnUrl = ViewData["KurslarReturnUrl"] as string
        ?? Url.Action("Kurslar", "Home")
        ?? "/Home/Kurslar";

    string aktifRol = User.FindFirst("AktifRol")?.Value ?? "";
    bool girisliMi = User.Identity?.IsAuthenticated == true;
    bool aktifOgrenciMi = aktifRol == "Öğrenci";
    bool ogrenciRoluVarMi = User.IsInRole("Öğrenci");
    string ogrenciKursDetayUrl = Url.Action("Detay", "OgrenciKurs", new { id = Model.KursId }) ?? $"/OgrenciKurs/Detay/{Model.KursId}";
    string ogrenciDersUrl = Url.Action("Izle", "OgrenciDers", new { kursId = Model.KursId }) ?? $"/OgrenciDers/Izle?kursId={Model.KursId}";
    string ogrenciReturnUrl = Model.KayitliMi
        ? ogrenciDersUrl
        : ogrenciKursDetayUrl;
}

<main class="mx-auto max-w-6xl px-5 py-8 sm:px-7 lg:px-8">

    <!-- Üst Bilgi -->
    <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
        <div class="grid grid-cols-1 gap-5 p-5 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-center">

            <div class="min-w-0">
                <div class="mb-3 flex flex-wrap items-center gap-2 text-sm font-bold">
                    <a href="@kurslarReturnUrl"
                       class="text-blue-600 transition hover:text-blue-700">
                        Tüm Kurslar
                    </a>

                    <span class="text-slate-300">/</span>

                    <span class="text-slate-500">
                        Kurs Detayı
                    </span>
                </div>

                <div class="flex flex-wrap items-center gap-2">
                    @foreach (var kategori in Model.Kategoriler.Take(3))
                    {
                        <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-black text-blue-700">
                            @kategori
                        </span>
                    }

                    @if (Model.KayitliMi)
                    {
                        <span class="rounded-full border border-emerald-100 bg-emerald-50 px-3 py-1 text-xs font-black text-emerald-700">
                            Kayıtlısın
                        </span>
                    }
                </div>

                <h1 class="mt-3 text-3xl font-black leading-tight text-slate-950 sm:text-4xl">
                    @Model.KursAdi
                </h1>

                <p class="mt-3 max-w-4xl text-base font-medium leading-7 text-slate-500">
                    @(string.IsNullOrWhiteSpace(Model.Aciklama)
                                        ? "Bu kurs için açıklama yakında eklenecek."
                                        : Model.Aciklama)
                </p>

                <div class="mt-4 flex flex-wrap items-center gap-3 text-sm font-bold text-slate-600">
                    <span>
                        Eğitmen:
                        <span class="text-slate-950">@Model.EgitmenAdSoyad</span>
                    </span>

                    <span class="text-slate-300">•</span>

                    <span>@Model.BolumSayisi bölüm</span>

                    <span class="text-slate-300">•</span>

                    <span>@Model.DersSayisi ders</span>

                    <span class="text-slate-300">•</span>

                    <span class="inline-flex items-center gap-1">
                        <span class="text-amber-500">★</span>
                        <span class="font-black text-amber-700">
                            @(Model.DegerlendirmeSayisi > 0 ? Model.OrtalamaPuan.ToString("0.0") : "Puan yok")
                        </span>
                        <span class="text-slate-500">
                            (@Model.DegerlendirmeSayisi)
                        </span>
                    </span>
                </div>

                <div class="mt-5 flex flex-wrap gap-2">
                    @if (aktifOgrenciMi)
                    {
                        if (Model.KayitliMi)
                        {
                            <a asp-controller="OgrenciDers"
                               asp-action="Izle"
                               asp-route-kursId="@Model.KursId"
                               class="inline-flex min-h-11 items-center justify-center rounded-xl bg-blue-600 px-5 text-sm font-black text-white transition hover:bg-blue-700">
                                Derse Devam Et
                            </a>
                        }
                        else
                        {
                            <a asp-controller="OgrenciKurs"
                               asp-action="Detay"
                               asp-route-id="@Model.KursId"
                               class="inline-flex min-h-11 items-center justify-center rounded-xl bg-blue-600 px-5 text-sm font-black text-white transition hover:bg-blue-700">
                                Kayıt Ol
                            </a>
                        }
                    }
                    else
                    {
                        if (girisliMi && ogrenciRoluVarMi)
                        {
                            <a asp-controller="Account"
                               asp-action="PanelDegistir"
                               asp-route-rol="Öğrenci"
                               asp-route-returnUrl="@ogrenciReturnUrl"
                               data-ogrenci-gecis="true"
                               class="inline-flex min-h-11 items-center justify-center rounded-xl bg-blue-600 px-5 text-sm font-black text-white transition hover:bg-blue-700">
                                Öğrenmeye Başla
                            </a>
                        }
                        else if (girisliMi)
                        {
                            <a asp-controller="ProfilAyarlari"
                               asp-action="Index"
                               data-ogrenci-profili-yok="true"
                               class="inline-flex min-h-11 items-center justify-center rounded-xl bg-blue-600 px-5 text-sm font-black text-white transition hover:bg-blue-700">
                                Öğrenmeye Başla
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Account"
                               asp-action="OgrenciLogin"
                               asp-route-tab="register"
                               class="inline-flex min-h-11 items-center justify-center rounded-xl bg-blue-600 px-5 text-sm font-black text-white transition hover:bg-blue-700">
                                Öğrenmeye Başla
                            </a>
                        }
                    }

                    <a href="@kurslarReturnUrl"
                       class="inline-flex min-h-11 items-center justify-center rounded-xl border border-slate-200 bg-white px-5 text-sm font-black text-slate-700 transition hover:border-blue-200 hover:text-blue-700">
                        Kurslara Dön
                    </a>
                </div>
            </div>

            <aside class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
                @if (!string.IsNullOrWhiteSpace(Model.KapakGorselUrl))
                {
                    <img src="@Model.KapakGorselUrl"
                         alt="@Model.KursAdi"
                         class="aspect-[16/9] w-full object-cover" />
                }
                else
                {
                    <div class="flex aspect-[16/9] w-full items-center justify-center bg-blue-50 text-lg font-black text-blue-700">
                        CoursVia
                    </div>
                }
            </aside>

        </div>
    </section>

    <div class="mt-6 space-y-5">

        <!-- Kurs İçeriği -->
        <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
            <div class="border-b border-slate-100 px-5 py-4">
                <h2 class="text-lg font-black text-slate-900">
                    Kurs İçeriği
                </h2>

                <p class="mt-1 text-sm font-semibold text-slate-500">
                    Bölümler, dersler ve ek kaynak durumu.
                </p>
            </div>

            @if (Model.Bolumler.Any())
            {
                <div class="divide-y divide-slate-100">
                    @foreach (var bolum in Model.Bolumler)
                    {
                        <details class="group" open>
                            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 transition hover:bg-slate-50">
                                <div class="min-w-0">
                                    <h3 class="truncate text-sm font-black text-slate-900">
                                        @bolum.SiraNo. @bolum.BolumAdi
                                    </h3>

                                    <p class="mt-1 text-xs font-bold text-slate-400">
                                        @bolum.Dersler.Count ders
                                    </p>
                                </div>

                                <svg xmlns="http://www.w3.org/2000/svg"
                                     class="h-5 w-5 shrink-0 text-slate-400 transition group-open:rotate-180"
                                     fill="none"
                                     viewBox="0 0 24 24"
                                     stroke="currentColor">
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          stroke-width="2"
                                          d="M19 9l-7 7-7-7" />
                                </svg>
                            </summary>

                            @if (bolum.Dersler.Any())
                            {
                                <div class="border-t border-slate-100 bg-slate-50">
                                    @foreach (var ders in bolum.Dersler)
                                    {
                                        <div class="flex items-start justify-between gap-4 border-b border-slate-100 px-5 py-3 last:border-b-0">
                                            <div class="min-w-0 flex-1">
                                                <div class="flex items-start gap-3">
                                                    <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-white text-xs font-black text-blue-700 ring-1 ring-blue-100">
                                                        @ders.SiraNo
                                                    </span>

                                                    <div class="min-w-0">
                                                        <p class="truncate text-sm font-bold text-slate-800">
                                                            @ders.DersAdi
                                                        </p>

                                                        @if (!string.IsNullOrWhiteSpace(ders.Aciklama))
                                                        {
                                                            <p class="mt-1 line-clamp-1 text-xs leading-5 text-slate-500">
                                                                @ders.Aciklama
                                                            </p>
                                                        }
                                                    </div>
                                                </div>
                                            </div>

                                            @if (ders.MateryalSayisi > 0)
                                            {
                                                <span class="shrink-0 rounded-full border border-blue-100 bg-blue-50 px-2.5 py-1 text-xs font-bold text-blue-700">
                                                    Ek kaynak var
                                                </span>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </details>
                    }
                </div>
            }
            else
            {
                <div class="px-6 py-12 text-center">
                    <h3 class="text-base font-black text-slate-900">
                        İçerik bulunamadı
                    </h3>

                    <p class="mt-1 text-sm font-semibold text-slate-500">
                        Bu kurs için henüz bölüm veya ders listesi bulunmuyor.
                    </p>
                </div>
            }
        </section>

        <!-- Değerlendirmeler -->
        <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
            <div class="flex flex-col gap-3 border-b border-slate-100 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <h2 class="text-lg font-black text-slate-900">
                        Kurs Değerlendirmeleri
                    </h2>

                    <p class="mt-1 text-sm font-semibold text-slate-500">
                        Öğrencilerin bu kurs için yaptığı değerlendirmeler.
                    </p>
                </div>

                <div class="rounded-2xl border border-amber-100 bg-amber-50 px-4 py-3">
                    <div class="flex items-center gap-3">
                        @if (Model.DegerlendirmeSayisi > 0)
                        {
                            <span class="text-2xl font-black text-amber-600">
                                @Model.OrtalamaPuan.ToString("0.0")
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex rounded-full border border-amber-100 bg-white px-3 py-1 text-xs font-black text-amber-700">
                                Puan yok
                            </span>
                        }

                        <div>
                            <div class="rating rating-sm">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (ortalamaPuanYuvarlak == i)
                                    {
                                        <input type="radio"
                                               name="publicOrtalamaPuan"
                                               class="mask mask-star-2 bg-amber-400"
                                               checked
                                               disabled />
                                    }
                                    else
                                    {
                                        <input type="radio"
                                               name="publicOrtalamaPuan"
                                               class="mask mask-star-2 bg-amber-400"
                                               disabled />
                                    }
                                }
                            </div>

                            <p class="text-xs font-bold text-amber-700">
                                @Model.DegerlendirmeSayisi değerlendirme
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.Degerlendirmeler.Any())
            {
                <div class="divide-y divide-slate-100">
                    @foreach (var yorum in Model.Degerlendirmeler)
                    {
                        int yorumPuani = Math.Clamp(yorum.Puan, 1, 5);
                        string yorumRatingName = $"publicYorumPuan_{yorum.DegerlendirmeId}";

                        <article class="px-5 py-4">
                            <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                                <div class="min-w-0">
                                    <div class="flex flex-wrap items-center gap-2">
                                        <h3 class="text-sm font-black text-slate-900">
                                            @yorum.OgrenciAdSoyad
                                        </h3>

                                        <span class="text-xs font-semibold text-slate-400">
                                            @yorum.DegerlendirmeTarihi.ToString("dd.MM.yyyy")
                                        </span>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(yorum.YorumMetni))
                                    {
                                        <p class="mt-2 text-sm leading-6 text-slate-600">
                                            “@yorum.YorumMetni”
                                        </p>
                                    }
                                    else
                                    {
                                        <p class="mt-2 text-sm font-semibold text-slate-400">
                                            Yorum metni bulunmuyor.
                                        </p>
                                    }
                                </div>

                                <div class="shrink-0">
                                    <div class="rating rating-sm">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (yorumPuani == i)
                                            {
                                                <input type="radio"
                                                       name="@yorumRatingName"
                                                       class="mask mask-star-2 bg-amber-400"
                                                       checked
                                                       disabled />
                                            }
                                            else
                                            {
                                                <input type="radio"
                                                       name="@yorumRatingName"
                                                       class="mask mask-star-2 bg-amber-400"
                                                       disabled />
                                            }
                                        }
                                    </div>

                                    <p class="mt-1 text-right text-xs font-bold text-amber-700">
                                        @yorum.Puan / 5
                                    </p>
                                </div>
                            </div>
                        </article>
                    }
                </div>

                @if (Model.YorumToplamSayfa > 1)
                {
                    <div class="flex flex-col gap-3 border-t border-slate-100 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
                        <p class="text-sm font-semibold text-slate-500">
                            Yorum sayfası
                            <span class="font-black text-slate-900">@Model.YorumSayfa</span>
                            /
                            <span class="font-black text-slate-900">@Model.YorumToplamSayfa</span>
                        </p>

                        <div class="flex flex-wrap items-center gap-2">
                            @if (Model.YorumOncekiSayfaVar)
                            {
                                <a asp-controller="Home"
                                   asp-action="KursDetay"
                                   asp-route-id="@Model.KursId"
                                   asp-route-yorumSayfa="@(Model.YorumSayfa - 1)"
                                   asp-route-returnUrl="@kurslarReturnUrl"
                                   class="btn btn-outline btn-sm rounded-xl">
                                    Önceki
                                </a>
                            }

                            @for (int i = 1; i <= Model.YorumToplamSayfa; i++)
                            {
                                if (i == Model.YorumSayfa)
                                {
                                    <span class="btn btn-primary btn-sm rounded-xl">
                                        @i
                                    </span>
                                }
                                else
                                {
                                    <a asp-controller="Home"
                                       asp-action="KursDetay"
                                       asp-route-id="@Model.KursId"
                                       asp-route-yorumSayfa="@i"
                                       asp-route-returnUrl="@kurslarReturnUrl"
                                       class="btn btn-outline btn-sm rounded-xl">
                                        @i
                                    </a>
                                }
                            }

                            @if (Model.YorumSonrakiSayfaVar)
                            {
                                <a asp-controller="Home"
                                   asp-action="KursDetay"
                                   asp-route-id="@Model.KursId"
                                   asp-route-yorumSayfa="@(Model.YorumSayfa + 1)"
                                   asp-route-returnUrl="@kurslarReturnUrl"
                                   class="btn btn-outline btn-sm rounded-xl">
                                    Sonraki
                                </a>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="px-6 py-12 text-center">
                    <h3 class="text-base font-black text-slate-900">
                        Henüz değerlendirme yok
                    </h3>

                    <p class="mt-1 text-sm font-semibold text-slate-500">
                        Bu kurs için öğrenciler tarafından yapılmış bir değerlendirme bulunmuyor.
                    </p>
                </div>
            }
        </section>
    </div>

</main>
