@using CoursVia.ViewModels.Home
@model HomeIndexViewModel

@{
    ViewData["Title"] = "Ana Sayfa";

    const string varsayilanKapak = "/uploads/kurs-kapaklari/86f361ce-fa77-4e19-b072-fe28b7a8128e.jpg";

    const string heroGorsel =
"https://images.pexels.com/photos/7777668/pexels-photo-7777668.jpeg?auto=compress&cs=tinysrgb&w=1920&h=1080&fit=crop";

    string KapakUrl(HomeKursKartiViewModel kurs)
    {
        return !string.IsNullOrWhiteSpace(kurs.KapakGorselUrl)
            ? kurs.KapakGorselUrl
            : varsayilanKapak;
    }

    string PuanYaz(double puan, int degerlendirmeSayisi)
    {
        return degerlendirmeSayisi > 0
            ? puan.ToString("0.0")
            : "Puan yok";
    }

    bool YeniKursMu(HomeKursKartiViewModel kurs)
    {
        return kurs.OlusturmaTarihi >= DateTime.Now.AddDays(-14);
    }

    string aktifRol = User.FindFirst("AktifRol")?.Value ?? "";
    bool girisliMi = User.Identity?.IsAuthenticated == true;
    bool aktifOgrenciMi = aktifRol == "Öğrenci";
    bool ogrenciRoluVarMi = User.IsInRole("Öğrenci");
    string ogrenciKesfetUrl = Url.Action("Kesfet", "OgrenciKurs") ?? "/OgrenciKurs/Kesfet";

    string OgrenciKursDetayUrl(int kursId)
    {
        return Url.Action("Detay", "OgrenciKurs", new { id = kursId }) ?? $"/OgrenciKurs/Detay/{kursId}";
    }

    string OgrenciPanelGecisUrl(int kursId)
    {
        return Url.Action("PanelDegistir", "Account", new
        {
            rol = "Öğrenci",
            returnUrl = OgrenciKursDetayUrl(kursId)
        }) ?? "/Account/PanelDegistir?rol=%C3%96%C4%9Frenci";
    }
}

<div class="bg-slate-50">

    <!-- Hero -->
    <section class="relative overflow-hidden bg-slate-950 bg-cover bg-center"
             style="background-image: linear-gradient(90deg, rgba(15,23,42,.95), rgba(15,23,42,.78), rgba(15,23,42,.32)), url('@heroGorsel');">

        <div class="mx-auto flex min-h-[430px] max-w-[1500px] flex-col justify-center px-5 py-12 sm:px-7 lg:min-h-[460px] lg:px-8">

            <div class="max-w-3xl">

                <h1 class="text-4xl font-black leading-[1.02] text-white sm:text-5xl lg:text-6xl">
                    CoursVia
                </h1>

                <p class="mt-4 max-w-2xl text-xl font-black leading-8 text-slate-100 sm:text-2xl">
                    Öğren, ilerle ve hedeflerine ulaş.
                </p>

                <div class="mt-6 flex flex-col gap-3 sm:flex-row">
                    @if (aktifOgrenciMi)
                    {
                        <a asp-controller="OgrenciKurs"
                           asp-action="Kesfet"
                           class="inline-flex min-h-11 items-center justify-center rounded-xl bg-blue-600 px-5 text-sm font-black text-white shadow-lg shadow-blue-950/25 transition hover:bg-blue-700">
                            Öğrenmeye Başla
                        </a>
                    }
                    else if (girisliMi && ogrenciRoluVarMi)
                    {
                        <a asp-controller="Account"
                           asp-action="PanelDegistir"
                           asp-route-rol="Öğrenci"
                           asp-route-returnUrl="@ogrenciKesfetUrl"
                           data-ogrenci-gecis="true"
                           class="inline-flex min-h-11 items-center justify-center rounded-xl bg-blue-600 px-5 text-sm font-black text-white shadow-lg shadow-blue-950/25 transition hover:bg-blue-700">
                            Öğrenmeye Başla
                        </a>
                    }
                    else if (girisliMi)
                    {
                        <a asp-controller="ProfilAyarlari"
                           asp-action="Index"
                           data-ogrenci-profili-yok="true"
                           class="inline-flex min-h-11 items-center justify-center rounded-xl bg-blue-600 px-5 text-sm font-black text-white shadow-lg shadow-blue-950/25 transition hover:bg-blue-700">
                            Öğrenmeye Başla
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Account"
                           asp-action="OgrenciLogin"
                           asp-route-tab="register"
                           class="inline-flex min-h-11 items-center justify-center rounded-xl bg-blue-600 px-5 text-sm font-black text-white shadow-lg shadow-blue-950/25 transition hover:bg-blue-700">
                            Öğrenmeye Başla
                        </a>
                    }

                    <a asp-controller="Account"
                       asp-action="EgitmenRegister"
                       class="inline-flex min-h-11 items-center justify-center rounded-xl border border-white/30 bg-white/10 px-5 text-sm font-black text-white backdrop-blur transition hover:bg-white/20">
                        Eğitmen Ol
                    </a>
                </div>

            </div>

        </div>

    </section>

    <!-- Öne Çıkan Kurslar -->
    <section class="mx-auto max-w-[1500px] px-5 py-10 sm:px-7 lg:px-8">

        <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <p class="text-sm font-black uppercase text-blue-600">
                    Vitrin
                </p>

                <h2 class="mt-1 text-2xl font-black text-slate-950 sm:text-3xl">
                    Öne çıkan kurslar
                </h2>
            </div>

            <a asp-controller="Home"
               asp-action="Kurslar"
               class="inline-flex min-h-10 items-center justify-center rounded-xl border border-slate-200 bg-white px-4 text-sm font-black text-slate-700 shadow-sm transition hover:border-blue-200 hover:text-blue-700">
                Tüm Kurslar
            </a>
        </div>

        @if (Model.OneCikanKurslar.Any())
        {
            <div class="relative mt-5">

                <button type="button"
                        class="btn-vitrin-prev invisible absolute left-0 top-1/2 z-10 hidden h-11 w-11 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-700 shadow-lg transition hover:border-blue-200 hover:text-blue-700 lg:inline-flex"
                        aria-label="Önceki kurslar">
                    <svg xmlns="http://www.w3.org/2000/svg"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="2"
                         stroke-linecap="round"
                         stroke-linejoin="round"
                         class="h-5 w-5">
                        <path d="m15 18-6-6 6-6" />
                    </svg>
                </button>

                <div id="vitrinKursSlider"
                     class="flex gap-3 overflow-x-auto scroll-smooth pb-2 [-ms-overflow-style:none] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">

                    @foreach (var kurs in Model.OneCikanKurslar)
                    {
                        string kursKartiHref = Url.Action("KursDetay", "Home", new { id = kurs.KursId }) ?? $"/Home/KursDetay/{kurs.KursId}";
                        bool kursKartiOgrenciGecis = false;
                        bool kursKartiOgrenciProfiliYok = false;

                        if (aktifOgrenciMi)
                        {
                            kursKartiHref = OgrenciKursDetayUrl(kurs.KursId);
                        }
                        else if (girisliMi && ogrenciRoluVarMi)
                        {
                            kursKartiHref = OgrenciPanelGecisUrl(kurs.KursId);
                            kursKartiOgrenciGecis = true;
                        }
                        else if (girisliMi)
                        {
                            kursKartiHref = Url.Action("Index", "ProfilAyarlari") ?? "/ProfilAyarlari";
                            kursKartiOgrenciProfiliYok = true;
                        }
                        else
                        {
                            kursKartiHref = Url.Action("OgrenciLogin", "Account", new { tab = "register" }) ?? "/Account/OgrenciLogin?tab=register";
                        }

                        <article class="group w-[220px] flex-none overflow-hidden rounded-lg border border-slate-200 bg-white transition hover:border-slate-300 hover:shadow-md sm:w-[238px] lg:w-[250px]">

                            <a href="@kursKartiHref"
                               data-ogrenci-gecis="@(kursKartiOgrenciGecis ? "true" : null)"
                               data-ogrenci-profili-yok="@(kursKartiOgrenciProfiliYok ? "true" : null)"
                               class="block">

                                <div class="aspect-[16/9] overflow-hidden bg-slate-200">
                                    <img src="@KapakUrl(kurs)"
                                         alt="@kurs.KursAdi"
                                         loading="lazy"
                                         class="h-full w-full object-cover transition duration-300 group-hover:scale-105" />
                                </div>

                                <div class="p-2.5">
                                    <h3 class="line-clamp-2 text-sm font-black leading-5 text-slate-950">
                                        @kurs.KursAdi
                                    </h3>

                                    <p class="mt-1 truncate text-xs font-semibold text-slate-500">
                                        @kurs.EgitmenAdSoyad
                                    </p>

                                    @if (YeniKursMu(kurs))
                                    {
                                        <span class="mt-2 inline-flex rounded bg-slate-100 px-2 py-0.5 text-xs font-black text-slate-500">
                                            Yeni
                                        </span>
                                    }

                                    <div class="mt-2 flex flex-wrap items-center gap-2 text-xs font-black">
                                        <span class="inline-flex items-center gap-1">
                                            <span class="text-amber-500">
                                                ★
                                            </span>

                                            <span class="text-amber-700">
                                                @PuanYaz(kurs.OrtalamaPuan, kurs.DegerlendirmeSayisi)
                                            </span>

                                            <span class="text-slate-400" title="Değerlendirme sayısı">
                                                (@kurs.DegerlendirmeSayisi)
                                            </span>
                                        </span>

                                        <span class="inline-flex items-center gap-1 text-slate-500" title="Öğrenci sayısı">
                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                 viewBox="0 0 24 24"
                                                 fill="none"
                                                 stroke="currentColor"
                                                 stroke-width="2"
                                                 stroke-linecap="round"
                                                 stroke-linejoin="round"
                                                 class="h-3.5 w-3.5 text-slate-400">
                                                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                                                <circle cx="9" cy="7" r="4" />
                                                <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
                                                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                                            </svg>

                                            @kurs.OgrenciSayisi
                                        </span>
                                    </div>

                                    @if (kurs.Kategoriler.Any())
                                    {
                                        <span class="mt-2 inline-flex max-w-full truncate rounded bg-blue-50 px-2 py-0.5 text-xs font-black text-blue-700">
                                            @kurs.Kategoriler.First()
                                        </span>
                                    }
                                </div>

                            </a>

                        </article>
                    }

                </div>

                <button type="button"
                        class="btn-vitrin-next absolute right-0 top-1/2 z-10 hidden h-11 w-11 translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-700 shadow-lg transition hover:border-blue-200 hover:text-blue-700 lg:inline-flex"
                        aria-label="Sonraki kurslar">
                    <svg xmlns="http://www.w3.org/2000/svg"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="2"
                         stroke-linecap="round"
                         stroke-linejoin="round"
                         class="h-5 w-5">
                        <path d="m9 18 6-6-6-6" />
                    </svg>
                </button>

            </div>
        }
        else
        {
            <div class="mt-8 rounded-2xl border border-dashed border-slate-300 bg-white px-6 py-12 text-center">
                <h3 class="text-xl font-black text-slate-900">
                    Yayına alınmış kurs bekleniyor
                </h3>

                <p class="mx-auto mt-2 max-w-xl text-sm font-semibold leading-6 text-slate-500">
                    Onaylanan kurslar burada otomatik olarak listelenecek.
                </p>
            </div>
        }

    </section>

    <!-- Akış -->
    <section class="bg-white">
        <div class="mx-auto max-w-[1500px] px-5 py-10 sm:px-7 lg:px-8">

            <div class="grid grid-cols-1 gap-4 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-center">

                <div>
                    <p class="text-sm font-black uppercase text-emerald-700">
                        Öğrenme akışı
                    </p>

                    <h2 class="mt-1 text-2xl font-black text-slate-950 sm:text-3xl">
                        Kısa, net ve takip edilebilir.
                    </h2>

                    <p class="mt-3 text-sm font-medium leading-6 text-slate-500">
                        CoursVia; kurs keşfinden ders takibine, sınavdan sertifikaya kadar süreci tek ekranda anlaşılır
                        tutar.
                    </p>
                </div>

                <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
                    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-blue-600 text-sm font-black text-white">
                            1
                        </div>

                        <h3 class="mt-3 text-base font-black text-slate-900">
                            Keşfet
                        </h3>

                        <p class="mt-2 text-sm font-medium leading-6 text-slate-500">
                            İhtiyacına göre doğru kursu bul.
                        </p>
                    </div>

                    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-emerald-600 text-sm font-black text-white">
                            2
                        </div>

                        <h3 class="mt-3 text-base font-black text-slate-900">
                            Öğren
                        </h3>

                        <p class="mt-2 text-sm font-medium leading-6 text-slate-500">
                            Dersleri izle, materyallere tek yerden ulaş.
                        </p>
                    </div>

                    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                        <div class="flex h-9 w-9 items-center justify-center rounded-xl bg-amber-500 text-sm font-black text-white">
                            3
                        </div>

                        <h3 class="mt-3 text-base font-black text-slate-900">
                            Tamamla
                        </h3>

                        <p class="mt-2 text-sm font-medium leading-6 text-slate-500">
                            Sınavı geç, sertifikanı al ve başarını belgele.
                        </p>
                    </div>
                </div>

            </div>

        </div>
    </section>

</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const slider = document.getElementById('vitrinKursSlider');
            const prevButton = document.querySelector('.btn-vitrin-prev');
            const nextButton = document.querySelector('.btn-vitrin-next');

            if (!slider || !prevButton || !nextButton) {
                return;
            }

            function scrollAmount() {
                return Math.max(slider.clientWidth * 0.85, 280);
            }

            function updateButtons() {
                const maxScroll = Math.max(slider.scrollWidth - slider.clientWidth, 0);
                const noScroll = maxScroll <= 2;
                const atStart = slider.scrollLeft <= 2;
                const atEnd = slider.scrollLeft >= maxScroll - 2;

                prevButton.disabled = atStart || noScroll;
                nextButton.disabled = atEnd || noScroll;

                prevButton.classList.toggle('invisible', atStart || noScroll);
                prevButton.classList.toggle('pointer-events-none', atStart || noScroll);

                nextButton.classList.toggle('invisible', atEnd || noScroll);
                nextButton.classList.toggle('pointer-events-none', atEnd || noScroll);
            }

            prevButton.addEventListener('click', function () {
                slider.scrollBy({
                    left: -scrollAmount(),
                    behavior: 'smooth'
                });
            });

            nextButton.addEventListener('click', function () {
                slider.scrollBy({
                    left: scrollAmount(),
                    behavior: 'smooth'
                });
            });

            slider.addEventListener('scroll', updateButtons, { passive: true });
            window.addEventListener('resize', updateButtons);

            updateButtons();
        });
    </script>
}
