@model CoursVia.ViewModels.Admin.KursOnaylariViewModel

@{
    ViewData["Title"] = "Kurs Onayları";

    int bulunanKursSayisi = Model.ToplamKayit > 0
        ? Model.ToplamKayit
        : Model.Kurslar.Count;

    string DurumBadgeClass(int durumId)
    {
        return durumId switch
        {
            4 => "border-amber-100 bg-amber-50 text-amber-700",
            5 => "border-emerald-100 bg-emerald-50 text-emerald-700",
            6 => "border-red-100 bg-red-50 text-red-700",
            _ => "border-slate-200 bg-slate-50 text-slate-600"
        };
    }

    string FiltreKartClass(string durum)
    {
        return Model.Durum == durum
            ? "border-blue-200 bg-blue-50 text-blue-700"
            : "border-slate-200 bg-white text-slate-700 hover:border-blue-100 hover:bg-blue-50 hover:text-blue-700";
    }

    string KisaAciklama(string? aciklama)
    {
        return string.IsNullOrWhiteSpace(aciklama)
            ? "Açıklama bulunmuyor."
            : aciklama;
    }
}

<div class="min-h-[calc(100vh-130px)] bg-slate-50">

    <div class="grid min-h-[calc(100vh-130px)] grid-cols-1 lg:grid-cols-[300px_minmax(0,1fr)]">

        <partial name="_AdminSidebar" />

        <main class="min-w-0 px-5 py-7 sm:px-7 lg:px-10">

            <div class="mx-auto max-w-7xl space-y-6">

                @if (TempData["AdminHata"] != null)
                {
                    <div class="flash-message alert alert-error rounded-2xl shadow-sm transition-all duration-500">
                        <span>@TempData["AdminHata"]</span>
                    </div>
                }

                @if (TempData["AdminBasari"] != null)
                {
                    <div class="flash-message alert rounded-2xl border border-emerald-100 bg-emerald-50 text-emerald-700 shadow-sm transition-all duration-500">
                        <span>@TempData["AdminBasari"]</span>
                    </div>
                }

                <!-- Üst Başlık -->
                <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
                    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">

                        <div>
                            <p class="text-sm font-semibold text-blue-600">
                                Admin Paneli
                            </p>

                            <h1 class="mt-2 text-3xl font-black tracking-tight text-slate-900">
                                Kurs Onayları
                            </h1>

                            <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-500">
                                Yayına gönderilen kursları inceleyin, uygun olanları onaylayın veya gerekçeli olarak reddedin.
                            </p>
                        </div>

                    </div>
                </section>

                <!-- Durum Kartları -->
                <section class="grid grid-cols-1 gap-4 md:grid-cols-3">

                    <a asp-controller="AdminKursOnay"
                       asp-action="Basvurular"
                       asp-route-durum="bekleyen"
                       class="group rounded-2xl border p-5 shadow-sm transition @FiltreKartClass("bekleyen")">

                        <div class="flex items-center justify-between gap-4">

                            <div>
                                <p class="text-xs font-black uppercase tracking-wide text-slate-400">
                                    Onay Bekleyen
                                </p>

                                <p class="mt-2 text-3xl font-black">
                                    @Model.BekleyenSayisi
                                </p>
                            </div>

                            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-amber-50 text-amber-700 transition group-hover:bg-amber-100">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     fill="none"
                                     viewBox="0 0 24 24"
                                     stroke-width="2"
                                     stroke="currentColor"
                                     class="h-5 w-5">
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25A8.967 8.967 0 0 1 18 3.75c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                                </svg>
                            </div>

                        </div>

                    </a>

                    <a asp-controller="AdminKursOnay"
                       asp-action="Basvurular"
                       asp-route-durum="onaylanan"
                       class="group rounded-2xl border p-5 shadow-sm transition @FiltreKartClass("onaylanan")">

                        <div class="flex items-center justify-between gap-4">

                            <div>
                                <p class="text-xs font-black uppercase tracking-wide text-slate-400">
                                    Onaylanan
                                </p>

                                <p class="mt-2 text-3xl font-black">
                                    @Model.OnaylananSayisi
                                </p>
                            </div>

                            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-700 transition group-hover:bg-emerald-100">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     fill="none"
                                     viewBox="0 0 24 24"
                                     stroke-width="2"
                                     stroke="currentColor"
                                     class="h-5 w-5">
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          d="M4.5 12.75 10.5 18.75 19.5 5.25" />
                                </svg>
                            </div>

                        </div>

                    </a>

                    <a asp-controller="AdminKursOnay"
                       asp-action="Basvurular"
                       asp-route-durum="reddedilen"
                       class="group rounded-2xl border p-5 shadow-sm transition @FiltreKartClass("reddedilen")">

                        <div class="flex items-center justify-between gap-4">

                            <div>
                                <p class="text-xs font-black uppercase tracking-wide text-slate-400">
                                    Reddedilen
                                </p>

                                <p class="mt-2 text-3xl font-black">
                                    @Model.ReddedilenSayisi
                                </p>
                            </div>

                            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-red-50 text-red-700 transition group-hover:bg-red-100">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     fill="none"
                                     viewBox="0 0 24 24"
                                     stroke-width="2"
                                     stroke="currentColor"
                                     class="h-5 w-5">
                                    <path stroke-linecap="round"
                                          stroke-linejoin="round"
                                          d="M6 18 18 6M6 6l12 12" />
                                </svg>
                            </div>

                        </div>

                    </a>

                </section>

                <!-- Filtre -->
                <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">

                    <form asp-controller="AdminKursOnay"
                          asp-action="Basvurular"
                          method="get"
                          class="grid grid-cols-1 gap-3 lg:grid-cols-[minmax(0,1fr)_240px_auto]">

                        <input type="hidden" name="sayfa" value="1" />

                        <input type="text"
                               name="arama"
                               value="@Model.Arama"
                               placeholder="Kurs adı, açıklama, eğitmen veya e-posta ara"
                               class="input input-bordered w-full rounded-xl border-slate-300 bg-white" />

                        <select name="durum"
                                class="select select-bordered w-full rounded-xl border-slate-300 bg-white">

                            @if (Model.Durum == "bekleyen")
                            {
                                <option value="bekleyen" selected>Onay Bekleyen</option>
                            }
                            else
                            {
                                <option value="bekleyen">Onay Bekleyen</option>
                            }

                            @if (Model.Durum == "onaylanan")
                            {
                                <option value="onaylanan" selected>Onaylanan</option>
                            }
                            else
                            {
                                <option value="onaylanan">Onaylanan</option>
                            }

                            @if (Model.Durum == "reddedilen")
                            {
                                <option value="reddedilen" selected>Reddedilen</option>
                            }
                            else
                            {
                                <option value="reddedilen">Reddedilen</option>
                            }

                            @if (Model.Durum == "tum")
                            {
                                <option value="tum" selected>Tüm Kurslar</option>
                            }
                            else
                            {
                                <option value="tum">Tüm Kurslar</option>
                            }

                        </select>

                        <div class="flex gap-2 lg:justify-end">
                            <button type="submit"
                                    class="btn btn-primary rounded-xl px-6">
                                Filtrele
                            </button>

                            @if (!string.IsNullOrWhiteSpace(Model.Arama) || Model.Durum != "bekleyen")
                            {
                                <a asp-controller="AdminKursOnay"
                                   asp-action="Basvurular"
                                   class="btn btn-outline rounded-xl">
                                    Temizle
                                </a>
                            }
                        </div>

                    </form>

                </section>

                <!-- Liste -->
                <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">

                    <div class="flex flex-col gap-1 border-b border-slate-100 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">

                        <div>
                            <h2 class="text-base font-black text-slate-900">
                                Kurs Listesi
                            </h2>

                            <p class="mt-1 text-sm text-slate-500">
                                @bulunanKursSayisi kurs bulundu
                            </p>
                        </div>

                    </div>

                    @if (Model.Kurslar.Any())
                    {
                        <div class="divide-y divide-slate-100">

                            @foreach (var kurs in Model.Kurslar)
                            {
                                <article class="p-5 transition hover:bg-slate-50">

                                    <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">

                                        <div class="flex min-w-0 flex-1 gap-4">

                                            <div class="shrink-0">
                                                @if (!string.IsNullOrWhiteSpace(kurs.KapakGorselUrl))
                                                {
                                                    <img src="@kurs.KapakGorselUrl"
                                                         alt="@kurs.KursAdi"
                                                         class="h-20 w-28 rounded-2xl object-cover" />
                                                }
                                                else
                                                {
                                                    <div class="flex h-20 w-28 items-center justify-center rounded-2xl bg-slate-100 text-xs font-black text-slate-500">
                                                        Görsel Yok
                                                    </div>
                                                }
                                            </div>

                                            <div class="min-w-0 flex-1">

                                                <div class="flex flex-wrap items-center gap-2">

                                                    <h3 class="text-base font-black text-slate-900">
                                                        @kurs.KursAdi
                                                    </h3>

                                                    <span class="rounded-full border px-2.5 py-0.5 text-xs font-bold @DurumBadgeClass(kurs.DurumId)">
                                                        @kurs.DurumAdi
                                                    </span>

                                                </div>

                                                <p class="mt-1 text-sm font-semibold text-slate-500">
                                                    @kurs.EgitmenAdSoyad · @kurs.EgitmenEposta
                                                </p>

                                                <p class="mt-2 line-clamp-2 text-sm leading-6 text-slate-500">
                                                    @KisaAciklama(kurs.Aciklama)
                                                </p>

                                                @if (kurs.Kategoriler.Any())
                                                {
                                                    <div class="mt-3 flex flex-wrap gap-1.5">
                                                        @foreach (var kategori in kurs.Kategoriler.Take(4))
                                                        {
                                                            <span class="rounded-full bg-blue-50 px-2.5 py-1 text-xs font-bold text-blue-700">
                                                                @kategori
                                                            </span>
                                                        }

                                                        @if (kurs.Kategoriler.Count > 4)
                                                        {
                                                            <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-bold text-slate-500">
                                                                +@(kurs.Kategoriler.Count - 4)
                                                            </span>
                                                        }
                                                    </div>
                                                }

                                            </div>

                                        </div>

                                        <div class="grid grid-cols-2 gap-2 text-center xl:w-[220px]">

                                            <div class="rounded-2xl border border-slate-200 bg-white p-3">
                                                <p class="text-lg font-black text-slate-900">
                                                    @kurs.BolumSayisi
                                                </p>
                                                <p class="text-[11px] font-bold uppercase tracking-wide text-slate-400">
                                                    Bölüm
                                                </p>
                                            </div>

                                            <div class="rounded-2xl border border-slate-200 bg-white p-3">
                                                <p class="text-lg font-black text-slate-900">
                                                    @kurs.DersSayisi
                                                </p>
                                                <p class="text-[11px] font-bold uppercase tracking-wide text-slate-400">
                                                    Ders
                                                </p>
                                            </div>

                                        </div>

                                        <div class="flex shrink-0 sm:w-36">
                                            <a asp-controller="AdminKursOnay"
                                               asp-action="Detay"
                                               asp-route-id="@kurs.KursId"
                                               class="btn btn-primary btn-sm w-full rounded-xl">
                                                İncele
                                            </a>
                                        </div>

                                    </div>

                                </article>
                            }

                        </div>

                        @if (Model.ToplamSayfa > 1)
                        {
                            <div class="flex flex-col gap-3 border-t border-slate-100 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">

                                <p class="text-sm text-slate-500">
                                    Sayfa
                                    <span class="font-bold text-slate-900">@Model.Sayfa</span>
                                    /
                                    <span class="font-bold text-slate-900">@Model.ToplamSayfa</span>
                                </p>

                                <div class="flex flex-wrap items-center gap-2">

                                    @if (Model.OncekiSayfaVar)
                                    {
                                        <a asp-controller="AdminKursOnay"
                                           asp-action="Basvurular"
                                           asp-route-arama="@Model.Arama"
                                           asp-route-durum="@Model.Durum"
                                           asp-route-sayfa="@(Model.Sayfa - 1)"
                                           class="btn btn-outline btn-sm rounded-xl">
                                            Önceki
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-outline btn-sm rounded-xl opacity-50"
                                                disabled>
                                            Önceki
                                        </button>
                                    }

                                    @for (int i = 1; i <= Model.ToplamSayfa; i++)
                                    {
                                        if (i == Model.Sayfa)
                                        {
                                            <span class="btn btn-primary btn-sm rounded-xl">
                                                @i
                                            </span>
                                        }
                                        else
                                        {
                                            <a asp-controller="AdminKursOnay"
                                               asp-action="Basvurular"
                                               asp-route-arama="@Model.Arama"
                                               asp-route-durum="@Model.Durum"
                                               asp-route-sayfa="@i"
                                               class="btn btn-outline btn-sm rounded-xl">
                                                @i
                                            </a>
                                        }
                                    }

                                    @if (Model.SonrakiSayfaVar)
                                    {
                                        <a asp-controller="AdminKursOnay"
                                           asp-action="Basvurular"
                                           asp-route-arama="@Model.Arama"
                                           asp-route-durum="@Model.Durum"
                                           asp-route-sayfa="@(Model.Sayfa + 1)"
                                           class="btn btn-outline btn-sm rounded-xl">
                                            Sonraki
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-outline btn-sm rounded-xl opacity-50"
                                                disabled>
                                            Sonraki
                                        </button>
                                    }

                                </div>

                            </div>
                        }
                    }
                    else
                    {
                        <div class="px-6 py-14 text-center">

                            <h3 class="text-base font-black text-slate-900">
                                Kurs bulunamadı
                            </h3>

                            <p class="mt-1 text-sm text-slate-500">
                                Arama veya filtreye uygun kurs bulunmuyor.
                            </p>

                            @if (!string.IsNullOrWhiteSpace(Model.Arama) || Model.Durum != "bekleyen")
                            {
                                <div class="mt-5 flex justify-center">
                                    <a asp-controller="AdminKursOnay"
                                       asp-action="Basvurular"
                                       class="btn btn-outline rounded-xl px-6">
                                        Filtreleri Temizle
                                    </a>
                                </div>
                            }

                        </div>
                    }

                </section>

            </div>

        </main>

    </div>

</div>
