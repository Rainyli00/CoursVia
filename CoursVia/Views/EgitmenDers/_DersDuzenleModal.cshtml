@model CoursVia.Models.Kurs

<dialog id="dersDuzenleModal" class="modal">

    <div class="modal-box max-h-[90vh] w-full max-w-5xl overflow-y-auto rounded-3xl bg-white p-0 shadow-2xl">

        <div class="sticky top-0 z-10 border-b border-slate-200 bg-white/95 px-6 py-5 backdrop-blur">
            <form method="dialog">
                <button class="btn btn-sm btn-circle btn-ghost absolute right-4 top-4 text-slate-500">
                    ×
                </button>
            </form>

            <p class="text-xs font-black uppercase tracking-wide text-blue-600">
                Ders Yönetimi
            </p>

            <h3 class="mt-1 text-2xl font-black text-slate-950">
                Ders Düzenle
            </h3>
        </div>

        <form asp-controller="EgitmenDers"
              asp-action="DersDuzenle"
              method="post"
              enctype="multipart/form-data"
              class="p-6">

            @Html.AntiForgeryToken()

            <input type="hidden" name="DersId" id="duzenleDersId" />
            <input type="hidden" name="KursId" id="duzenleKursId" value="@Model.KursId" />
            <input type="hidden" name="BolumId" id="duzenleBolumId" />
            <input type="hidden" name="MevcutVideoUrl" id="duzenleMevcutVideoUrl" />

            <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_360px]">

                <div class="space-y-5">
                    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                        <h4 class="mb-4 text-sm font-black uppercase tracking-wide text-slate-500">
                            Temel Bilgiler
                        </h4>

                        <div class="form-control">
                            <label class="label">
                                <span class="label-text font-bold text-slate-700">Ders Adı</span>
                            </label>

                            <input type="text"
                                   name="DersAdi"
                                   id="duzenleDersAdi"
                                   maxlength="200"
                                   class="input input-bordered rounded-xl border-slate-300 bg-white"
                                   required />
                        </div>

                        <div class="form-control mt-4">
                            <label class="label">
                                <span class="label-text font-bold text-slate-700">Açıklama</span>
                            </label>

                            <textarea name="Aciklama"
                                      id="duzenleAciklama"
                                      rows="5"
                                      class="textarea textarea-bordered rounded-xl border-slate-300 bg-white"></textarea>
                        </div>
                    </section>

                    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                        <h4 class="mb-4 text-sm font-black uppercase tracking-wide text-slate-500">
                            Video
                        </h4>

                        <div class="mb-4 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
                            <p class="text-xs font-bold uppercase tracking-wide text-slate-400">Mevcut video</p>
                            <p id="duzenleMevcutVideoText" class="mt-1 break-all text-sm font-semibold text-slate-700"></p>
                        </div>

                        <div class="grid gap-2 sm:grid-cols-3">
                            <label class="flex cursor-pointer items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-700 transition hover:border-blue-200">
                                <input type="radio"
                                       name="VideoTipi"
                                       value="mevcut"
                                       class="radio radio-primary radio-sm"
                                       checked
                                       onchange="toggleDersDuzenleVideoInput('mevcut')" />
                                Mevcut
                            </label>

                            <label class="flex cursor-pointer items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-700 transition hover:border-blue-200">
                                <input type="radio"
                                       name="VideoTipi"
                                       value="link"
                                       class="radio radio-primary radio-sm"
                                       onchange="toggleDersDuzenleVideoInput('link')" />
                                Link
                            </label>

                            <label class="flex cursor-pointer items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-700 transition hover:border-blue-200">
                                <input type="radio"
                                       name="VideoTipi"
                                       value="dosya"
                                       class="radio radio-primary radio-sm"
                                       onchange="toggleDersDuzenleVideoInput('dosya')" />
                                Dosya
                            </label>
                        </div>

                        <div id="duzenleVideoLinkContainer" class="mt-4 hidden">
                            <input type="url"
                                   name="VideoUrl"
                                   id="duzenleVideoUrl"
                                   class="input input-bordered w-full rounded-xl border-slate-300 bg-white"
                                   placeholder="https://..." />
                        </div>

                        <div id="duzenleVideoDosyaContainer" class="mt-4 hidden">
                            <input type="file"
                                   name="VideoDosyasi"
                                   id="duzenleVideoDosyasi"
                                   accept="video/mp4,video/webm"
                                   class="file-input file-input-bordered w-full rounded-xl border-slate-300 bg-white" />
                        </div>
                    </section>
                </div>

                <aside class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                    <div class="mb-4 flex items-center justify-between gap-3">
                        <div>
                            <h4 class="text-sm font-black uppercase tracking-wide text-slate-500">
                                Materyaller
                            </h4>
                        </div>

                        <button type="button"
                                id="duzenleMateryalEkleBtn"
                                class="btn btn-sm btn-outline btn-info rounded-xl">
                            Ekle
                        </button>
                    </div>

                    <div id="duzenleMevcutMateryalListesi" class="space-y-2"></div>
                    <div id="duzenleYeniMateryalListesi" class="mt-3 space-y-2"></div>
                </aside>
            </div>

            <div class="mt-6 flex flex-col-reverse gap-3 border-t border-slate-100 pt-5 sm:flex-row sm:items-center sm:justify-end">
                <button type="button"
                        class="btn btn-ghost rounded-xl text-slate-500"
                        onclick="dersDuzenleModal.close()">
                    İptal
                </button>

                <button type="submit"
                        class="btn btn-primary rounded-xl px-8 shadow-sm">
                    Güncelle
                </button>
            </div>

        </form>

    </div>

    <form method="dialog" class="modal-backdrop">
        <button>close</button>
    </form>

</dialog>
