@model CoursVia.ViewModels.Admin.KullaniciDuzenleViewModel

@{
    ViewData["Title"] = "Kullanıcı Düzenle";

    string RolBadgeClass(string rolAdi)
    {
        return rolAdi switch
        {
            "Admin" => "bg-slate-900 text-white",
            "Eğitmen" => "bg-blue-50 text-blue-700",
            "Öğrenci" => "bg-emerald-50 text-emerald-700",
            _ => "bg-slate-100 text-slate-600"
        };
    }

    string adSoyad = $"{Model.Ad} {Model.Soyad}".Trim();

    var seciliBranslar = Model.BransSecenekleri
        .Where(x => x.SeciliMi)
        .OrderBy(x => x.KategoriAdi)
        .ToList();
}

<div class="min-h-[calc(100vh-130px)] bg-slate-50">

    <div class="grid min-h-[calc(100vh-130px)] grid-cols-1 lg:grid-cols-[300px_minmax(0,1fr)]">

        <partial name="_AdminSidebar" />

        <main class="min-w-0 px-5 py-7 sm:px-7 lg:px-10">

            <div class="mx-auto max-w-7xl space-y-5">

                @if (TempData["AdminHata"] != null)
                {
                    <div class="flash-message alert alert-error rounded-2xl shadow-sm transition-all duration-500">
                        <span>@TempData["AdminHata"]</span>
                    </div>
                }

                @if (TempData["AdminBasari"] != null)
                {
                    <div class="flash-message alert rounded-2xl border border-emerald-100 bg-emerald-50 text-emerald-700 shadow-sm transition-all duration-500">
                        <span>@TempData["AdminBasari"]</span>
                    </div>
                }

                <!-- Başlık -->
                <section class="rounded-2xl border border-slate-200 bg-white px-5 py-4 shadow-sm">

                    <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">

                        <div>
                            <h1 class="text-2xl font-black tracking-tight text-slate-900">
                                Kullanıcı Düzenle
                            </h1>

                            <p class="mt-1 text-sm text-slate-500">
                                @adSoyad kullanıcısının temel bilgilerini düzenleyin.
                            </p>
                        </div>

                        <div class="flex flex-wrap gap-1.5">

                            @foreach (var rol in Model.Roller)
                            {
                                <span class="rounded-full px-2.5 py-1 text-xs font-bold @RolBadgeClass(rol)">
                                    @rol
                                </span>
                            }

                        </div>

                    </div>

                </section>

                <form asp-controller="AdminKullanici"
                      asp-action="Duzenle"
                      method="post">

                    @Html.AntiForgeryToken()

                    <input type="hidden" asp-for="KullaniciId" />
                    <input type="hidden" asp-for="EgitmenMi" />
                    <input type="hidden" asp-for="EgitmenProfilId" />

                    <div class="grid grid-cols-1 gap-5 xl:grid-cols-[minmax(0,1fr)_320px]">

                        <!-- Sol Form -->
                        <div class="space-y-5">

                            <!-- Temel Bilgiler -->
                            <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">

                                <div class="border-b border-slate-100 px-5 py-4">
                                    <h2 class="text-base font-black text-slate-900">
                                        Temel Bilgiler
                                    </h2>
                                </div>

                                <div class="grid grid-cols-1 gap-4 p-5 md:grid-cols-2">

                                    <div>
                                        <label asp-for="Ad" class="mb-1 block text-sm font-bold text-slate-600">
                                            Ad
                                        </label>

                                        <input asp-for="Ad"
                                               class="input input-bordered w-full rounded-xl border-slate-300 bg-white" />

                                        <span asp-validation-for="Ad" class="mt-1 block text-sm text-red-600"></span>
                                    </div>

                                    <div>
                                        <label asp-for="Soyad" class="mb-1 block text-sm font-bold text-slate-600">
                                            Soyad
                                        </label>

                                        <input asp-for="Soyad"
                                               class="input input-bordered w-full rounded-xl border-slate-300 bg-white" />

                                        <span asp-validation-for="Soyad" class="mt-1 block text-sm text-red-600"></span>
                                    </div>

                                    <div>
                                        <label asp-for="Eposta" class="mb-1 block text-sm font-bold text-slate-600">
                                            E-posta
                                        </label>

                                        <input asp-for="Eposta"
                                               type="email"
                                               class="input input-bordered w-full rounded-xl border-slate-300 bg-white" />

                                        <span asp-validation-for="Eposta" class="mt-1 block text-sm text-red-600"></span>
                                    </div>

                                    <div>
                                        <label asp-for="Telefon" class="mb-1 block text-sm font-bold text-slate-600">
                                            Telefon
                                        </label>

                                        <input asp-for="Telefon"
                                               class="input input-bordered w-full rounded-xl border-slate-300 bg-white"
                                               placeholder="Telefon numarası" />

                                        <span asp-validation-for="Telefon" class="mt-1 block text-sm text-red-600"></span>
                                    </div>

                                    <div>
                                        <label asp-for="DurumId" class="mb-1 block text-sm font-bold text-slate-600">
                                            Kullanıcı Durumu
                                        </label>

                                        <select asp-for="DurumId"
                                                class="select select-bordered w-full rounded-xl border-slate-300 bg-white">

                                            @foreach (var durum in Model.DurumSecenekleri)
                                            {
                                                <option value="@durum.DurumId">
                                                    @durum.DurumAdi
                                                </option>
                                            }

                                        </select>

                                        <span asp-validation-for="DurumId" class="mt-1 block text-sm text-red-600"></span>
                                    </div>

                                    <div class="md:col-span-2 pt-2">

                                        <p class="mb-2 text-sm font-bold text-slate-600">
                                            Kullanıcı Rolleri
                                        </p>

                                        <div class="grid grid-cols-1 gap-3 md:grid-cols-[minmax(0,1fr)_auto]">
                                            <select id="rolSelect"
                                                    class="select select-bordered w-full rounded-xl border-slate-300 bg-white">
                                                <option value="">Rol seçin</option>
                                                <option value="admin" data-ad="Admin">Admin</option>
                                                <option value="egitmen" data-ad="Eğitmen">Eğitmen</option>
                                                <option value="ogrenci" data-ad="Öğrenci">Öğrenci</option>
                                            </select>

                                            <button type="button"
                                                    id="rolEkleBtn"
                                                    class="btn btn-outline rounded-xl px-6">
                                                Ekle
                                            </button>
                                        </div>

                                        <!-- Hidden inputs for backend -->
                                        <input type="hidden" id="hiddenAdminYetkisi" name="AdminYetkisiVarMi" value="@Model.AdminYetkisiVarMi.ToString().ToLower()" />
                                        <input type="hidden" id="hiddenEgitmenRolu" name="EgitmenRoluVarMi" value="@Model.EgitmenRoluVarMi.ToString().ToLower()" />
                                        <input type="hidden" id="hiddenOgrenciRolu" name="OgrenciRoluVarMi" value="@Model.OgrenciRoluVarMi.ToString().ToLower()" />

                                        <span asp-validation-for="AdminYetkisiVarMi" class="mt-1 block text-sm text-red-600"></span>

                                        <div id="seciliRollerListesi" class="mt-3 flex flex-wrap gap-2"></div>

                                        <p id="rolBosMesaj" class="mt-3 text-sm font-semibold text-slate-500 hidden">
                                            Henüz rol atanmadı.
                                        </p>

                                    </div>

                                </div>

                            </section>

                            <!-- Eğitmen Bilgileri -->
                            @if (Model.EgitmenMi && Model.EgitmenProfilId.HasValue)
                            {
                                <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">

                                    <div class="border-b border-slate-100 px-5 py-4">
                                        <h2 class="text-base font-black text-slate-900">
                                            Eğitmen Bilgileri
                                        </h2>
                                    </div>

                                    <div class="space-y-4 p-5">

                                        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">

                                            <div>
                                                <label asp-for="UzmanlikAlani" class="mb-1 block text-sm font-bold text-slate-600">
                                                    Uzmanlık Alanı
                                                </label>

                                                <input asp-for="UzmanlikAlani"
                                                       class="input input-bordered w-full rounded-xl border-slate-300 bg-white"
                                                       placeholder="Örn: Backend Geliştirme" />

                                                <span asp-validation-for="UzmanlikAlani" class="mt-1 block text-sm text-red-600"></span>
                                            </div>

                                            <div>
                                                <label asp-for="DeneyimYili" class="mb-1 block text-sm font-bold text-slate-600">
                                                    Deneyim Yılı
                                                </label>

                                                <input asp-for="DeneyimYili"
                                                       type="number"
                                                       min="0"
                                                       class="input input-bordered w-full rounded-xl border-slate-300 bg-white" />

                                                <span asp-validation-for="DeneyimYili" class="mt-1 block text-sm text-red-600"></span>
                                            </div>

                                            <div class="md:col-span-2">
                                                <label asp-for="WebsiteUrl" class="mb-1 block text-sm font-bold text-slate-600">
                                                    Website
                                                </label>

                                                <input asp-for="WebsiteUrl"
                                                       class="input input-bordered w-full rounded-xl border-slate-300 bg-white"
                                                       placeholder="https://..." />

                                                <span asp-validation-for="WebsiteUrl" class="mt-1 block text-sm text-red-600"></span>
                                            </div>

                                        </div>

                                        <div>
                                            <label asp-for="Biyografi" class="mb-1 block text-sm font-bold text-slate-600">
                                                Biyografi
                                            </label>

                                            <textarea asp-for="Biyografi"
                                                      rows="5"
                                                      class="textarea textarea-bordered w-full resize-none rounded-xl border-slate-300 bg-white"
                                                      placeholder="Eğitmenin kısa biyografisi"></textarea>

                                            <span asp-validation-for="Biyografi" class="mt-1 block text-sm text-red-600"></span>
                                        </div>

                                        <div>
                                            <p class="mb-2 text-sm font-bold text-slate-600">
                                                Branşlar
                                            </p>

                                            @if (Model.BransSecenekleri.Any())
                                            {
                                                <div class="grid grid-cols-1 gap-3 md:grid-cols-[minmax(0,1fr)_auto]">

                                                    <select id="bransSelect"
                                                            class="select select-bordered w-full rounded-xl border-slate-300 bg-white">

                                                        <option value="">
                                                            Branş seçin
                                                        </option>

                                                        @foreach (var brans in Model.BransSecenekleri.OrderBy(x => x.KategoriAdi))
                                                        {
                                                            <option value="@brans.KategoriId"
                                                                    data-ad="@brans.KategoriAdi">
                                                                @brans.KategoriAdi
                                                            </option>
                                                        }

                                                    </select>

                                                    <button type="button"
                                                            id="bransEkleBtn"
                                                            class="btn btn-outline rounded-xl px-6">
                                                        Ekle
                                                    </button>

                                                </div>

                                                <p class="mt-1 text-xs font-semibold text-slate-400">
                                                    Dropdown açıkken harfe basarak ilgili branşa hızlıca gidebilirsiniz.
                                                </p>

                                                <div id="seciliBransInputlari">

                                                    @foreach (var brans in seciliBranslar)
                                                    {
                                                        <input type="hidden"
                                                               name="SeciliBransIdleri"
                                                               value="@brans.KategoriId"
                                                               data-brans-id="@brans.KategoriId" />
                                                    }

                                                </div>

                                                <div id="seciliBransListesi"
                                                     class="mt-3 flex flex-wrap gap-2">

                                                    @foreach (var brans in seciliBranslar)
                                                    {
                                                        <span data-brans-chip="@brans.KategoriId"
                                                              class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-3 py-1 text-xs font-bold text-blue-700">

                                                            <span>
                                                                @brans.KategoriAdi
                                                            </span>

                                                            <button type="button"
                                                                    data-brans-sil="@brans.KategoriId"
                                                                    class="text-blue-500 hover:text-red-600">
                                                                ×
                                                            </button>

                                                        </span>
                                                    }

                                                </div>

                                                <p id="bransBosMesaj"
                                                   class="mt-3 text-sm font-semibold text-slate-500 @(seciliBranslar.Any() ? "hidden" : "")">
                                                    Henüz branş seçilmedi.
                                                </p>
                                            }
                                            else
                                            {
                                                <p class="text-sm font-semibold text-slate-500">
                                                    Kategori bulunamadı.
                                                </p>
                                            }

                                        </div>

                                    </div>

                                </section>
                            }

                        </div>

                        <!-- Sağ Panel -->
                        <aside class="space-y-5 xl:sticky xl:top-24 xl:h-fit">

                            <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">

                                <h2 class="text-base font-black text-slate-900">
                                    İşlemler
                                </h2>

                                <div class="mt-4 space-y-2">

                                    <button type="submit"
                                            class="btn btn-primary w-full rounded-xl">
                                        Kaydet
                                    </button>

                                    <a asp-controller="AdminKullanici"
                                       asp-action="Detay"
                                       asp-route-id="@Model.KullaniciId"
                                       class="btn btn-outline w-full rounded-xl">
                                        Detaya Dön
                                    </a>

                                    <a asp-controller="AdminKullanici"
                                       asp-action="Kullanicilar"
                                       class="btn btn-outline w-full rounded-xl">
                                        Listeye Dön
                                    </a>

                                </div>

                            </section>

                            <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">

                                <h2 class="text-base font-black text-slate-900">
                                    Roller
                                </h2>

                                <div class="mt-4 flex flex-wrap gap-1.5">

                                    @if (Model.Roller.Any())
                                    {
                                        @foreach (var rol in Model.Roller)
                                        {
                                            <span class="rounded-full px-2.5 py-1 text-xs font-bold @RolBadgeClass(rol)">
                                                @rol
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-bold text-slate-500">
                                            Rol yok
                                        </span>
                                    }

                                </div>

                            </section>

                        </aside>

                    </div>

                </form>

            </div>

        </main>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // ─── Branş Yönetimi ───
            const bransSelect = document.getElementById('bransSelect');
            const bransEkleBtn = document.getElementById('bransEkleBtn');
            const seciliBransInputlari = document.getElementById('seciliBransInputlari');
            const seciliBransListesi = document.getElementById('seciliBransListesi');
            const bransBosMesaj = document.getElementById('bransBosMesaj');

            if (bransSelect && bransEkleBtn && seciliBransInputlari && seciliBransListesi) {

                function bosMesajiGuncelle() {
                    const seciliVarMi = seciliBransInputlari.querySelectorAll('input[name="SeciliBransIdleri"]').length > 0;

                    if (bransBosMesaj) {
                        bransBosMesaj.classList.toggle('hidden', seciliVarMi);
                    }
                }

                function bransVarMi(bransId) {
                    return seciliBransInputlari.querySelector(`input[data-brans-id="${bransId}"]`) !== null;
                }

                function bransEkle() {
                    const bransId = bransSelect.value;
                    const seciliOption = bransSelect.options[bransSelect.selectedIndex];

                    if (!bransId || !seciliOption || bransVarMi(bransId)) {
                        bransSelect.value = '';
                        return;
                    }

                    const bransAdi = seciliOption.dataset.ad || seciliOption.textContent.trim();

                    const input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'SeciliBransIdleri';
                    input.value = bransId;
                    input.dataset.bransId = bransId;

                    seciliBransInputlari.appendChild(input);

                    const chip = document.createElement('span');
                    chip.dataset.bransChip = bransId;
                    chip.className = 'inline-flex items-center gap-2 rounded-full bg-blue-50 px-3 py-1 text-xs font-bold text-blue-700';

                    const text = document.createElement('span');
                    text.textContent = bransAdi;

                    const silBtn = document.createElement('button');
                    silBtn.type = 'button';
                    silBtn.dataset.bransSil = bransId;
                    silBtn.className = 'text-blue-500 hover:text-red-600';
                    silBtn.textContent = '×';

                    chip.appendChild(text);
                    chip.appendChild(silBtn);

                    seciliBransListesi.appendChild(chip);

                    bransSelect.value = '';
                    bosMesajiGuncelle();
                }

                function bransSil(bransId) {
                    const input = seciliBransInputlari.querySelector(`input[data-brans-id="${bransId}"]`);
                    const chip = seciliBransListesi.querySelector(`[data-brans-chip="${bransId}"]`);

                    if (input) {
                        input.remove();
                    }

                    if (chip) {
                        chip.remove();
                    }

                    bosMesajiGuncelle();
                }

                bransEkleBtn.addEventListener('click', bransEkle);

                bransSelect.addEventListener('keydown', function (event) {
                    if (event.key === 'Enter') {
                        event.preventDefault();
                        bransEkle();
                    }
                });

                seciliBransListesi.addEventListener('click', function (event) {
                    const button = event.target.closest('[data-brans-sil]');

                    if (!button) {
                        return;
                    }

                    bransSil(button.dataset.bransSil);
                });

                bosMesajiGuncelle();
            }

            // ─── Rol Yönetimi ───
            const rolSelect = document.getElementById('rolSelect');
            const rolEkleBtn = document.getElementById('rolEkleBtn');
            const seciliRollerListesi = document.getElementById('seciliRollerListesi');
            const rolBosMesaj = document.getElementById('rolBosMesaj');

            const hiddenAdminYetkisi = document.getElementById('hiddenAdminYetkisi');
            const hiddenEgitmenRolu = document.getElementById('hiddenEgitmenRolu');
            const hiddenOgrenciRolu = document.getElementById('hiddenOgrenciRolu');

            if (!rolSelect || !rolEkleBtn || !seciliRollerListesi) {
                return;
            }

            const rolTanimlari = {
                admin: {
                    ad: 'Admin',
                    chipClass: 'bg-slate-900 text-white',
                    silBtnClass: 'text-slate-300 hover:text-red-300',
                    hiddenInput: hiddenAdminYetkisi
                },
                egitmen: {
                    ad: 'Eğitmen',
                    chipClass: 'bg-blue-50 text-blue-700',
                    silBtnClass: 'text-blue-400 hover:text-red-600',
                    hiddenInput: hiddenEgitmenRolu
                },
                ogrenci: {
                    ad: 'Öğrenci',
                    chipClass: 'bg-emerald-50 text-emerald-700',
                    silBtnClass: 'text-emerald-400 hover:text-red-600',
                    hiddenInput: hiddenOgrenciRolu
                }
            };

            function rolAktifMi(rolKey) {
                const tanim = rolTanimlari[rolKey];
                return tanim && tanim.hiddenInput && tanim.hiddenInput.value === 'true';
            }

            function rolBosMesajiGuncelle() {
                const seciliRolVarMi = Object.keys(rolTanimlari).some(function (key) {
                    return rolAktifMi(key);
                });

                if (rolBosMesaj) {
                    rolBosMesaj.classList.toggle('hidden', seciliRolVarMi);
                }
            }

            function dropdownGuncelle() {
                const options = rolSelect.querySelectorAll('option[value]');
                options.forEach(function (option) {
                    if (option.value && rolAktifMi(option.value)) {
                        option.hidden = true;
                        option.disabled = true;
                    } else {
                        option.hidden = false;
                        option.disabled = false;
                    }
                });
                rolSelect.value = '';
            }

            function rolChipOlustur(rolKey) {
                const tanim = rolTanimlari[rolKey];
                if (!tanim) return;

                const chip = document.createElement('span');
                chip.dataset.rolChip = rolKey;
                chip.className = 'inline-flex items-center gap-2 rounded-full px-3 py-1.5 text-xs font-bold ' + tanim.chipClass;

                const text = document.createElement('span');
                text.textContent = tanim.ad;

                const silBtn = document.createElement('button');
                silBtn.type = 'button';
                silBtn.dataset.rolSil = rolKey;
                silBtn.className = silBtn.className = tanim.silBtnClass;
                silBtn.textContent = '×';

                chip.appendChild(text);
                chip.appendChild(silBtn);

                seciliRollerListesi.appendChild(chip);
            }

            function rolleriBaslat() {
                seciliRollerListesi.innerHTML = '';

                Object.keys(rolTanimlari).forEach(function (key) {
                    if (rolAktifMi(key)) {
                        rolChipOlustur(key);
                    }
                });

                rolBosMesajiGuncelle();
                dropdownGuncelle();
            }

            function rolEkle() {
                const rolKey = rolSelect.value;

                if (!rolKey || !rolTanimlari[rolKey] || rolAktifMi(rolKey)) {
                    rolSelect.value = '';
                    return;
                }

                rolTanimlari[rolKey].hiddenInput.value = 'true';
                rolChipOlustur(rolKey);

                rolSelect.value = '';
                rolBosMesajiGuncelle();
                dropdownGuncelle();
            }

            function rolSil(rolKey) {
                const tanim = rolTanimlari[rolKey];
                if (!tanim) return;

                tanim.hiddenInput.value = 'false';

                const chip = seciliRollerListesi.querySelector('[data-rol-chip="' + rolKey + '"]');
                if (chip) {
                    chip.remove();
                }

                rolBosMesajiGuncelle();
                dropdownGuncelle();
            }

            rolEkleBtn.addEventListener('click', rolEkle);

            rolSelect.addEventListener('keydown', function (event) {
                if (event.key === 'Enter') {
                    event.preventDefault();
                    rolEkle();
                }
            });

            seciliRollerListesi.addEventListener('click', function (event) {
                const button = event.target.closest('[data-rol-sil]');
                if (!button) return;

                rolSil(button.dataset.rolSil);
            });

            rolleriBaslat();
        });
    </script>
}